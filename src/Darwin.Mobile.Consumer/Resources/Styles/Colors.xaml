<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Neutral0">#FFFFFF</Color>
    <Color x:Key="Neutral50">#F4F4F4</Color>
    <Color x:Key="Neutral100">#FFF8E7</Color>
    <Color x:Key="Neutral200">#FFF8E7</Color>
    <Color x:Key="Neutral300">#FFF8E7</Color>
    <Color x:Key="NeutralButtonSecondary">#F4F5FA</Color>
    <Color x:Key="Neutral600">#565656</Color>
    <Color x:Key="Neutral700">#565656</Color>
    <Color x:Key="Neutral900">#000000</Color>
    <Color x:Key="DarkAction">#121212</Color>

    <Color x:Key="BrandGold500">#FBE200</Color>
    <Color x:Key="BrandGold300">#FFE36A</Color>
    <Color x:Key="BrandGold50">#FFF8E7</Color>
    <Color x:Key="BrandGold600">#E6B800</Color>
    <Color x:Key="BrandGold700">#B89000</Color>
    <Color x:Key="LoginFieldYellow">#F1D900</Color>
    <Color x:Key="InternalPrimaryButton">#FFDB34</Color>
    <Color x:Key="DiscoverHeaderYellow">#FEDB42</Color>
    <Color x:Key="DiscoverHeaderButton">#FCF3C3</Color>
    <Color x:Key="BrandGoldSurfaceOverlay">#E6FFF8E7</Color>
    <Color x:Key="BusyOverlayColor">#40FFFFFF</Color>

    <Color x:Key="Success500">#006B2D</Color>
    <Color x:Key="Warning500">#B7791F</Color>
    <Color x:Key="Danger500">#A00000</Color>
    <Color x:Key="Info500">#E09F1A</Color>

    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource Neutral50}" />
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource Neutral0}" />
    <SolidColorBrush x:Key="BrushSurfaceMuted" Color="{StaticResource Neutral100}" />
    <SolidColorBrush x:Key="BrushButtonSecondary" Color="{StaticResource NeutralButtonSecondary}" />
    <SolidColorBrush x:Key="BrushDarkAction" Color="{StaticResource DarkAction}" />
    <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource InternalPrimaryButton}" />
    <SolidColorBrush x:Key="BrushDiscoverHeader" Color="{StaticResource DiscoverHeaderYellow}" />
    <SolidColorBrush x:Key="BrushDiscoverHeaderButton" Color="{StaticResource DiscoverHeaderButton}" />
    <SolidColorBrush x:Key="BrushPrimaryLight" Color="{StaticResource BrandGold300}" />
    <SolidColorBrush x:Key="BrushPrimaryPressed" Color="{StaticResource BrandGold600}" />
    <SolidColorBrush x:Key="BrushLoginField" Color="{StaticResource LoginFieldYellow}" />
    <SolidColorBrush x:Key="BrushOnPrimary" Color="{StaticResource Neutral0}" />
    <SolidColorBrush x:Key="BrushOnSurface" Color="{StaticResource Neutral900}" />
    <SolidColorBrush x:Key="BrushOnSurfaceSecondary" Color="{StaticResource Neutral700}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource Neutral100}" />
    <SolidColorBrush x:Key="BrushLink" Color="{StaticResource BrandGold500}" />
    <SolidColorBrush x:Key="BrushLegalLink" Color="{StaticResource Neutral700}" />
    <SolidColorBrush x:Key="BrushImagePlaceholderOverlay" Color="{StaticResource BrandGoldSurfaceOverlay}" />
    <SolidColorBrush x:Key="BrushBusyOverlay" Color="{StaticResource BusyOverlayColor}" />
</ResourceDictionary>
