<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:chips="clr-namespace:Syncfusion.Maui.Toolkit.Chips;assembly=Syncfusion.Maui.Toolkit"
    xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
    x:Class="Darwin.Mobile.Consumer.Views.DiscoverPage"
    x:DataType="vm:DiscoverViewModel"
    Title="{x:Static res:AppResources.DiscoverTitle}"
    BackgroundColor="{StaticResource DiscoverHeaderYellow}">

    <Grid Background="{StaticResource BrushDiscoverHeader}">
        <pullToRefresh:SfPullToRefresh RefreshCommand="{Binding RefreshCommand}"
                                       IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}"
                                       ProgressColor="{StaticResource InternalPrimaryButton}"
                                       ProgressBackground="{StaticResource Neutral0}">
            <pullToRefresh:SfPullToRefresh.PullableContent>
                <CollectionView x:Name="DiscoverCollectionView"
                                Background="{StaticResource BrushBackground}"
                                ItemsSource="{Binding DisplayItems}"
                                SelectionMode="Single"
                                SelectionChanged="OnDiscoverItemSelected"
                                ItemSizingStrategy="MeasureFirstItem"
                                ItemsUpdatingScrollMode="KeepScrollOffset">
                    <CollectionView.Header>
                        <Border Background="{StaticResource BrushDiscoverHeader}"
                                StrokeThickness="0">
                            <VerticalStackLayout Padding="20,18,20,16" Spacing="12">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Margin="0,0,0,2">
                                    <Border Grid.Column="0"
                                            WidthRequest="48"
                                            HeightRequest="48"
                                            Padding="0"
                                            Background="{StaticResource BrushDarkAction}"
                                            Stroke="{StaticResource BrandGold50}"
                                            StrokeThickness="1"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="24" />
                                        </Border.StrokeShape>
                                        <Grid>
                                            <Image Source="{Binding CurrentUserProfileImageUrl}"
                                                   Aspect="AspectFill"
                                                   IsVisible="{Binding HasCurrentUserProfileImage}" />
                                            <Label Text="{Binding CurrentUserInitials}"
                                                   IsVisible="{Binding HasCurrentUserProfileImage, Converter={StaticResource InverseBoolConverter}}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   FontAttributes="Bold"
                                                   FontSize="14"
                                                   TextColor="{StaticResource Neutral0}" />
                                        </Grid>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding DiscoverGreetingText}"
                                               FontAttributes="Bold"
                                               FontSize="14"
                                               TextColor="{StaticResource Neutral900}" />
                                        <Label Text="{Binding DiscoverGreetingSubtitle}"
                                               FontSize="12"
                                               TextColor="{StaticResource Neutral700}" />
                                    </VerticalStackLayout>
                                    <Grid Grid.Column="2" WidthRequest="46" HeightRequest="46" VerticalOptions="Center">
                                        <Button Text="🔔"
                                                Command="{Binding OpenNotificationsCommand}"
                                                Background="{StaticResource BrushDiscoverHeaderButton}"
                                                TextColor="{StaticResource Neutral900}"
                                                CornerRadius="23"
                                                Padding="0"
                                                FontSize="19" />
                                        <Border IsVisible="{Binding HasUnreadNotifications}"
                                                Background="{StaticResource BrushDarkAction}"
                                                Padding="4,1"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                MinimumWidthRequest="18"
                                                HeightRequest="18">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="9" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding UnreadNotificationsText}"
                                                   FontAttributes="Bold"
                                                   FontSize="9"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center"
                                                   TextColor="{StaticResource Neutral0}" />
                                        </Border>
                                    </Grid>
                                </Grid>

                                <Border Stroke="{StaticResource BrandGold50}"
                                        StrokeThickness="1"
                                        Padding="0"
                                        Background="Transparent">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="22" />
                                    </Border.StrokeShape>
                                    <Grid HeightRequest="148">
                                        <Image Source="loyan_gold_card_background.png"
                                               Aspect="Fill" />
                                        <VerticalStackLayout Padding="18,16" Spacing="10">
                                            <Label Text="{x:Static res:AppResources.DiscoverTitle}"
                                                   Style="{StaticResource TitleLabelStyle}" />
                                            <Label Text="{x:Static res:AppResources.DiscoverExploreHeadline}"
                                                   Style="{StaticResource BodyLabelStyle}"
                                                   MaxLines="2" />
                                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                                <Grid Grid.Column="0">
                                                    <buttons:SfButton Text="{x:Static res:AppResources.DiscoverMyBusinessesTab}"
                                                                      Command="{Binding ShowJoinedTabCommand}"
                                                                      Style="{StaticResource DiscoverHeaderDarkButtonStyle}" />
                                                    <Image Source="icon_business_white.svg"
                                                           WidthRequest="24"
                                                           HeightRequest="24"
                                                           HorizontalOptions="Start"
                                                           VerticalOptions="Center"
                                                           Margin="12,0,0,0"
                                                           InputTransparent="True" />
                                                </Grid>
                                                <Grid Grid.Column="1">
                                                    <buttons:SfButton Text="{x:Static res:AppResources.DiscoverExploreTab}"
                                                                      Command="{Binding ShowExploreTabCommand}"
                                                                      Style="{StaticResource DiscoverHeaderButtonStyle}" />
                                                    <Image Source="icon_compass_black.svg"
                                                           WidthRequest="24"
                                                           HeightRequest="24"
                                                           HorizontalOptions="Start"
                                                           VerticalOptions="Center"
                                                           Margin="12,0,0,0"
                                                           InputTransparent="True" />
                                                </Grid>
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>

                            <VerticalStackLayout IsVisible="{Binding IsJoinedTabSelected}" Spacing="14">
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Border Grid.Column="0" Style="{StaticResource HeaderStatTileBorderStyle}" Padding="14,10">
                                        <Grid ColumnDefinitions="78,*" ColumnSpacing="10" VerticalOptions="Center">
                                            <Label Grid.Column="0"
                                                   Text="{x:Static res:AppResources.DiscoverJoinedBusinessesTitle}"
                                                   Style="{StaticResource CaptionLabelStyle}"
                                                   WidthRequest="72"
                                                   LineBreakMode="WordWrap"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding JoinedBusinessCount}"
                                                   Style="{StaticResource MetricValueLabelStyle}"
                                                   HorizontalTextAlignment="End"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource HeaderStatTileBorderStyle}" Padding="14,10">
                                        <Grid ColumnDefinitions="70,*" ColumnSpacing="10" VerticalOptions="Center">
                                            <Label Grid.Column="0"
                                                   Text="{x:Static res:AppResources.DiscoverTotalPointsTitle}"
                                                   Style="{StaticResource CaptionLabelStyle}"
                                                   WidthRequest="64"
                                                   LineBreakMode="WordWrap"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding TotalJoinedPointsBalance}"
                                                   Style="{StaticResource MetricValueLabelStyle}"
                                                   HorizontalTextAlignment="End"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Label Text="{x:Static res:AppResources.DiscoverMyBusinessesEmpty}"
                                       Style="{StaticResource BodyLabelStyle}"
                                       IsVisible="{Binding HasJoinedAccounts, Converter={StaticResource InverseBoolConverter}}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout IsVisible="{Binding IsExploreTabSelected}" Spacing="14">
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <VerticalStackLayout Spacing="12">
                                        <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.DiscoverSearchPlaceholder}"
                                                                       Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                            <Entry Text="{Binding SearchQuery}"
                                                   Placeholder="{x:Static res:AppResources.DiscoverSearchPlaceholder}"
                                                   ReturnType="Search"
                                                   ReturnCommand="{Binding SearchCommand}"
                                                   Style="{StaticResource FormEntryStyle}" />
                                        </inputLayout:SfTextInputLayout>
                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="{x:Static res:AppResources.DiscoverCategoryFilterLabel}"
                                                   Style="{StaticResource CaptionLabelStyle}" />
                                            <chips:SfChipGroup ItemsSource="{Binding CategoryKinds}"
                                                               DisplayMemberPath="DisplayName"
                                                               SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                                               ChipType="Choice"
                                                               ChoiceMode="SingleOrNone"
                                                               ChipCornerRadius="10"
                                                               ChipBackground="{StaticResource BrushSurface}"
                                                               ChipStroke="{StaticResource BrandGold50}"
                                                               ChipStrokeThickness="1"
                                                               ChipTextColor="{StaticResource Neutral900}"
                                                               ChipTextSize="13"
                                                               SelectedChipBackground="{StaticResource BrushPrimary}"
                                                               SelectedChipTextColor="{StaticResource Neutral900}"
                                                               SelectionIndicatorColor="{StaticResource InternalPrimaryButton}" />
                                        </VerticalStackLayout>
                                        <Border Style="{StaticResource MutedCardBorderStyle}">
                                            <VerticalStackLayout Spacing="10">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                        <Label Text="{x:Static res:AppResources.DiscoverNearbyOnlyLabel}" FontAttributes="Bold" TextColor="{StaticResource Neutral900}" />
                                                        <Label Text="{x:Static res:AppResources.DiscoverNearbyRadiusLabel}" Style="{StaticResource CaptionLabelStyle}" />
                                                    </VerticalStackLayout>
                                                    <Switch Grid.Column="1" IsToggled="{Binding IsNearbyOnly}" OnColor="{StaticResource InternalPrimaryButton}" />
                                                </Grid>
                                                <chips:SfChipGroup ItemsSource="{Binding NearbyRadiusChoices}"
                                                                   DisplayMemberPath="DisplayName"
                                                                   SelectedItem="{Binding SelectedNearbyRadiusOption, Mode=TwoWay}"
                                                                   IsVisible="{Binding IsNearbyOnly}"
                                                                   ChipType="Choice"
                                                                   ChoiceMode="Single"
                                                                   ChipCornerRadius="10"
                                                                   ChipBackground="{StaticResource BrushSurface}"
                                                                   ChipStroke="{StaticResource BrandGold50}"
                                                                   ChipStrokeThickness="1"
                                                                   ChipTextColor="{StaticResource Neutral900}"
                                                                   ChipTextSize="13"
                                                                   SelectedChipBackground="{StaticResource BrushPrimary}"
                                                                   SelectedChipTextColor="{StaticResource Neutral900}"
                                                                   SelectionIndicatorColor="{StaticResource InternalPrimaryButton}" />
                                            </VerticalStackLayout>
                                        </Border>
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                            <Grid Grid.Column="0">
                                                <buttons:SfButton Text="{x:Static res:AppResources.DiscoverSearchButton}"
                                                                  Command="{Binding SearchCommand}"
                                                                  Style="{StaticResource DiscoverHeaderButtonStyle}" />
                                                <Image Source="icon_search_black.svg"
                                                       WidthRequest="24"
                                                       HeightRequest="24"
                                                       HorizontalOptions="Start"
                                                       VerticalOptions="Center"
                                                       Margin="12,0,0,0"
                                                       InputTransparent="True" />
                                            </Grid>
                                            <Grid Grid.Column="1">
                                                <buttons:SfButton Text="{x:Static res:AppResources.DiscoverClearFiltersButton}"
                                                                  Command="{Binding ClearFiltersCommand}"
                                                                  Style="{StaticResource DiscoverHeaderButtonStyle}" />
                                                <Image Source="icon_clear_black.svg"
                                                       WidthRequest="24"
                                                       HeightRequest="24"
                                                       HorizontalOptions="Start"
                                                       VerticalOptions="Center"
                                                       Margin="12,0,0,0"
                                                       InputTransparent="True" />
                                            </Grid>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>

                                <Border x:Name="ExploreMapFrame" Style="{StaticResource CardBorderStyle}" Padding="0" IsVisible="False">
                                    <ContentView x:Name="ExploreMapHost" HeightRequest="220" />
                                </Border>

                                <Label Text="{x:Static res:AppResources.DiscoverExploreEmpty}"
                                       Style="{StaticResource BodyLabelStyle}"
                                       IsVisible="{Binding HasExploreResults, Converter={StaticResource InverseBoolConverter}}" />
                            </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </CollectionView.Header>

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DiscoverDisplayItem">
                            <VerticalStackLayout Padding="16,3,16,3">
                                <Border Style="{StaticResource DiscoverListCardBorderStyle}"
                                        Margin="1,3"
                                        Padding="0"
                                        IsVisible="{Binding IsJoinedAccount}">
                                    <Grid ColumnDefinitions="0.95*,2*" ColumnSpacing="10" MinimumHeightRequest="126">
                                        <Border Grid.Column="0" Padding="0" Background="{StaticResource BrushMuted}" StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="10" />
                                            </Border.StrokeShape>
                                            <Grid>
                                                <Image Source="{Binding MainImageUrl}" Aspect="AspectFill" IsVisible="{Binding HasMainImage}" />
                                                <Label Text="{Binding BusinessInitials}" IsVisible="{Binding HasMainImage, Converter={StaticResource InverseBoolConverter}}" HorizontalOptions="Center" VerticalOptions="Center" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Neutral900}" />
                                            </Grid>
                                        </Border>
                                        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" RowSpacing="8" Padding="0,12,12,12">
                                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <Border Grid.Column="0" WidthRequest="42" HeightRequest="42" Padding="0" Background="{StaticResource BrushDarkAction}" Stroke="{StaticResource BrandGold50}" StrokeThickness="1">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="21" />
                                                    </Border.StrokeShape>
                                                    <Grid>
                                                        <Image Source="{Binding ProfileImageUrl}" Aspect="AspectFill" IsVisible="{Binding HasProfileImage}" />
                                                        <Label Text="{Binding BusinessInitials}" IsVisible="{Binding HasProfileImage, Converter={StaticResource InverseBoolConverter}}" HorizontalOptions="Center" VerticalOptions="Center" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Neutral0}" />
                                                    </Grid>
                                                </Border>
                                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                                    <Label Text="{Binding BusinessName}" FontSize="17" FontAttributes="Bold" TextColor="{StaticResource Neutral900}" LineBreakMode="WordWrap" MaxLines="2" />
                                                    <Label Text="{Binding JoinedAccount.PointsBalance, StringFormat='{0} points'}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                                                </VerticalStackLayout>
                                            </Grid>
                                            <Grid Grid.Row="2">
                                                <buttons:SfButton Text="{x:Static res:AppResources.DiscoverOpenQrButton}" Clicked="OnOpenQrClicked" CommandParameter="{Binding BusinessId}" Style="{StaticResource DiscoverListPrimaryActionButtonStyle}" />
                                                <Image Source="icon_qr_black.svg" WidthRequest="24" HeightRequest="24" HorizontalOptions="Start" VerticalOptions="Center" Margin="12,0,0,0" InputTransparent="True" />
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource DiscoverListCardBorderStyle}"
                                        Margin="1,3"
                                        Padding="0"
                                        IsVisible="{Binding IsExploreBusiness}">
                                    <Grid ColumnDefinitions="0.95*,2*" ColumnSpacing="10" MinimumHeightRequest="126">
                                        <Border Grid.Column="0" Padding="0" Background="{StaticResource BrushMuted}" StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="10" />
                                            </Border.StrokeShape>
                                            <Grid>
                                                <Image Source="{Binding MainImageUrl}" Aspect="AspectFill" IsVisible="{Binding HasMainImage}" />
                                                <Label Text="{Binding BusinessInitials}" IsVisible="{Binding HasMainImage, Converter={StaticResource InverseBoolConverter}}" HorizontalOptions="Center" VerticalOptions="Center" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Neutral900}" />
                                            </Grid>
                                        </Border>
                                        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" RowSpacing="8" Padding="0,12,12,12">
                                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <Border Grid.Column="0" WidthRequest="42" HeightRequest="42" Padding="0" Background="{StaticResource BrushDarkAction}" Stroke="{StaticResource BrandGold50}" StrokeThickness="1">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="21" />
                                                    </Border.StrokeShape>
                                                    <Grid>
                                                        <Image Source="{Binding ProfileImageUrl}" Aspect="AspectFill" IsVisible="{Binding HasProfileImage}" />
                                                        <Label Text="{Binding BusinessInitials}" IsVisible="{Binding HasProfileImage, Converter={StaticResource InverseBoolConverter}}" HorizontalOptions="Center" VerticalOptions="Center" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Neutral0}" />
                                                    </Grid>
                                                </Border>
                                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                                    <Label Text="{Binding BusinessName}" FontSize="17" FontAttributes="Bold" TextColor="{StaticResource Neutral900}" LineBreakMode="WordWrap" MaxLines="2" />
                                                    <Label Text="{Binding ExploreItem.Business.Category, StringFormat='{x:Static res:AppResources.BusinessCategoryFormat}'}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding ExploreItem.Business.Category, Converter={StaticResource NullCheckConverter}}" />
                                                    <Label Text="{Binding ExploreItem.Business.City}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding ExploreItem.Business.City, Converter={StaticResource NullCheckConverter}}" />
                                                </VerticalStackLayout>
                                            </Grid>
                                            <Border Grid.Row="2" Style="{StaticResource MutedCardBorderStyle}" Padding="10,8" IsVisible="{Binding ExploreItem.IsJoined}" HorizontalOptions="Start">
                                                <Label Text="{x:Static res:AppResources.DiscoverAlreadyJoinedLabel}" FontSize="12" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.Footer>
                        <BoxView HeightRequest="28" Color="Transparent" />
                    </CollectionView.Footer>
                </CollectionView>
            </pullToRefresh:SfPullToRefresh.PullableContent>
        </pullToRefresh:SfPullToRefresh>
    </Grid>
</ContentPage>
