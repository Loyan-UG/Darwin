<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    x:Class="Darwin.Mobile.Consumer.Views.ResetPasswordPage"
    x:DataType="vm:ResetPasswordViewModel"
    NavigationPage.HasNavigationBar="False"
    Title="{x:Static res:AppResources.ResetPasswordTitle}"
    BackgroundColor="{StaticResource BrandGold500}">

    <ScrollView>
        <VerticalStackLayout Padding="24,12,24,24" Spacing="18">
            <Border Style="{StaticResource CardBorderStyle}"
                    Background="Transparent"
                    StrokeThickness="0"
                    Padding="0">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static res:AppResources.ResetPasswordTitle}"
                           Style="{StaticResource TitleLabelStyle}"
                           TextColor="{StaticResource Neutral900}" />
                    <Label Text="{x:Static res:AppResources.ResetPasswordDescription}"
                           Style="{StaticResource BodyLabelStyle}"
                           TextColor="{StaticResource Neutral900}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}"
                    Background="Transparent"
                    StrokeThickness="0"
                    Padding="0">
                <VerticalStackLayout Spacing="12">
                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.EmailLabel}"
                                                   ContainerType="Filled"
                                                   Stroke="{StaticResource LoginFieldYellow}"
                                                   ContainerBackground="{StaticResource LoginFieldYellow}"
                                                   OutlineCornerRadius="8"
                                                   FocusedStrokeThickness="0"
                                                   UnfocusedStrokeThickness="0"
                                                   InputViewPadding="12,2">
                        <Entry Text="{Binding Email}"
                               Keyboard="Email"
                               Placeholder="{x:Static res:AppResources.EmailPlaceholder}"
                               Style="{StaticResource FormEntryStyle}"
                               BackgroundColor="Transparent"
                               HeightRequest="40" />
                    </inputLayout:SfTextInputLayout>

                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.ResetPasswordTokenLabel}"
                                                   ContainerType="Filled"
                                                   Stroke="{StaticResource LoginFieldYellow}"
                                                   ContainerBackground="{StaticResource LoginFieldYellow}"
                                                   OutlineCornerRadius="8"
                                                   FocusedStrokeThickness="0"
                                                   UnfocusedStrokeThickness="0"
                                                   InputViewPadding="12,2">
                        <Entry Text="{Binding Token}"
                               Placeholder="{x:Static res:AppResources.ResetPasswordTokenPlaceholder}"
                               Style="{StaticResource FormEntryStyle}"
                               BackgroundColor="Transparent"
                               HeightRequest="40" />
                    </inputLayout:SfTextInputLayout>

                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.NewPasswordLabel}"
                                                   ContainerType="Filled"
                                                   Stroke="{StaticResource LoginFieldYellow}"
                                                   ContainerBackground="{StaticResource LoginFieldYellow}"
                                                   OutlineCornerRadius="8"
                                                   FocusedStrokeThickness="0"
                                                   UnfocusedStrokeThickness="0"
                                                   InputViewPadding="12,2"
                                                   EnablePasswordVisibilityToggle="True">
                        <Entry Text="{Binding NewPassword}"
                               IsPassword="True"
                               Placeholder="{x:Static res:AppResources.LoginPasswordPlaceholder}"
                               Style="{StaticResource FormEntryStyle}"
                               BackgroundColor="Transparent"
                               HeightRequest="40" />
                    </inputLayout:SfTextInputLayout>

                    <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.ConfirmNewPasswordLabel}"
                                                   ContainerType="Filled"
                                                   Stroke="{StaticResource LoginFieldYellow}"
                                                   ContainerBackground="{StaticResource LoginFieldYellow}"
                                                   OutlineCornerRadius="8"
                                                   FocusedStrokeThickness="0"
                                                   UnfocusedStrokeThickness="0"
                                                   InputViewPadding="12,2"
                                                   EnablePasswordVisibilityToggle="True">
                        <Entry Text="{Binding ConfirmNewPassword}"
                               IsPassword="True"
                               Placeholder="{x:Static res:AppResources.LoginPasswordPlaceholder}"
                               Style="{StaticResource FormEntryStyle}"
                               BackgroundColor="Transparent"
                               HeightRequest="40" />
                    </inputLayout:SfTextInputLayout>
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorLabelStyle}"
                   IsVisible="{Binding HasError}" />

            <Label Text="{Binding SuccessMessage}"
                   Style="{StaticResource SuccessLabelStyle}"
                   IsVisible="{Binding HasSuccess}" />

            <buttons:SfButton Text="{x:Static res:AppResources.ResetPasswordActionButton}"
                              Style="{StaticResource AuthPrimaryButtonStyle}"
                              Command="{Binding ResetPasswordCommand}" />

            <Button Text="{x:Static res:AppResources.RegisterReturnToLoginButton}"
                    Style="{StaticResource AuthSecondaryButtonStyle}"
                    HorizontalOptions="Center"
                    Clicked="OnReturnToLoginClicked" />

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="{StaticResource Neutral900}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
