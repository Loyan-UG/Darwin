<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    x:Class="Darwin.Mobile.Consumer.Views.ProfilePage"
    x:DataType="vm:ProfileViewModel"
    Title="{x:Static res:AppResources.ProfileTitle}">

    <Grid>
        <pullToRefresh:SfPullToRefresh RefreshCommand="{Binding RefreshCommand}"
                                       ProgressColor="{StaticResource InternalPrimaryButton}"
                                       ProgressBackground="{StaticResource Neutral0}">
            <pullToRefresh:SfPullToRefresh.PullableContent>
                <ScrollView>
                    <VerticalStackLayout Padding="20,16,20,22" Spacing="14">
                <Border Style="{StaticResource InternalPageHeaderBorderStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{x:Static res:AppResources.ProfileSectionTitle}"
                               Style="{StaticResource TitleLabelStyle}" />
                        <Label Text="{Binding Email}"
                               Style="{StaticResource BodyLabelStyle}" />
                        <Label Text="{Binding SuccessMessage}"
                               Style="{StaticResource SuccessLabelStyle}"
                               IsVisible="{Binding HasSuccess}" />
                        <Label Text="{Binding ErrorMessage}"
                               Style="{StaticResource ErrorLabelStyle}"
                               IsVisible="{Binding HasError}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <Border Grid.Column="0"
                                    WidthRequest="64"
                                    HeightRequest="64"
                                    Padding="0"
                                    Background="{StaticResource BrushDarkAction}"
                                    Stroke="{StaticResource BrandGold50}"
                                    StrokeThickness="1"
                                    VerticalOptions="Start">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="32" />
                                </Border.StrokeShape>
                                <Grid>
                                    <Image Source="{Binding ProfileImageUrl}"
                                           Aspect="AspectFill"
                                           IsVisible="{Binding HasProfileImage}" />
                                    <Label Text="{Binding ProfileInitials}"
                                           IsVisible="{Binding HasProfileImage, Converter={StaticResource InverseBoolConverter}}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           FontAttributes="Bold"
                                           FontSize="18"
                                           TextColor="{StaticResource Neutral0}" />
                                </Grid>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                <Label Text="{x:Static res:AppResources.ProfileAvatarTitle}"
                                       Style="{StaticResource SectionHeadingLabelStyle}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <buttons:SfButton Grid.Column="0"
                                                      Text="{x:Static res:AppResources.ProfileAvatarUploadButton}"
                                                      Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                                      Command="{Binding UploadProfileImageCommand}" />
                                    <buttons:SfButton Grid.Column="1"
                                                      Text="{x:Static res:AppResources.ProfileAvatarRemoveButton}"
                                                      Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                                      Command="{Binding RemoveProfileImageCommand}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="{x:Static res:AppResources.ProfileSectionTitle}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.FirstNameLabel}"
                                                               Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                    <Entry Text="{Binding FirstName}" Style="{StaticResource FormEntryStyle}" />
                                </inputLayout:SfTextInputLayout>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.LastNameLabel}"
                                                               Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                    <Entry Text="{Binding LastName}" Style="{StaticResource FormEntryStyle}" />
                                </inputLayout:SfTextInputLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.EmailLabel}"
                                                       Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                            <Entry Text="{Binding Email}" IsReadOnly="True" Style="{StaticResource FormEntryStyle}" />
                        </inputLayout:SfTextInputLayout>

                        <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.PhoneLabel}"
                                                       Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                            <Entry Text="{Binding PhoneE164}" Placeholder="{x:Static res:AppResources.ProfilePhonePlaceholder}" Keyboard="Telephone" Style="{StaticResource FormEntryStyle}" />
                        </inputLayout:SfTextInputLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.LocaleLabel}"
                                                               Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                    <Entry Text="{Binding Locale}" Placeholder="{x:Static res:AppResources.ProfileLocalePlaceholder}" Style="{StaticResource FormEntryStyle}" />
                                </inputLayout:SfTextInputLayout>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.CurrencyLabel}"
                                                               Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                    <Entry Text="{Binding Currency}" Placeholder="{x:Static res:AppResources.ProfileCurrencyPlaceholder}" Style="{StaticResource FormEntryStyle}" />
                                </inputLayout:SfTextInputLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.TimezoneLabel}"
                                                       Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                            <Entry Text="{Binding Timezone}" Placeholder="{x:Static res:AppResources.ProfileTimezonePlaceholder}" Style="{StaticResource FormEntryStyle}" />
                        </inputLayout:SfTextInputLayout>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <buttons:SfButton Grid.Column="0"
                                              Text="{x:Static res:AppResources.SaveProfileButton}"
                                              Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                              Command="{Binding SaveProfileCommand}" />
                            <buttons:SfButton Grid.Column="1"
                                              Text="{x:Static res:AppResources.SettingsDeleteAccountButton}"
                                              Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                              Clicked="OnAccountDeletionClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static res:AppResources.ProfilePhoneVerificationSectionTitle}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />
                        <Label Text="{Binding PhoneVerificationReadinessText}"
                               Style="{StaticResource BodyLabelStyle}" />
                        <Label Text="{Binding PhoneVerificationStatusMessage}"
                               Style="{StaticResource SecondaryBodyLabelStyle}"
                               IsVisible="{Binding HasPhoneVerificationStatus}" />

                        <VerticalStackLayout Spacing="4" IsVisible="{Binding ShouldShowPhoneVerificationRequest}">
                            <buttons:SfButton Text="{x:Static res:AppResources.ProfilePhoneVerificationRequestButton}"
                                              Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                              Command="{Binding RequestPhoneVerificationCommand}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8" IsVisible="{Binding ShouldShowPhoneVerificationCodeEntry}">
                            <Label Text="{x:Static res:AppResources.ProfilePhoneVerificationCodeLabel}"
                                   Style="{StaticResource CaptionLabelStyle}" />
                            <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.ProfilePhoneVerificationCodeLabel}"
                                                           Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                <Entry Text="{Binding PhoneVerificationCode}"
                                       Placeholder="{x:Static res:AppResources.ProfilePhoneVerificationCodePlaceholder}"
                                       Keyboard="Numeric"
                                       Style="{StaticResource FormEntryStyle}" />
                            </inputLayout:SfTextInputLayout>

                            <buttons:SfButton Text="{x:Static res:AppResources.ProfilePhoneVerificationConfirmButton}"
                                              Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                              Command="{Binding ConfirmPhoneVerificationCommand}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static res:AppResources.ProfilePushRegistrationSectionTitle}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />

                        <buttons:SfButton Text="{x:Static res:AppResources.ProfilePushOpenSettingsButton}"
                                          Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                          Command="{Binding OpenNotificationSettingsCommand}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static res:AppResources.ProfileCustomerContextSectionTitle}"
                               Style="{StaticResource SectionHeadingLabelStyle}" />

                        <Label Text="{x:Static res:AppResources.ProfileCustomerContextEmpty}"
                               Style="{StaticResource BodyLabelStyle}"
                               IsVisible="{Binding HasLinkedCustomerContext, Converter={StaticResource InverseBoolConverter}}" />

                        <VerticalStackLayout Spacing="8" IsVisible="{Binding HasLinkedCustomerContext}">
                            <Label Text="{Binding LinkedCustomerDisplayName, StringFormat='{x:Static res:AppResources.ProfileCustomerDisplayNameFormat}'}"
                                   Style="{StaticResource BodyLabelStyle}"
                                   LineBreakMode="WordWrap" />
                            <Label Text="{Binding LinkedCustomerCompanyName, StringFormat='{x:Static res:AppResources.ProfileCustomerCompanyFormat}'}"
                                   Style="{StaticResource SecondaryBodyLabelStyle}"
                                   IsVisible="{Binding HasLinkedCustomerCompanyName}" />
                            <Label Text="{Binding LinkedCustomerSegmentsSummary, StringFormat='{x:Static res:AppResources.ProfileCustomerSegmentsFormat}'}"
                                   Style="{StaticResource SecondaryBodyLabelStyle}"
                                   LineBreakMode="WordWrap"
                                   IsVisible="{Binding HasLinkedCustomerSegments}" />
                            <Label Text="{Binding LinkedCustomerLastInteractionText}"
                                   Style="{StaticResource SecondaryBodyLabelStyle}"
                                   LineBreakMode="WordWrap" />
                            <buttons:SfButton Text="{x:Static res:AppResources.ProfileViewCustomerContextButton}"
                                              Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                              Clicked="OnViewCustomerContextClicked" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
                    </VerticalStackLayout>
                </ScrollView>
            </pullToRefresh:SfPullToRefresh.PullableContent>
        </pullToRefresh:SfPullToRefresh>

        <Grid BackgroundColor="{StaticResource BusyOverlayColor}"
              IsVisible="{Binding IsBusy}"
              InputTransparent="False">
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12">
                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="{StaticResource InternalPrimaryButton}" />
                <Label Text="{x:Static res:AppResources.ProfileTitle}"
                       Style="{StaticResource SecondaryBodyLabelStyle}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
