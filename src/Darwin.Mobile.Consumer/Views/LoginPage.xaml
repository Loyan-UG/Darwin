<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
    x:Class="Darwin.Mobile.Consumer.Views.LoginPage"
    x:DataType="vm:LoginViewModel"
    Title="{x:Static res:AppResources.LoginTitle}"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{StaticResource BrandGold500}">

    <Grid RowDefinitions="Auto,Auto,*"
          Padding="24,10,24,24"
          RowSpacing="10">
        <Image Grid.Row="0"
               Source="loyan_logo_login_dark.png"
               Aspect="AspectFit"
               HeightRequest="34"
               HorizontalOptions="Fill"
               VerticalOptions="Start"
               Margin="0,0,0,2" />

        <Image Grid.Row="1"
               Source="login_header.png"
               Aspect="AspectFit"
               HeightRequest="220"
               HorizontalOptions="Fill"
               VerticalOptions="Center"
               Margin="-10,14,-10,0" />

        <ScrollView Grid.Row="2"
                    x:Name="RootScrollView"
                    Margin="0,34,0,0">
            <VerticalStackLayout Spacing="8">
                <Label Text="{x:Static res:AppResources.LoginTitle}"
                       Style="{StaticResource TitleLabelStyle}"
                       TextColor="{StaticResource Neutral900}"
                       HorizontalOptions="Center"
                       Margin="0,0,0,2" />

            <Border Style="{StaticResource CardBorderStyle}"
                    Background="Transparent"
                    StrokeThickness="0"
                    Padding="0"
                    Margin="0">
                <VerticalStackLayout Spacing="5">
                    <Border Background="{StaticResource BrushLoginField}"
                            StrokeThickness="0"
                            HeightRequest="42">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="9" />
                        </Border.StrokeShape>
                        <inputLayout:SfTextInputLayout x:Name="EmailInputLayout"
                                                       ContainerType="Filled"
                                                       Stroke="{StaticResource LoginFieldYellow}"
                                                       ContainerBackground="{StaticResource LoginFieldYellow}"
                                                       OutlineCornerRadius="9"
                                                       FocusedStrokeThickness="0"
                                                       UnfocusedStrokeThickness="0"
                                                       InputViewPadding="12,4"
                                                       Padding="0"
                                                       HeightRequest="42">
                            <Entry x:Name="EmailEntry"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   Placeholder="{x:Static res:AppResources.LoginEmailPlaceholder}"
                                   TextColor="{StaticResource Neutral900}"
                                   PlaceholderColor="{StaticResource Neutral900}"
                                   BackgroundColor="Transparent"
                                   HeightRequest="40"
                                   FontSize="16"
                                   ClearButtonVisibility="WhileEditing"
                                   Focused="OnEmailEntryFocused"
                                   Unfocused="OnEmailEntryUnfocused" />
                        </inputLayout:SfTextInputLayout>
                    </Border>

                    <Border Background="{StaticResource BrushLoginField}"
                            StrokeThickness="0"
                            HeightRequest="42">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="9" />
                        </Border.StrokeShape>
                        <inputLayout:SfTextInputLayout x:Name="PasswordInputLayout"
                                                       ContainerType="Filled"
                                                       Stroke="{StaticResource LoginFieldYellow}"
                                                       ContainerBackground="{StaticResource LoginFieldYellow}"
                                                       OutlineCornerRadius="9"
                                                       FocusedStrokeThickness="0"
                                                       UnfocusedStrokeThickness="0"
                                                       EnablePasswordVisibilityToggle="True"
                                                       InputViewPadding="12,4"
                                                       Padding="0"
                                                       HeightRequest="42">
                            <Entry x:Name="PasswordEntry"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   Placeholder="{x:Static res:AppResources.LoginPasswordPlaceholder}"
                                   TextColor="{StaticResource Neutral900}"
                                   PlaceholderColor="{StaticResource Neutral900}"
                                   BackgroundColor="Transparent"
                                   HeightRequest="40"
                                   FontSize="16"
                                   Focused="OnPasswordEntryFocused"
                                   Unfocused="OnPasswordEntryUnfocused" />
                        </inputLayout:SfTextInputLayout>
                    </Border>

                    <Label Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorLabelStyle}"
                           IsVisible="{Binding HasError}" />

                    <Label Text="{Binding InfoMessage}"
                           TextColor="{StaticResource Neutral900}"
                           FontSize="13"
                           IsVisible="{Binding HasInfo}" />

                    <buttons:SfButton Text="{x:Static res:AppResources.LoginButton}"
                                      Style="{StaticResource AuthPrimaryButtonStyle}"
                                      Margin="0,4,0,0"
                                      Command="{Binding LoginCommand}"
                                      IsEnabled="{Binding IsLoginReady}" />

                    <Grid ColumnDefinitions="*,Auto,*"
                          Margin="0,3,0,0"
                          VerticalOptions="Center">
                        <BoxView Grid.Column="0"
                                 HeightRequest="1"
                                 Color="{StaticResource Neutral900}"
                                 Opacity="0.24"
                                 VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{x:Static res:AppResources.ExternalLoginDivider}"
                               TextColor="{StaticResource Neutral900}"
                               FontSize="12"
                               FontAttributes="Bold"
                               Margin="10,0" />
                        <BoxView Grid.Column="2"
                                 HeightRequest="1"
                                 Color="{StaticResource Neutral900}"
                                 Opacity="0.24"
                                 VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8"
                          Margin="0,0,0,0">
                        <Button Grid.Column="0"
                                Text="{x:Static res:AppResources.ExternalLoginGoogleComingSoon}"
                                IsEnabled="False"
                                BackgroundColor="{StaticResource LoginFieldYellow}"
                                TextColor="{StaticResource Neutral900}"
                                CornerRadius="18"
                                HeightRequest="38"
                                FontAttributes="Bold"
                                FontSize="12" />
                        <Button Grid.Column="1"
                                Text="{x:Static res:AppResources.ExternalLoginMicrosoftComingSoon}"
                                IsEnabled="False"
                                BackgroundColor="{StaticResource LoginFieldYellow}"
                                TextColor="{StaticResource Neutral900}"
                                CornerRadius="18"
                                HeightRequest="38"
                                FontAttributes="Bold"
                                FontSize="12" />
                    </Grid>

                    <HorizontalStackLayout Spacing="18"
                                           HorizontalOptions="Center"
                                           Margin="0,2,0,0">
                        <Label Text="{x:Static res:AppResources.RegisterButton}"
                               TextColor="{StaticResource Neutral900}"
                               FontAttributes="Bold"
                               FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterTapped" />
                            </Label.GestureRecognizers>
                        </Label>

                        <Label Text="{x:Static res:AppResources.ForgotPasswordButton}"
                               TextColor="{StaticResource Neutral900}"
                               FontAttributes="Bold"
                               FontSize="14"
                               TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnForgotPasswordTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <Label Text="{x:Static res:AppResources.RequestActivationEmailButton}"
                           TextColor="{StaticResource Neutral900}"
                           FontAttributes="Bold"
                           FontSize="14"
                           TextDecorations="Underline"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"
                           IsVisible="{Binding ShowActivationEmailAction}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding RequestActivationEmailCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Button Text="{x:Static res:AppResources.ActivationOpenFlowButton}"
                            Style="{StaticResource LinkButtonStyle}"
                            HorizontalOptions="Center"
                            IsVisible="{Binding ShowActivationEmailAction}"
                            Clicked="OnOpenActivationClicked" />
                </VerticalStackLayout>
                </Border>

                <ActivityIndicator IsVisible="{Binding IsBusy}"
                                   IsRunning="{Binding IsBusy}"
                                   Color="{StaticResource Neutral900}" />

                <Label Text="{x:Static res:AppResources.LegalHubTitle}"
                       TextColor="{StaticResource Neutral900}"
                       FontSize="14"
                       TextDecorations="Underline"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"
                       Margin="0,2,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLegalHubTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
