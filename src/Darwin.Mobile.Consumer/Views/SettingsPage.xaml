<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    x:Class="Darwin.Mobile.Consumer.Views.SettingsPage"
    Title="{x:Static res:AppResources.SettingsTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28" Spacing="14">
            <Border Style="{StaticResource InternalPageHeaderBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static res:AppResources.SettingsTitle}"
                           Style="{StaticResource TitleLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.SettingsSubtitle}"
                           Style="{StaticResource BodyLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource ElevatedListCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.SettingsProfileButton}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <buttons:SfButton Grid.Column="0"
                                          Text="{x:Static res:AppResources.SettingsProfileButton}"
                                          Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                          Command="{Binding OpenProfileCommand}" />
                        <buttons:SfButton Grid.Column="1"
                                          Text="{x:Static res:AppResources.SettingsPreferencesButton}"
                                          Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                          Command="{Binding OpenMemberPreferencesCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <buttons:SfButton Grid.Column="0"
                                          Text="{x:Static res:AppResources.SettingsOrdersAndInvoicesButton}"
                                          Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                          Command="{Binding OpenMemberCommerceCommand}" />
                        <buttons:SfButton Grid.Column="1"
                                          Text="{x:Static res:AppResources.SettingsChangePasswordButton}"
                                          Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                          Command="{Binding OpenChangePasswordCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource ElevatedListCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.SettingsLegalHubButton}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <buttons:SfButton Text="{x:Static res:AppResources.SettingsLegalHubButton}"
                                      Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                      Command="{Binding OpenLegalHubCommand}" />

                    <buttons:SfButton Text="{x:Static res:AppResources.SettingsDeleteAccountButton}"
                                      Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                      Command="{Binding OpenAccountDeletionCommand}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource ElevatedListCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.LogoutButtonText}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <buttons:SfButton Text="{x:Static res:AppResources.LogoutButtonText}"
                                      Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                      Clicked="OnLogoutClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
