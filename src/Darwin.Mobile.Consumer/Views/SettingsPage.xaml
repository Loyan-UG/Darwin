<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:res="clr-namespace:Darwin.Mobile.Consumer.Resources"
    xmlns:vm="clr-namespace:Darwin.Mobile.Consumer.ViewModels"
    x:Class="Darwin.Mobile.Consumer.Views.SettingsPage"
    x:DataType="vm:SettingsViewModel"
    Title="{x:Static res:AppResources.SettingsTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28" Spacing="14">
            <Border Style="{StaticResource InternalPageHeaderBorderStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{x:Static res:AppResources.SettingsTitle}"
                           Style="{StaticResource TitleLabelStyle}" />
                    <Label Text="{x:Static res:AppResources.SettingsSubtitle}"
                           Style="{StaticResource BodyLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource ElevatedListCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Border Style="{StaticResource MutedCardBorderStyle}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenProfileCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    WidthRequest="56"
                                    HeightRequest="56"
                                    Padding="0"
                                    Background="{StaticResource BrushDarkAction}"
                                    Stroke="{StaticResource BrandGold50}"
                                    StrokeThickness="1"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="28" />
                                </Border.StrokeShape>
                                <Grid>
                                    <Image Source="{Binding ProfileImageUrl}"
                                           Aspect="AspectFill"
                                           IsVisible="{Binding HasProfileImage}" />
                                    <Label Text="{Binding ProfileInitials}"
                                           IsVisible="{Binding HasProfileImage, Converter={StaticResource InverseBoolConverter}}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           FontAttributes="Bold"
                                           FontSize="16"
                                           TextColor="{StaticResource Neutral0}" />
                                </Grid>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="{Binding ProfileDisplayName}"
                                       Style="{StaticResource SectionHeadingLabelStyle}"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding ProfileEmail}"
                                       Style="{StaticResource SecondaryBodyLabelStyle}"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="&gt;"
                                   FontSize="26"
                                   TextColor="{StaticResource Neutral700}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <buttons:SfButton Grid.Column="0"
                                          Text="{x:Static res:AppResources.SettingsPreferencesButton}"
                                          Style="{StaticResource SyncfusionPrimaryButtonStyle}"
                                          Command="{Binding OpenMemberPreferencesCommand}" />
                        <buttons:SfButton Grid.Column="1"
                                          Text="{x:Static res:AppResources.SettingsOrdersAndInvoicesButton}"
                                          Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                          Command="{Binding OpenMemberCommerceCommand}" />
                    </Grid>

                    <buttons:SfButton Text="{x:Static res:AppResources.SettingsChangePasswordButton}"
                                          Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                          Command="{Binding OpenChangePasswordCommand}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource ElevatedListCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.SettingsLegalHubButton}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <buttons:SfButton Text="{x:Static res:AppResources.SettingsLegalHubButton}"
                                      Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                      Command="{Binding OpenLegalHubCommand}" />

                    <buttons:SfButton Text="{x:Static res:AppResources.SettingsDeleteAccountButton}"
                                      Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                      Command="{Binding OpenAccountDeletionCommand}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource ElevatedListCardBorderStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static res:AppResources.LogoutButtonText}"
                           Style="{StaticResource SectionHeadingLabelStyle}" />

                    <buttons:SfButton Text="{x:Static res:AppResources.LogoutButtonText}"
                                      Style="{StaticResource SyncfusionOutlinedButtonStyle}"
                                      Clicked="OnLogoutClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
