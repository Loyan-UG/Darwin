<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
    xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit">

    <!--
        Shared visual language:
        - Crisp typography
        - Soft corner radius
        - Gold accent with readable dark text
    -->

    <!-- Page defaults -->
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource BrushBackground}" />
    </Style>

    <Style x:Key="SyncfusionOutlinedInputLayoutStyle" TargetType="inputLayout:SfTextInputLayout">
        <Setter Property="ContainerType" Value="Outlined" />
        <Setter Property="Stroke" Value="{StaticResource Neutral100}" />
        <Setter Property="ContainerBackground" Value="{StaticResource Neutral0}" />
        <Setter Property="OutlineCornerRadius" Value="10" />
        <Setter Property="FocusedStrokeThickness" Value="2" />
        <Setter Property="UnfocusedStrokeThickness" Value="1" />
        <Setter Property="InputViewPadding" Value="14,6" />
    </Style>

    <!-- Buttons -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushPrimary}" />
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup Name="CommonStates">
                    <VisualState Name="Normal" />
                    <VisualState Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Background" Value="{StaticResource BrushPrimaryPressed}" />
                            <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Background" Value="{StaticResource BrushButtonSecondary}" />
                            <Setter Property="TextColor" Value="{StaticResource Neutral700}" />
                            <Setter Property="Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}" />

    <Style x:Key="SyncfusionPrimaryButtonStyle" TargetType="buttons:SfButton">
        <Setter Property="Background" Value="{StaticResource BrushPrimary}" />
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Shadow" Value="{x:Null}" />
    </Style>

    <Style x:Key="SyncfusionOutlinedButtonStyle" TargetType="buttons:SfButton">
        <Setter Property="Background" Value="{StaticResource BrushButtonSecondary}" />
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Shadow" Value="{x:Null}" />
    </Style>

    <Style x:Key="OutlinedButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="{StaticResource BrushButtonSecondary}" />
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup Name="CommonStates">
                    <VisualState Name="Normal" />
                    <VisualState Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Background" Value="{StaticResource BrushBorder}" />
                            <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Background" Value="{StaticResource BrushButtonSecondary}" />
                            <Setter Property="TextColor" Value="{StaticResource Neutral700}" />
                            <Setter Property="Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource OutlinedButtonStyle}" />

    <Style x:Key="LinkButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup Name="CommonStates">
                    <VisualState Name="Normal" />
                    <VisualState Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource Neutral700}" />
                            <Setter Property="Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="LegalLinkButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Neutral700}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup Name="CommonStates">
                    <VisualState Name="Normal" />
                    <VisualState Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource Neutral700}" />
                            <Setter Property="Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="DangerLinkButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Danger500}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup Name="CommonStates">
                    <VisualState Name="Normal" />
                    <VisualState Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource Neutral700}" />
                            <Setter Property="Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Labels -->
    <Style x:Key="TitleLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="BodyLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="SecondaryBodyLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource Neutral700}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="SectionEyebrowLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Neutral700}" />
        <Setter Property="CharacterSpacing" Value="1.1" />
        <Setter Property="TextTransform" Value="Uppercase" />
    </Style>

    <Style x:Key="SectionHeadingLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="CaptionLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource Neutral700}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="MetricValueLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource BrushBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MutedCardBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="Background" Value="{StaticResource BrushBackground}" />
    </Style>

    <Style x:Key="InternalPageHeaderBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="Background" Value="{StaticResource BrushDiscoverHeader}" />
        <Setter Property="Stroke" Value="{StaticResource BrandGold50}" />
        <Setter Property="Padding" Value="18,16" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="22,22,28,28" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ElevatedListCardBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="Margin" Value="2,4" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#42000000" Offset="0,0" Radius="9" Opacity="0.26" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatTileBorderStyle" TargetType="Border" BasedOn="{StaticResource MutedCardBorderStyle}">
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="16" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HeaderStatTileBorderStyle" TargetType="Border" BasedOn="{StaticResource StatTileBorderStyle}">
        <Setter Property="Background" Value="{StaticResource BrushDiscoverHeaderButton}" />
    </Style>

    <Style x:Key="EmptyStateCardBorderStyle" TargetType="Border" BasedOn="{StaticResource MutedCardBorderStyle}">
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="FormLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
    </Style>

    <Style x:Key="FormFieldBorderStyle" TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource BrushBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource BrushSurface}" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FormEntryStyle" TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Neutral700}" />
        <Setter Property="ClearButtonVisibility" Value="WhileEditing" />
    </Style>

    <Style x:Key="FormEditorStyle" TargetType="Editor">
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Neutral700}" />
        <Setter Property="AutoSize" Value="TextChanges" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="TitleColor" Value="{StaticResource Neutral700}" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{StaticResource Neutral900}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource Neutral700}" />
        <Setter Property="CancelButtonColor" Value="{StaticResource BrandGold600}" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource InternalPrimaryButton}" />
        <Setter Property="ThumbColor" Value="{StaticResource Neutral0}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource InternalPrimaryButton}" />
    </Style>

    <Style x:Key="ErrorLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource Danger500}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="SuccessLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource Success500}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="WarningLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource Warning500}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="InfoLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource BrandGold600}" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="SkeletonBlockBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrushBorder}" />
        <Setter Property="Opacity" Value="0.7" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="8" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
