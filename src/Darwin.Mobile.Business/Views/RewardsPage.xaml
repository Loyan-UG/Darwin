<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Darwin.Mobile.Business.ViewModels"
             xmlns:res="clr-namespace:Darwin.Mobile.Business.Resources"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
             xmlns:chips="clr-namespace:Syncfusion.Maui.Toolkit.Chips;assembly=Syncfusion.Maui.Toolkit"
             xmlns:inputLayout="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
             xmlns:views="clr-namespace:Darwin.Mobile.Business.Views"
             x:Class="Darwin.Mobile.Business.Views.RewardsPage"
             x:DataType="vm:RewardsViewModel"
             x:Name="PageRoot"
             Title="{x:Static res:AppResources.RewardsTitle}">

    <pullToRefresh:SfPullToRefresh RefreshCommand="{Binding RefreshCommand}"
                                   IsRefreshing="{Binding IsBusy, Mode=OneWay}"
                                   ProgressColor="{StaticResource BrandGold500}"
                                   ProgressBackground="{StaticResource Neutral0}">
        <pullToRefresh:SfPullToRefresh.PullableContent>
            <ScrollView>
                <VerticalStackLayout Padding="20,18,20,24" Spacing="14">
                    <Border Style="{StaticResource InternalPageHeaderBorderStyle}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="{x:Static res:AppResources.RewardsTitle}" Style="{StaticResource TitleLabelStyle}" />
                            <Label Text="{x:Static res:AppResources.RewardsSubtitle}" Style="{StaticResource BodyLabelStyle}" />
                            <Label Text="{Binding OperatorRole, StringFormat='{x:Static res:AppResources.RewardsOperatorRoleFormat}'}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                            <Label Text="{x:Static res:AppResources.BusinessPermissionDeniedRewardEdit}" Style="{StaticResource WarningLabelStyle}" IsVisible="{Binding CanManageRewards, Converter={StaticResource InverseBoolConverter}}" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border Grid.Column="0" Style="{StaticResource HeaderStatTileBorderStyle}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{x:Static res:AppResources.RewardsCurrentTiersLabel}" Style="{StaticResource CaptionLabelStyle}" />
                                        <Label Text="{Binding RewardTiers.Count}" Style="{StaticResource MetricValueLabelStyle}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource HeaderStatTileBorderStyle}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{x:Static res:AppResources.RewardsCampaignsLabel}" Style="{StaticResource CaptionLabelStyle}" />
                                        <Label Text="{Binding TotalCampaignCount}" Style="{StaticResource MetricValueLabelStyle}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <buttons:SfButton Grid.Column="0"
                                                  Text="{x:Static res:AppResources.RewardsNewTierButton}"
                                                  Command="{Binding Source={x:Reference PageRoot}, Path=OpenNewRewardTierCommand, x:DataType=views:RewardsPage}"
                                                  IsEnabled="{Binding CanManageRewards}"
                                                  Style="{StaticResource SyncfusionPrimaryButtonStyle}" />
                                <buttons:SfButton Grid.Column="1"
                                                  Text="{x:Static res:AppResources.RewardsCampaignNewButton}"
                                                  Command="{Binding Source={x:Reference PageRoot}, Path=OpenNewCampaignCommand, x:DataType=views:RewardsPage}"
                                                  IsEnabled="{Binding CanManageRewards}"
                                                  Style="{StaticResource SyncfusionOutlinedButtonStyle}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{x:Static res:AppResources.RewardsCurrentTiersLabel}" Style="{StaticResource SectionHeadingLabelStyle}" />
                                    <Label Text="{x:Static res:AppResources.RewardsTiersEmptyStateMessage}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding HasRewardTiers, Converter={StaticResource InverseBoolConverter}}" />
                                </VerticalStackLayout>
                                <buttons:SfButton Grid.Column="1"
                                                  Text="{x:Static res:AppResources.RewardsNewTierButton}"
                                                  Command="{Binding Source={x:Reference PageRoot}, Path=OpenNewRewardTierCommand, x:DataType=views:RewardsPage}"
                                                  IsEnabled="{Binding CanManageRewards}"
                                                  Style="{StaticResource SyncfusionOutlinedButtonStyle}" />
                            </Grid>

                            <VerticalStackLayout Spacing="10"
                                                 IsVisible="{Binding HasRewardTiers}"
                                                 BindableLayout.ItemsSource="{Binding RewardTiers}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RewardTierEditorItem">
                                        <Border Style="{StaticResource MutedCardBorderStyle}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={x:Reference PageRoot}, Path=OpenRewardTierEditorCommand, x:DataType=views:RewardsPage}"
                                                                      CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding PointsRequired, StringFormat='{x:Static res:AppResources.RewardsTierPointsFormat}'}" Style="{StaticResource BodyLabelStyle}" />
                                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding LocalizedRewardType}" Style="{StaticResource CaptionLabelStyle}" />
                                                <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding RewardValue, StringFormat='{x:Static res:AppResources.RewardsTierValueFormat}'}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding RewardValue, Converter={StaticResource NullCheckConverter}}" />
                                                <Label Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding Description}" Style="{StaticResource SecondaryBodyLabelStyle}" IsVisible="{Binding Description, Converter={StaticResource NullCheckConverter}}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{x:Static res:AppResources.RewardsCampaignsLabel}" Style="{StaticResource SectionHeadingLabelStyle}" />
                                    <Label Text="{Binding CampaignFilterSummary}" Style="{StaticResource SecondaryBodyLabelStyle}" />
                                </VerticalStackLayout>
                                <buttons:SfButton Grid.Column="1"
                                                  Text="{x:Static res:AppResources.RewardsCampaignNewButton}"
                                                  Command="{Binding Source={x:Reference PageRoot}, Path=OpenNewCampaignCommand, x:DataType=views:RewardsPage}"
                                                  IsEnabled="{Binding CanManageRewards}"
                                                  Style="{StaticResource SyncfusionOutlinedButtonStyle}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <Border Grid.Column="0" Style="{StaticResource HeaderStatTileBorderStyle}">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{x:Static res:AppResources.RewardsCampaignStateFilterDraft}" Style="{StaticResource CaptionLabelStyle}" />
                                        <Label Text="{Binding DraftCampaignCount}" Style="{StaticResource MetricValueLabelStyle}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource HeaderStatTileBorderStyle}">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{x:Static res:AppResources.RewardsCampaignStateFilterActive}" Style="{StaticResource CaptionLabelStyle}" />
                                        <Label Text="{Binding ActiveCampaignCount}" Style="{StaticResource MetricValueLabelStyle}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource HeaderStatTileBorderStyle}">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{x:Static res:AppResources.RewardsCampaignStateFilterExpired}" Style="{StaticResource CaptionLabelStyle}" />
                                        <Label Text="{Binding ExpiredCampaignCount}" Style="{StaticResource MetricValueLabelStyle}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <inputLayout:SfTextInputLayout Hint="{x:Static res:AppResources.RewardsCampaignSearchPlaceholder}"
                                                           Style="{StaticResource SyncfusionOutlinedInputLayoutStyle}">
                                <Entry Placeholder="{x:Static res:AppResources.RewardsCampaignSearchPlaceholder}" Text="{Binding CampaignSearchQuery}" Style="{StaticResource FormEntryStyle}" />
                            </inputLayout:SfTextInputLayout>

                            <chips:SfChipGroup ItemsSource="{Binding CampaignStateFilterOptions}"
                                               DisplayMemberPath="Label"
                                               SelectedItem="{Binding SelectedCampaignStateFilter, Mode=TwoWay}"
                                               ChipType="Choice"
                                               ChoiceMode="Single"
                                               ChipCornerRadius="10"
                                               ChipBackground="{StaticResource BrushSurface}"
                                               ChipStroke="{StaticResource BrandGold50}"
                                               ChipStrokeThickness="1"
                                               ChipTextColor="{StaticResource Neutral900}"
                                               ChipTextSize="13"
                                               SelectedChipBackground="{StaticResource BrushPrimary}"
                                               SelectedChipTextColor="{StaticResource Neutral0}" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" IsVisible="{Binding HasActiveCampaignFilters}">
                                <buttons:SfButton Grid.Column="0" Text="{x:Static res:AppResources.RewardsCampaignClearSearchButton}" Command="{Binding ClearCampaignSearchCommand}" IsEnabled="{Binding HasCampaignSearchQuery}" Style="{StaticResource SyncfusionOutlinedButtonStyle}" />
                                <buttons:SfButton Grid.Column="1" Text="{x:Static res:AppResources.RewardsCampaignClearFiltersButton}" Command="{Binding ClearCampaignFiltersCommand}" IsEnabled="{Binding HasActiveCampaignFilters}" Style="{StaticResource SyncfusionOutlinedButtonStyle}" />
                            </Grid>

                            <Border Style="{StaticResource EmptyStateCardBorderStyle}" IsVisible="{Binding ShowCampaignDatasetEmptyState}">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{x:Static res:AppResources.RewardsCampaignsLabel}" Style="{StaticResource SectionHeadingLabelStyle}" />
                                    <Label Text="{x:Static res:AppResources.RewardsCampaignsEmptyDataset}" Style="{StaticResource BodyLabelStyle}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Style="{StaticResource EmptyStateCardBorderStyle}" IsVisible="{Binding ShowCampaignFilteredEmptyState}">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{x:Static res:AppResources.RewardsCampaignsLabel}" Style="{StaticResource SectionHeadingLabelStyle}" />
                                    <Label Text="{x:Static res:AppResources.RewardsCampaignsEmptyFiltered}" Style="{StaticResource BodyLabelStyle}" />
                                </VerticalStackLayout>
                            </Border>

                            <VerticalStackLayout Spacing="10"
                                                 IsVisible="{Binding HasCampaigns}"
                                                 BindableLayout.ItemsSource="{Binding Campaigns}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BusinessCampaignEditorItem">
                                        <Border Style="{StaticResource MutedCardBorderStyle}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={x:Reference PageRoot}, Path=OpenCampaignEditorCommand, x:DataType=views:RewardsPage}"
                                                                      CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="7">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                    <Label Text="{Binding Title}" Style="{StaticResource BodyLabelStyle}" LineBreakMode="WordWrap" />
                                                    <Label Grid.Column="1" Text="{Binding LocalizedCampaignState, StringFormat='{x:Static res:AppResources.RewardsCampaignStateFormat}'}" Style="{StaticResource CaptionLabelStyle}" />
                                                </Grid>
                                                <Label Text="{Binding AudienceSummary}" Style="{StaticResource CaptionLabelStyle}" />
                                                <Label Text="{Binding ChannelSummary}" Style="{StaticResource CaptionLabelStyle}" />
                                                <Label Text="{Binding DeliveryStatusSummary}" Style="{StaticResource CaptionLabelStyle}" />
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                    <VerticalStackLayout Spacing="2">
                                                        <Label Text="{Binding StartsAtUtc, StringFormat='{x:Static res:AppResources.RewardsCampaignStartAtFormat}'}" Style="{StaticResource CaptionLabelStyle}" IsVisible="{Binding StartsAtUtc, Converter={StaticResource NullCheckConverter}}" />
                                                        <Label Text="{Binding EndsAtUtc, StringFormat='{x:Static res:AppResources.RewardsCampaignEndAtFormat}'}" Style="{StaticResource CaptionLabelStyle}" IsVisible="{Binding EndsAtUtc, Converter={StaticResource NullCheckConverter}}" />
                                                    </VerticalStackLayout>
                                                    <buttons:SfButton Grid.Column="1"
                                                                      Text="{Binding ActivationButtonText}"
                                                                      Command="{Binding Source={x:Reference PageRoot}, Path=ToggleCampaignActivationCommand, x:DataType=views:RewardsPage}"
                                                                      CommandParameter="{Binding .}"
                                                                      Style="{StaticResource SyncfusionOutlinedButtonStyle}" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabelStyle}" IsVisible="{Binding HasError}" />
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource BrandGold500}" />
                </VerticalStackLayout>
            </ScrollView>
        </pullToRefresh:SfPullToRefresh.PullableContent>
    </pullToRefresh:SfPullToRefresh>
</ContentPage>
