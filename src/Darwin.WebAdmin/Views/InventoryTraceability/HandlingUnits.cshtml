@model Darwin.WebAdmin.ViewModels.Inventory.HandlingUnitsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("HandlingUnits");
    string ListUrl() => Url.Action("HandlingUnits", "InventoryTraceability") ?? string.Empty;
}
<div id="inventory-traceability-workspace-shell">
    <h1 class="mb-3">@T.T("HandlingUnits")</h1>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <form asp-action="HandlingUnits" method="get" class="d-flex gap-2" hx-get="@ListUrl()" hx-target="#inventory-traceability-workspace-shell" hx-swap="outerHTML" hx-push-url="true">
            <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
            <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("Search")">
            <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
            <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        </form>
        <a asp-action="CreateHandlingUnit" asp-route-businessId="@Model.BusinessId" class="btn btn-primary" hx-get="@Url.Action("CreateHandlingUnit", "InventoryTraceability", new { businessId = Model.BusinessId })" hx-target="#inventory-traceability-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("NewHandlingUnit")</a>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-md"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div>
        <div class="col-md"><div class="card h-100 border-success-subtle"><div class="card-body"><div class="text-muted small">@T.T("Open")</div><div class="fs-4 fw-semibold">@Model.Summary.OpenCount</div></div></div></div>
        <div class="col-md"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Closed")</div><div class="fs-4 fw-semibold">@Model.Summary.ClosedCount</div></div></div></div>
        <div class="col-md"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("InTransit")</div><div class="fs-4 fw-semibold">@Model.Summary.InTransitCount</div></div></div></div>
        <div class="col-md"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Received")</div><div class="fs-4 fw-semibold">@Model.Summary.ReceivedCount</div></div></div></div>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead><tr><th>@T.T("Code")</th><th>@T.T("DisplayName")</th><th>@T.T("Warehouse")</th><th>@T.T("Location")</th><th>@T.T("Type")</th><th>@T.T("Status")</th><th>@T.T("Contents")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
            <tbody>
            @if (Model.Items.Count == 0) { <tr><td colspan="8" class="text-center text-muted">@T.T("NoHandlingUnitsFound")</td></tr> }
            else foreach (var item in Model.Items)
            {
                <tr>
                    <td class="fw-semibold">@item.Code<div class="small text-muted">@item.Barcode</div></td>
                    <td>@item.DisplayName @if (!string.IsNullOrWhiteSpace(item.ParentCode)) { <div class="small text-muted">@T.T("Parent"): @item.ParentCode</div> }</td>
                    <td>@item.WarehouseName</td>
                    <td>@item.LocationCode</td>
                    <td><span class="badge text-bg-light">@T.T(item.HandlingUnitType.ToString())</span></td>
                    <td><span class="badge text-bg-light">@T.T(item.Status.ToString())</span></td>
                    <td>@item.ContentCount / @item.TotalQuantity</td>
                    <td class="text-end"><a asp-action="EditHandlingUnit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" hx-get="@Url.Action("EditHandlingUnit", "InventoryTraceability", new { id = item.Id })" hx-target="#inventory-traceability-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Edit")</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="InventoryTraceability" asp-action="HandlingUnits" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#inventory-traceability-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
