@model Darwin.WebAdmin.ViewModels.Inventory.InventoryLotsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("InventoryLots");
    string ListUrl() => Url.Action("Lots", "InventoryTraceability") ?? string.Empty;
}
<div id="inventory-traceability-workspace-shell">
    <h1 class="mb-3">@T.T("InventoryLots")</h1>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <form asp-action="Lots" method="get" class="d-flex gap-2" hx-get="@ListUrl()" hx-target="#inventory-traceability-workspace-shell" hx-swap="outerHTML" hx-push-url="true">
            <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
            <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("Search")">
            <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
            <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        </form>
        <a asp-action="CreateLot" asp-route-businessId="@Model.BusinessId" class="btn btn-primary" hx-get="@Url.Action("CreateLot", "InventoryTraceability", new { businessId = Model.BusinessId })" hx-target="#inventory-traceability-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("NewInventoryLot")</a>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-md"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div>
        <div class="col-md"><div class="card h-100 border-success-subtle"><div class="card-body"><div class="text-muted small">@T.T("Active")</div><div class="fs-4 fw-semibold">@Model.Summary.ActiveCount</div></div></div></div>
        <div class="col-md"><div class="card h-100 border-warning-subtle"><div class="card-body"><div class="text-muted small">@T.T("Quarantined")</div><div class="fs-4 fw-semibold">@Model.Summary.QuarantinedCount</div></div></div></div>
        <div class="col-md"><div class="card h-100 border-danger-subtle"><div class="card-body"><div class="text-muted small">@T.T("Expired")</div><div class="fs-4 fw-semibold">@Model.Summary.ExpiredCount</div></div></div></div>
        <div class="col-md"><div class="card h-100 border-danger-subtle"><div class="card-body"><div class="text-muted small">@T.T("Recalled")</div><div class="fs-4 fw-semibold">@Model.Summary.RecalledCount</div></div></div></div>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead><tr><th>@T.T("LotCode")</th><th>@T.T("Variant")</th><th>@T.T("SupplierLot")</th><th>@T.T("Expiry")</th><th>@T.T("Status")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
            <tbody>
            @if (Model.Items.Count == 0) { <tr><td colspan="6" class="text-center text-muted">@T.T("NoInventoryLotsFound")</td></tr> }
            else foreach (var item in Model.Items)
            {
                <tr>
                    <td class="fw-semibold">@item.LotCode</td>
                    <td>@item.VariantSku</td>
                    <td>@item.SupplierLotCode</td>
                    <td>@item.ExpiryDateUtc?.ToString("yyyy-MM-dd")</td>
                    <td><span class="badge text-bg-light">@T.T(item.Status.ToString())</span></td>
                    <td class="text-end"><a asp-action="EditLot" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" hx-get="@Url.Action("EditLot", "InventoryTraceability", new { id = item.Id })" hx-target="#inventory-traceability-workspace-shell" hx-swap="outerHTML" hx-push-url="true">@T.T("Edit")</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="InventoryTraceability" asp-action="Lots" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#inventory-traceability-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
