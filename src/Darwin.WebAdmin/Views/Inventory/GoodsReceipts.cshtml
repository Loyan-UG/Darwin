@model Darwin.WebAdmin.ViewModels.Inventory.GoodsReceiptsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("GoodsReceipts");
    var culture = System.Globalization.CultureInfo.CurrentCulture;
    string OptionalDate(DateTime? value) => value.HasValue ? value.Value.ToString("g", culture) : "-";
    string GoodsReceiptsUrl(object? businessId = null, string? q = null, string? filter = null) => Url.Action("GoodsReceipts", "Inventory", new { businessId, q, filter }) ?? string.Empty;
    string EditGoodsReceiptUrl(Guid id) => Url.Action("EditGoodsReceipt", "Inventory", new { id }) ?? string.Empty;
}

<div id="inventory-goods-receipts-workspace-shell">
    <h1 class="mb-3">@T.T("GoodsReceipts")</h1>

    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <form asp-action="GoodsReceipts" method="get" class="d-flex flex-wrap gap-2"
              hx-get="@GoodsReceiptsUrl()"
              hx-target="#inventory-goods-receipts-workspace-shell"
              hx-swap="outerHTML"
              hx-push-url="true">
            <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
            <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchGoodsReceiptsPlaceholder")">
            <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
            <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
            <a asp-action="GoodsReceipts" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
               hx-get="@GoodsReceiptsUrl(Model.BusinessId)"
               hx-target="#inventory-goods-receipts-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Reset")</a>
        </form>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4 col-xl-2"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div>
        <div class="col-md-4 col-xl-2"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Draft")</div><div class="fs-4 fw-semibold">@Model.Summary.DraftCount</div></div></div></div>
        <div class="col-md-4 col-xl-2"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Received")</div><div class="fs-4 fw-semibold">@Model.Summary.ReceivedCount</div></div></div></div>
        <div class="col-md-4 col-xl-2"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Inspected")</div><div class="fs-4 fw-semibold">@Model.Summary.InspectedCount</div></div></div></div>
        <div class="col-md-4 col-xl-2"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Posted")</div><div class="fs-4 fw-semibold">@Model.Summary.PostedCount</div></div></div></div>
        <div class="col-md-4 col-xl-2"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Cancelled")</div><div class="fs-4 fw-semibold">@Model.Summary.CancelledCount</div></div></div></div>
    </div>

    <div class="card mb-4">
        <div class="card-header">@T.T("CreateGoodsReceipt")</div>
        <div class="card-body">
            <form asp-action="CreateGoodsReceipt" method="post" class="row g-2 align-items-end"
                  hx-post="@Url.Action("CreateGoodsReceipt", "Inventory")"
                  hx-target="#inventory-goods-receipts-workspace-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="BusinessId" />
                <div class="col-md-4">
                    <label asp-for="PurchaseOrderId" class="form-label">@T.T("PurchaseOrder")</label>
                    <select asp-for="PurchaseOrderId" asp-items="Model.PurchaseOrderOptions" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="WarehouseId" class="form-label">@T.T("Warehouse")</label>
                    <select asp-for="WarehouseId" asp-items="Model.WarehouseOptions" class="form-select"></select>
                </div>
                <div class="col-md-3">
                    <label asp-for="InternalNotes" class="form-label">@T.T("InternalNotes")</label>
                    <input asp-for="InternalNotes" class="form-control" />
                </div>
                <div class="col-md-1 d-grid">
                    <button type="submit" class="btn btn-primary">@T.T("Create")</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
            <tr>
                <th>@T.T("ReceiptNumber")</th>
                <th>@T.T("PurchaseOrder")</th>
                <th>@T.T("Supplier")</th>
                <th>@T.T("Warehouse")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("Quantities")</th>
                <th>@T.T("Dates")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted">@T.T("NoGoodsReceiptsFound")</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@(item.GoodsReceiptNumber ?? "-")</td>
                        <td>@item.PurchaseOrderNumber</td>
                        <td>@item.SupplierName</td>
                        <td>@item.WarehouseName</td>
                        <td><span class="badge text-bg-secondary">@T.T(item.Status)</span></td>
                        <td>
                            <div>@T.T("Lines"): @item.LineCount</div>
                            <div class="small text-muted">@T.T("Received"): @item.ReceivedQuantity / @T.T("Accepted"): @item.AcceptedQuantity</div>
                        </td>
                        <td>
                            <div>@T.T("Received"): @OptionalDate(item.ReceivedAtUtc)</div>
                            <div class="small text-muted">@T.T("Posted"): @OptionalDate(item.PostedAtUtc)</div>
                        </td>
                        <td class="text-end">
                            <a asp-action="EditGoodsReceipt" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                               hx-get="@EditGoodsReceiptUrl(item.Id)"
                               hx-target="#inventory-goods-receipts-workspace-shell"
                               hx-swap="outerHTML"
                               hx-push-url="true">@T.T("Open")</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>

    <pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="GoodsReceipts" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#inventory-goods-receipts-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
