@model Darwin.WebAdmin.ViewModels.Inventory.StockCountsListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("StockCountsTitle");
    string CountsUrl(object? businessId = null, object? warehouseId = null, string? q = null, string? filter = null) => Url.Action("StockCounts", "Inventory", new { businessId, warehouseId, q, filter }) ?? string.Empty;
    string CreateUrl(object? businessId = null, object? warehouseId = null) => Url.Action("CreateStockCount", "Inventory", new { businessId, warehouseId }) ?? string.Empty;
    string EditUrl(Guid id) => Url.Action("EditStockCount", "Inventory", new { id }) ?? string.Empty;
}

<div id="inventory-stock-counts-workspace-shell">
<h1 class="mb-3">@T.T("StockCountsTitle")</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="StockCounts" method="get" class="d-flex gap-2"
          hx-get="@CountsUrl()"
          hx-target="#inventory-stock-counts-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <select name="warehouseId" asp-items="Model.WarehouseOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchStockCountsPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="StockCounts" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary"
           hx-get="@CountsUrl(Model.BusinessId, Model.WarehouseId)"
           hx-target="#inventory-stock-counts-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </form>
    <a asp-action="CreateStockCount" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-primary"
       hx-get="@CreateUrl(Model.BusinessId, Model.WarehouseId)"
       hx-target="#inventory-stock-counts-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("NewStockCount")</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3 col-xl"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div>
    <div class="col-md-3 col-xl"><div class="card h-100 border-primary-subtle"><div class="card-body"><div class="text-muted small">@T.T("Draft")</div><div class="fs-4 fw-semibold">@Model.Summary.DraftCount</div></div></div></div>
    <div class="col-md-3 col-xl"><div class="card h-100 border-warning-subtle"><div class="card-body"><div class="text-muted small">@T.T("ReviewPending")</div><div class="fs-4 fw-semibold">@Model.Summary.ReviewPendingCount</div></div></div></div>
    <div class="col-md-3 col-xl"><div class="card h-100 border-success-subtle"><div class="card-body"><div class="text-muted small">@T.T("Posted")</div><div class="fs-4 fw-semibold">@Model.Summary.PostedCount</div></div></div></div>
    <div class="col-md-3 col-xl"><div class="card h-100 border-danger-subtle"><div class="card-body"><div class="text-muted small">@T.T("Variance")</div><div class="fs-4 fw-semibold">@Model.Summary.VarianceCount</div></div></div></div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
        <tr>
            <th>@T.T("Count")</th>
            <th>@T.T("Warehouse")</th>
            <th>@T.T("Location")</th>
            <th>@T.T("Type")</th>
            <th>@T.T("Status")</th>
            <th class="text-end">@T.T("Lines")</th>
            <th class="text-end">@T.T("Variance")</th>
            <th class="text-end">@T.T("Actions")</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="8" class="text-center text-muted">@T.T("NoStockCountsFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@(item.CountNumber ?? item.Title)</div>
                        <div class="small text-muted">@item.Title</div>
                    </td>
                    <td>@item.WarehouseName</td>
                    <td>@(item.LocationCode ?? "-")</td>
                    <td><span class="badge text-bg-light">@T.T(item.CountType.ToString())</span></td>
                    <td><span class="badge @(item.Status == Darwin.Domain.Enums.StockCountSessionStatus.Posted ? "text-bg-success" : item.Status == Darwin.Domain.Enums.StockCountSessionStatus.Cancelled ? "text-bg-secondary" : item.Status == Darwin.Domain.Enums.StockCountSessionStatus.ReviewPending ? "text-bg-warning" : "text-bg-primary")">@T.T(item.Status.ToString())</span></td>
                    <td class="text-end">@item.LineCount</td>
                    <td class="text-end">
                        <div>@item.TotalVarianceQuantity</div>
                        @if (item.VarianceLineCount > 0)
                        {
                            <span class="badge text-bg-warning">@item.VarianceLineCount</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="EditStockCount" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@EditUrl(item.Id)"
                           hx-target="#inventory-stock-counts-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="StockCounts" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#inventory-stock-counts-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
