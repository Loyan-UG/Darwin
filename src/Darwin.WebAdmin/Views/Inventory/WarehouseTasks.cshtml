@model Darwin.WebAdmin.ViewModels.Inventory.WarehouseTasksListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("WarehouseTasksTitle");
    string TasksUrl(object? businessId = null, object? warehouseId = null, string? q = null, string? filter = null) => Url.Action("WarehouseTasks", "Inventory", new { businessId, warehouseId, q, filter }) ?? string.Empty;
    string CreateTaskUrl(object? businessId = null, object? warehouseId = null) => Url.Action("CreateWarehouseTask", "Inventory", new { businessId, warehouseId }) ?? string.Empty;
    string EditTaskUrl(Guid id) => Url.Action("EditWarehouseTask", "Inventory", new { id }) ?? string.Empty;
}

<div id="inventory-warehouse-tasks-workspace-shell">
<h1 class="mb-3">@T.T("WarehouseTasksTitle")</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="WarehouseTasks" method="get" class="d-flex gap-2"
          hx-get="@TasksUrl()"
          hx-target="#inventory-warehouse-tasks-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <select name="warehouseId" asp-items="Model.WarehouseOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchWarehouseTasksPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="WarehouseTasks" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary"
           hx-get="@TasksUrl(Model.BusinessId, Model.WarehouseId)"
           hx-target="#inventory-warehouse-tasks-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </form>
    <a asp-action="CreateWarehouseTask" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-primary"
       hx-get="@CreateTaskUrl(Model.BusinessId, Model.WarehouseId)"
       hx-target="#inventory-warehouse-tasks-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("NewWarehouseTask")</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3 col-xl"><div class="card h-100"><div class="card-body"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.TotalCount</div></div></div></div>
    <div class="col-md-3 col-xl"><div class="card h-100 border-primary-subtle"><div class="card-body"><div class="text-muted small">@T.T("Ready")</div><div class="fs-4 fw-semibold">@Model.Summary.ReadyCount</div></div></div></div>
    <div class="col-md-3 col-xl"><div class="card h-100 border-info-subtle"><div class="card-body"><div class="text-muted small">@T.T("Assigned")</div><div class="fs-4 fw-semibold">@Model.Summary.AssignedCount</div></div></div></div>
    <div class="col-md-3 col-xl"><div class="card h-100 border-warning-subtle"><div class="card-body"><div class="text-muted small">@T.T("InProgress")</div><div class="fs-4 fw-semibold">@Model.Summary.InProgressCount</div></div></div></div>
    <div class="col-md-3 col-xl"><div class="card h-100 border-danger-subtle"><div class="card-body"><div class="text-muted small">@T.T("Overdue")</div><div class="fs-4 fw-semibold">@Model.Summary.OverdueCount</div></div></div></div>
    <div class="col-md-3 col-xl"><div class="card h-100 border-danger"><div class="card-body"><div class="text-muted small">@T.T("Shortage")</div><div class="fs-4 fw-semibold">@Model.Summary.ShortageCount</div></div></div></div>
</div>

@if (Model.BusinessId.HasValue && Model.WarehouseId.HasValue)
{
    <div class="card mb-4">
        <div class="card-header">@T.T("CreatePickingTask")</div>
        <div class="card-body">
            <form asp-action="CreatePickingTaskFromOrder" method="post" class="row g-2 align-items-end"
                  hx-post="@Url.Action("CreatePickingTaskFromOrder", "Inventory")"
                  hx-target="#inventory-warehouse-tasks-workspace-shell"
                  hx-swap="outerHTML">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="PickingTask.BusinessId" value="@Model.BusinessId.Value" />
                <input type="hidden" asp-for="PickingTask.WarehouseId" value="@Model.WarehouseId.Value" />
                <div class="col-md-3">
                    <label asp-for="PickingTask.OrderId" class="form-label">@T.T("OrderId")</label>
                    <input asp-for="PickingTask.OrderId" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="PickingTask.FromLocationId" class="form-label">@T.T("SourceLocation")</label>
                    <select asp-for="PickingTask.FromLocationId" asp-items="Model.LocationOptions" class="form-select"></select>
                </div>
                <div class="col-md-2">
                    <label asp-for="PickingTask.Priority" class="form-label">@T.T("Priority")</label>
                    <select asp-for="PickingTask.Priority" class="form-select">
                        @foreach (var priority in Enum.GetValues<Darwin.Domain.Enums.WarehouseTaskPriority>())
                        {
                            <option value="@priority">@T.T(priority.ToString())</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label asp-for="PickingTask.DueAtUtc" class="form-label">@T.T("DueAtUtc")</label>
                    <input asp-for="PickingTask.DueAtUtc" class="form-control" />
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-outline-primary">@T.T("CreatePickingTask")</button>
                </div>
                <div class="col-12">
                    <label asp-for="PickingTask.InternalNotes" class="form-label">@T.T("InternalNotes")</label>
                    <input asp-for="PickingTask.InternalNotes" class="form-control" />
                </div>
            </form>
        </div>
    </div>
}

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
        <tr>
            <th>@T.T("Task")</th>
            <th>@T.T("Warehouse")</th>
            <th>@T.T("Type")</th>
            <th>@T.T("Status")</th>
            <th>@T.T("Priority")</th>
            <th>@T.T("Locations")</th>
            <th>@T.T("AssignedTo")</th>
            <th class="text-end">@T.T("Quantity")</th>
            <th class="text-end">@T.T("Actions")</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="9" class="text-center text-muted">@T.T("NoWarehouseTasksFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@(item.TaskNumber ?? item.Title)</div>
                        <div class="small text-muted">@item.Title</div>
                    </td>
                    <td>@item.WarehouseName</td>
                    <td><span class="badge text-bg-light">@T.T(item.TaskType.ToString())</span></td>
                    <td><span class="badge @(item.Status == Darwin.Domain.Enums.WarehouseTaskStatus.Completed ? "text-bg-success" : item.Status == Darwin.Domain.Enums.WarehouseTaskStatus.Cancelled ? "text-bg-secondary" : item.Status == Darwin.Domain.Enums.WarehouseTaskStatus.InProgress ? "text-bg-warning" : "text-bg-primary")">@T.T(item.Status.ToString())</span></td>
                    <td><span class="badge @(item.Priority == Darwin.Domain.Enums.WarehouseTaskPriority.Urgent ? "text-bg-danger" : item.Priority == Darwin.Domain.Enums.WarehouseTaskPriority.High ? "text-bg-warning" : "text-bg-light")">@T.T(item.Priority.ToString())</span></td>
                    <td>
                        <div class="small">@T.T("From"): @(item.FromLocationCode ?? "-")</div>
                        <div class="small">@T.T("To"): @(item.ToLocationCode ?? "-")</div>
                    </td>
                    <td>@(item.AssignedToDisplayName ?? "-")</td>
                    <td class="text-end">
                        <div>@item.CompletedQuantity / @item.RequestedQuantity</div>
                        @if (item.HasShortage)
                        {
                            <span class="badge text-bg-danger">@T.T("Shortage"): @item.ShortQuantity</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="EditWarehouseTask" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"
                           hx-get="@EditTaskUrl(item.Id)"
                           hx-target="#inventory-warehouse-tasks-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="WarehouseTasks" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#inventory-warehouse-tasks-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
