@model Darwin.WebAdmin.ViewModels.Inventory.GoodsReceiptDetailVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("GoodsReceipt");
    var rowVersion = Convert.ToBase64String(Model.RowVersion);
    var isDraft = string.Equals(Model.Status, "Draft", StringComparison.OrdinalIgnoreCase);
    var isReceived = string.Equals(Model.Status, "Received", StringComparison.OrdinalIgnoreCase);
    var isInspected = string.Equals(Model.Status, "Inspected", StringComparison.OrdinalIgnoreCase);
    string UpdateUrl() => Url.Action("UpdateGoodsReceiptLifecycle", "Inventory") ?? string.Empty;
}

<div id="inventory-goods-receipt-detail-shell">
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1">@T.T("GoodsReceipt") @(Model.GoodsReceiptNumber ?? "-")</h1>
            <div class="text-muted small">@Model.PurchaseOrderNumber / @Model.SupplierName / @Model.WarehouseName</div>
        </div>
        <a asp-action="GoodsReceipts" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary"
           hx-get="@Url.Action("GoodsReceipts", "Inventory", new { businessId = Model.BusinessId })"
           hx-target="#inventory-goods-receipt-detail-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Back")</a>
    </div>

    <form asp-action="UpdateGoodsReceiptLifecycle" method="post"
          hx-post="@UpdateUrl()"
          hx-target="#inventory-goods-receipt-detail-shell"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="BusinessId" />
        <input type="hidden" name="rowVersion" value="@rowVersion" />
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-2"><div class="text-muted small">@T.T("Status")</div><div class="fw-semibold">@T.T(Model.Status)</div></div>
                    <div class="col-md-2"><div class="text-muted small">@T.T("Received")</div><div class="fw-semibold">@(Model.ReceivedAtUtc?.ToString("g") ?? "-")</div></div>
                    <div class="col-md-2"><div class="text-muted small">@T.T("Inspected")</div><div class="fw-semibold">@(Model.InspectedAtUtc?.ToString("g") ?? "-")</div></div>
                    <div class="col-md-2"><div class="text-muted small">@T.T("Posted")</div><div class="fw-semibold">@(Model.PostedAtUtc?.ToString("g") ?? "-")</div></div>
                    <div class="col-md-4"><div class="text-muted small">@T.T("InternalNotes")</div><div class="fw-semibold">@(Model.InternalNotes ?? "-")</div></div>
                </div>
            </div>
        </div>

        <div class="table-responsive mb-3">
            <table class="table table-sm align-middle">
                <thead>
                <tr>
                    <th>@T.T("Line")</th>
                    <th>@T.T("Ordered")</th>
                    <th>@T.T("PreviouslyReceived")</th>
                    <th>@T.T("Received")</th>
                    <th>@T.T("Accepted")</th>
                    <th>@T.T("Rejected")</th>
                    <th>@T.T("Damaged")</th>
                </tr>
                </thead>
                <tbody>
                @for (var i = 0; i < Model.Lines.Count; i++)
                {
                    <tr>
                        <td>
                            <input type="hidden" asp-for="Lines[i].Id" />
                            <input type="hidden" asp-for="Lines[i].PurchaseOrderLineId" />
                            <input type="hidden" asp-for="Lines[i].ProductVariantId" />
                            <div class="fw-semibold">@(Model.Lines[i].SupplierSku ?? "-")</div>
                            <div class="small text-muted">@(Model.Lines[i].Description ?? "-")</div>
                        </td>
                        <td>@Model.Lines[i].OrderedQuantity</td>
                        <td>@Model.Lines[i].PreviouslyReceivedQuantity</td>
                        <td>
                            @if (isDraft)
                            {
                                <input asp-for="Lines[i].ReceivedQuantity" class="form-control form-control-sm" />
                            }
                            else
                            {
                                @Model.Lines[i].ReceivedQuantity
                            }
                        </td>
                        <td>
                            @if (isReceived)
                            {
                                <input asp-for="Lines[i].AcceptedQuantity" class="form-control form-control-sm" />
                            }
                            else
                            {
                                @Model.Lines[i].AcceptedQuantity
                            }
                        </td>
                        <td>
                            @if (isReceived)
                            {
                                <input asp-for="Lines[i].RejectedQuantity" class="form-control form-control-sm" />
                            }
                            else
                            {
                                @Model.Lines[i].RejectedQuantity
                            }
                        </td>
                        <td>
                            @if (isReceived)
                            {
                                <input asp-for="Lines[i].DamagedQuantity" class="form-control form-control-sm" />
                            }
                            else
                            {
                                @Model.Lines[i].DamagedQuantity
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="d-flex flex-wrap gap-2">
            @if (isDraft)
            {
                <button type="submit" name="action" value="Receive" class="btn btn-success">@T.T("Receive")</button>
                <button type="submit" name="action" value="Cancel" class="btn btn-outline-danger">@T.T("Cancel")</button>
            }
            else if (isReceived)
            {
                <button type="submit" name="action" value="Inspect" class="btn btn-primary">@T.T("Inspect")</button>
                <button type="submit" name="action" value="Cancel" class="btn btn-outline-danger">@T.T("Cancel")</button>
            }
            else if (isInspected)
            {
                <button type="submit" name="action" value="Post" class="btn btn-warning">@T.T("Post")</button>
                <button type="submit" name="action" value="Cancel" class="btn btn-outline-danger">@T.T("Cancel")</button>
            }
        </div>
    </form>
</div>
