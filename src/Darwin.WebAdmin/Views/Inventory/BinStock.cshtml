@model Darwin.WebAdmin.ViewModels.Inventory.BinStockListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BinStockTitle");
    string BinStockUrl(object? businessId = null, object? warehouseId = null, string? q = null, string? filter = null) => Url.Action("BinStock", "Inventory", new { businessId, warehouseId, q, filter }) ?? string.Empty;
    string StockLevelsUrl(object? businessId = null, object? warehouseId = null) => Url.Action("StockLevels", "Inventory", new { businessId, warehouseId }) ?? string.Empty;
    string VariantLedgerUrl(Guid variantId, Guid? warehouseId) => Url.Action("VariantLedger", "Inventory", new { variantId, warehouseId }) ?? string.Empty;
    string BadgeClass(bool attention) => attention ? "badge bg-warning-subtle text-warning-emphasis" : "badge bg-success-subtle text-success-emphasis";
    string LocationText(Darwin.WebAdmin.ViewModels.Inventory.BinStockListItemVm item) => item.LocationId.HasValue ? $"{item.LocationCode} - {item.LocationDisplayName}" : T.T("Unassigned");
}

<div id="inventory-bin-stock-workspace-shell">
<h1 class="mb-3">@T.T("BinStockTitle")</h1>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="BinStock" method="get" class="d-flex gap-2"
          hx-get="@BinStockUrl()"
          hx-target="#inventory-bin-stock-workspace-shell"
          hx-swap="outerHTML"
          hx-push-url="true">
        <input type="hidden" name="businessId" value="@Model.BusinessId" />
        <select name="warehouseId" asp-items="Model.WarehouseOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchStockLevelsPlaceholder")">
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="BinStock" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary"
           hx-get="@BinStockUrl(Model.BusinessId, Model.WarehouseId)"
           hx-target="#inventory-bin-stock-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("Reset")</a>
    </form>
    <a asp-action="StockLevels" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-outline-secondary"
       hx-get="@StockLevelsUrl(Model.BusinessId, Model.WarehouseId)"
       hx-target="#inventory-bin-stock-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("StockLevels")</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Summary.RowCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Assigned")</div><div class="fs-4 fw-semibold">@Model.Summary.AssignedCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Unassigned")</div><div class="fs-4 fw-semibold">@Model.Summary.UnassignedCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("NeedsAttention")</div><div class="fs-4 fw-semibold">@Model.Summary.AttentionCount</div></div></div>
</div>

<div class="d-flex gap-2 flex-wrap mb-3">
    <a asp-action="BinStock" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="WithAttention" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.BinStockQueueFilter.WithAttention ? "btn-warning" : "btn-outline-warning")"
       hx-get="@BinStockUrl(Model.BusinessId, Model.WarehouseId, Model.Query, "WithAttention")"
       hx-target="#inventory-bin-stock-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("NeedsAttention")</a>
    <a asp-action="BinStock" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Assigned" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.BinStockQueueFilter.Assigned ? "btn-primary" : "btn-outline-primary")"
       hx-get="@BinStockUrl(Model.BusinessId, Model.WarehouseId, Model.Query, "Assigned")"
       hx-target="#inventory-bin-stock-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Assigned")</a>
    <a asp-action="BinStock" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-filter="Unassigned" class="btn btn-sm @(Model.Filter == Darwin.Application.Inventory.DTOs.BinStockQueueFilter.Unassigned ? "btn-secondary" : "btn-outline-secondary")"
       hx-get="@BinStockUrl(Model.BusinessId, Model.WarehouseId, Model.Query, "Unassigned")"
       hx-target="#inventory-bin-stock-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("Unassigned")</a>
    <a asp-action="BinStock" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-secondary"
       hx-get="@BinStockUrl(Model.BusinessId, Model.WarehouseId, Model.Query)"
       hx-target="#inventory-bin-stock-workspace-shell"
       hx-swap="outerHTML"
       hx-push-url="true">@T.T("ClearQueueFilters")</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>@T.T("Warehouse")</th>
                <th>@T.T("Location")</th>
                <th>@T.T("Sku")</th>
                <th class="text-end">@T.T("Quantity")</th>
                <th class="text-end">@T.T("Available")</th>
                <th>@T.T("IdentityEvidence")</th>
                <th>@T.T("Status")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="8" class="text-center text-muted">@T.T("NoStockLevelsFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.WarehouseName</td>
                    <td>@LocationText(item)</td>
                    <td>@item.VariantSku</td>
                    <td class="text-end">@item.DerivedQuantity</td>
                    <td class="text-end">@item.AvailableQuantity</td>
                    <td>
                        @if (item.Identities.Count == 0)
                        {
                            <span class="text-muted">-</span>
                        }
                        else
                        {
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var identity in item.Identities)
                                {
                                    var label = string.Join(" / ", new[] { identity.LotCode, identity.SerialNumber, identity.HandlingUnitCode }.Where(x => !string.IsNullOrWhiteSpace(x)));
                                    <span class="badge text-bg-light border">@label: @identity.Quantity</span>
                                }
                            </div>
                        }
                    </td>
                    <td><span class="@BadgeClass(item.HasAttention)">@(item.HasAttention ? T.T("NeedsAttention") : T.T("Ready"))</span></td>
                    <td class="text-end">
                        <a asp-action="VariantLedger" asp-route-variantId="@item.ProductVariantId" asp-route-warehouseId="@item.WarehouseId" class="btn btn-sm btn-outline-primary"
                           hx-get="@VariantLedgerUrl(item.ProductVariantId, item.WarehouseId)"
                           hx-target="#inventory-bin-stock-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Ledger")</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Inventory" asp-action="BinStock" asp-route-businessId="@Model.BusinessId" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" hx-target="#inventory-bin-stock-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
