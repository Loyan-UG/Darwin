@model Darwin.WebAdmin.ViewModels.HumanResources.PayrollPeriodEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (bool?)ViewData["IsCreate"] ?? Model.Id == Guid.Empty;
    var rowVersion = Convert.ToBase64String(Model.RowVersion ?? Array.Empty<byte>());
    ViewData["Title"] = isCreate ? T.T("CreatePayrollPeriod") : T.T("EditPayrollPeriod");
}
<section class="admin-page">
    <h1 class="mb-3">@(isCreate ? T.T("CreatePayrollPeriod") : T.T("EditPayrollPeriod"))</h1>
    <form asp-action="@(isCreate ? "CreatePayrollPeriod" : "EditPayrollPeriod")" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="RowVersion" type="hidden" />
        <section class="admin-form-section">
            <div class="row g-3">
                <div class="col-md-4"><label asp-for="BusinessId" class="form-label"></label><select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select></div>
                <div class="col-md-4"><label asp-for="PeriodCode" class="form-label"></label><input asp-for="PeriodCode" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Model.StatusOptions" class="form-select" disabled></select><input asp-for="Status" type="hidden" /></div>
                <div class="col-md-3"><label asp-for="PeriodStartUtc" class="form-label"></label><input asp-for="PeriodStartUtc" type="date" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="PeriodEndUtc" class="form-label"></label><input asp-for="PeriodEndUtc" type="date" class="form-control" /></div>
                <div class="col-md-2"><label class="form-label">@T.T("Employees")</label><input value="@Model.EmployeeCount" class="form-control" readonly /></div>
                <div class="col-md-2"><label class="form-label">@T.T("WorkMinutes")</label><input value="@Model.TotalWorkMinutes" class="form-control" readonly /></div>
                <div class="col-md-2"><label class="form-label">@T.T("AbsenceMinutes")</label><input value="@Model.TotalAbsenceMinutes" class="form-control" readonly /></div>
                <div class="col-md-6"><label asp-for="ReviewNotes" class="form-label"></label><textarea asp-for="ReviewNotes" class="form-control"></textarea></div>
                <div class="col-md-6"><label asp-for="MetadataJson" class="form-label"></label><textarea asp-for="MetadataJson" class="form-control"></textarea></div>
            </div>
        </section>
        <button class="btn btn-primary" type="submit">@T.T("Save")</button>
        <a asp-action="PayrollPeriods" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Back")</a>
    </form>

    @if (!isCreate)
    {
        <section class="admin-form-section mt-4">
            <h2 class="admin-form-section-title">@T.T("PayrollSummary")</h2>
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead><tr><th>@T.T("Employee")</th><th>@T.T("WorkMinutes")</th><th>@T.T("BreakMinutes")</th><th>@T.T("AbsenceMinutes")</th><th>@T.T("Timesheets")</th><th>@T.T("Absences")</th></tr></thead>
                    <tbody>
                    @if (!Model.Lines.Any()) { <tr><td colspan="6" class="text-muted">@T.T("NoRecords")</td></tr> }
                    else {
                        foreach (var line in Model.Lines) {
                            <tr><td>@line.EmployeeNumber - @line.EmployeeName</td><td>@line.WorkMinutes</td><td>@line.BreakMinutes</td><td>@line.AbsenceMinutes</td><td>@line.ApprovedTimesheetCount</td><td>@line.ConfirmedAbsenceCount</td></tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </section>
        <section class="admin-form-section mt-4">
            <h2 class="admin-form-section-title">@T.T("Lifecycle")</h2>
            <div class="d-flex flex-wrap gap-2">
                <form asp-action="PreparePayrollPeriod" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="businessId" value="@Model.BusinessId" />
                    <input type="hidden" name="rowVersion" value="@rowVersion" />
                    <button class="btn btn-sm btn-outline-primary" type="submit">@T.T("Prepare")</button>
                </form>
                @foreach (var target in new[] { Darwin.Domain.Enums.PayrollPeriodStatus.Reviewed, Darwin.Domain.Enums.PayrollPeriodStatus.Approved, Darwin.Domain.Enums.PayrollPeriodStatus.Cancelled })
                {
                    <form asp-action="UpdatePayrollPeriodLifecycle" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="businessId" value="@Model.BusinessId" />
                        <input type="hidden" name="rowVersion" value="@rowVersion" />
                        <input type="hidden" name="target" value="@target" />
                        <input type="hidden" name="notes" value="@Model.ReviewNotes" />
                        <button class="btn btn-sm btn-outline-primary" type="submit">@T.T(target.ToString())</button>
                    </form>
                }
            </div>
        </section>
    }
</section>
