@model Darwin.WebAdmin.ViewModels.HumanResources.HrListVm<Darwin.Application.HumanResources.DTOs.PayrollRuleSetListItemDto, Darwin.Application.HumanResources.DTOs.PayrollRuleSetQueueFilter>
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{ ViewData["Title"] = T.T("PayrollRules"); }
<section class="admin-page">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">@T.T("PayrollRules")</h1>
        <a asp-action="CreatePayrollRuleSet" asp-route-businessId="@Model.BusinessId" class="btn btn-primary">@T.T("Create")</a>
    </div>
    <form asp-action="PayrollRules" method="get" class="d-flex gap-2 mb-3">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("Search")" />
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
    </form>
    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">@T.T("Records")</div><div class="fs-4">@Model.Total</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">@T.T("Active")</div><div class="fs-4">@Model.Items.Count(x => x.Status == Darwin.Domain.Enums.PayrollRuleSetStatus.Active)</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">@T.T("Draft")</div><div class="fs-4">@Model.Items.Count(x => x.Status == Darwin.Domain.Enums.PayrollRuleSetStatus.Draft)</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">@T.T("Components")</div><div class="fs-4">@Model.Items.Sum(x => x.ComponentCount)</div></div></div></div>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead><tr><th>@T.T("RuleSetCode")</th><th>@T.T("Jurisdiction")</th><th>@T.T("Version")</th><th>@T.T("Effective")</th><th>@T.T("Currency")</th><th>@T.T("Components")</th><th>@T.T("Status")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
            <tbody>
            @if (!Model.Items.Any()) { <tr><td colspan="8" class="text-muted">@T.T("NoRecords")</td></tr> }
            else {
                foreach (var item in Model.Items) {
                    <tr>
                        <td><div class="fw-semibold">@item.RuleSetCode</div><div class="text-muted small">@item.DisplayName</div></td>
                        <td>@item.JurisdictionCode</td>
                        <td>@item.RuleVersion</td>
                        <td>@item.EffectiveFromUtc.ToString("yyyy-MM-dd") - @(item.EffectiveToUtc?.ToString("yyyy-MM-dd") ?? T.T("Open"))</td>
                        <td>@item.Currency</td>
                        <td>@item.ComponentCount</td>
                        <td><span class="badge text-bg-light">@T.T(item.Status.ToString())</span></td>
                        <td class="text-end"><a asp-action="EditPayrollRuleSet" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">@T.T("Open")</a></td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>
