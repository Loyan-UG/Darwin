@model Darwin.WebAdmin.ViewModels.HumanResources.LeaveRequestEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{ var isCreate = (bool?)ViewData["IsCreate"] ?? Model.Id == Guid.Empty; ViewData["Title"] = isCreate ? T.T("CreateLeaveRequest") : T.T("EditLeaveRequest"); var rowVersion = Convert.ToBase64String(Model.RowVersion ?? Array.Empty<byte>()); }
<section class="admin-page"><h1 class="mb-3">@(isCreate ? T.T("CreateLeaveRequest") : T.T("EditLeaveRequest"))</h1>
    <form asp-action="@(isCreate ? "CreateLeaveRequest" : "EditLeaveRequest")" method="post">@Html.AntiForgeryToken()<input asp-for="Id" type="hidden" /><input asp-for="RowVersion" type="hidden" />
        <div class="row g-3"><div class="col-md-4"><label asp-for="BusinessId" class="form-label"></label><select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select></div><div class="col-md-4"><label asp-for="EmployeeId" class="form-label"></label><select asp-for="EmployeeId" asp-items="Model.EmployeeOptions" class="form-select"></select></div><div class="col-md-4"><label asp-for="RequestNumber" class="form-label"></label><input asp-for="RequestNumber" class="form-control" /></div><div class="col-md-3"><label asp-for="LeaveType" class="form-label"></label><select asp-for="LeaveType" asp-items="Model.LeaveTypeOptions" class="form-select"></select></div><div class="col-md-3"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Model.StatusOptions" class="form-select" disabled></select><input asp-for="Status" type="hidden" /></div><div class="col-md-3"><label asp-for="StartDateUtc" class="form-label"></label><input asp-for="StartDateUtc" type="date" class="form-control" /></div><div class="col-md-3"><label asp-for="EndDateUtc" class="form-label"></label><input asp-for="EndDateUtc" type="date" class="form-control" /></div><div class="col-md-3"><label asp-for="RequestedMinutes" class="form-label"></label><input asp-for="RequestedMinutes" class="form-control" /></div><div class="col-md-3"><label asp-for="PrivacyClassification" class="form-label"></label><select asp-for="PrivacyClassification" asp-items="Model.PrivacyOptions" class="form-select"></select></div><div class="col-md-6"><label asp-for="ReviewNotes" class="form-label"></label><textarea asp-for="ReviewNotes" class="form-control"></textarea></div><div class="col-md-6"><label asp-for="InternalNotes" class="form-label"></label><textarea asp-for="InternalNotes" class="form-control"></textarea></div><div class="col-md-6"><label asp-for="MetadataJson" class="form-label"></label><textarea asp-for="MetadataJson" class="form-control"></textarea></div></div>
        <div class="mt-3"><button class="btn btn-primary" type="submit">@T.T("Save")</button> <a asp-action="LeaveRequests" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Back")</a></div>
    </form>
    @if (!isCreate) {
        <section class="admin-form-section mt-4"><h2 class="admin-form-section-title">@T.T("Lifecycle")</h2><div class="d-flex flex-wrap gap-2">
            @foreach (var target in new[] { Darwin.Domain.Enums.LeaveRequestStatus.Submitted, Darwin.Domain.Enums.LeaveRequestStatus.InReview, Darwin.Domain.Enums.LeaveRequestStatus.Approved, Darwin.Domain.Enums.LeaveRequestStatus.Rejected, Darwin.Domain.Enums.LeaveRequestStatus.Cancelled }) {
                <form asp-action="UpdateLeaveRequestLifecycle" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="businessId" value="@Model.BusinessId" /><input type="hidden" name="rowVersion" value="@rowVersion" /><input type="hidden" name="target" value="@target" /><input type="hidden" name="notes" value="@Model.ReviewNotes" /><button class="btn btn-sm btn-outline-primary" type="submit">@T.T(target.ToString())</button></form>
            }
        </div></section>
    }
</section>
