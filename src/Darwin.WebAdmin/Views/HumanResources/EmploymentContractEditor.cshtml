@model Darwin.WebAdmin.ViewModels.HumanResources.EmploymentContractEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{ var isCreate = (bool?)ViewData["IsCreate"] ?? Model.Id == Guid.Empty; ViewData["Title"] = isCreate ? T.T("CreateEmploymentContract") : T.T("EditEmploymentContract"); }
<div id="hr-contract-editor">
    <h1 class="mb-3">@(isCreate ? T.T("CreateEmploymentContract") : T.T("EditEmploymentContract"))</h1>
    <form asp-action="@(isCreate ? "CreateEmploymentContract" : "EditEmploymentContract")" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" /><input asp-for="RowVersion" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <section class="admin-form-section"><h2 class="admin-form-section-title">@T.T("EmploymentContract")</h2><div class="row g-3">
            <div class="col-md-4"><label asp-for="BusinessId" class="form-label"></label><select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select></div>
            <div class="col-md-4"><label asp-for="EmployeeId" class="form-label"></label><select asp-for="EmployeeId" asp-items="Model.EmployeeOptions" class="form-select"></select></div>
            <div class="col-md-4"><label asp-for="ContractNumber" class="form-label"></label><input asp-for="ContractNumber" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="EmploymentType" class="form-label"></label><select asp-for="EmploymentType" asp-items="Model.EmploymentTypeOptions" class="form-select"></select></div>
            <div class="col-md-3"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select></div>
            <div class="col-md-3"><label asp-for="StartDateUtc" class="form-label"></label><input asp-for="StartDateUtc" class="form-control" type="date" /></div>
            <div class="col-md-3"><label asp-for="EndDateUtc" class="form-label"></label><input asp-for="EndDateUtc" class="form-control" type="date" /></div>
            <div class="col-md-3"><label asp-for="WeeklyHoursMinor" class="form-label"></label><input asp-for="WeeklyHoursMinor" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="PrivacyClassification" class="form-label"></label><select asp-for="PrivacyClassification" asp-items="Model.PrivacyOptions" class="form-select"></select></div>
            <div class="col-md-6"><label asp-for="InternalNotes" class="form-label"></label><textarea asp-for="InternalNotes" class="form-control" rows="3"></textarea></div>
            <div class="col-md-6"><label asp-for="MetadataJson" class="form-label"></label><textarea asp-for="MetadataJson" class="form-control font-monospace" rows="3"></textarea></div>
        </div></section>
        <button type="submit" class="btn btn-primary">@(isCreate ? T.T("Create") : T.T("Save"))</button>
        <a asp-action="EmploymentContracts" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Back")</a>
    </form>
    @if (!isCreate)
    {
        <form asp-action="ArchiveEmploymentContract" method="post" class="mt-3">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="businessId" value="@Model.BusinessId" /><input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion ?? Array.Empty<byte>())" /><button type="submit" class="btn btn-outline-danger">@T.T("Archive")</button></form>
    }
</div>
