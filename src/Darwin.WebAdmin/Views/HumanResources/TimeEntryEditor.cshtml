@model Darwin.WebAdmin.ViewModels.HumanResources.TimeEntryEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{ var isCreate = (bool?)ViewData["IsCreate"] ?? Model.Id == Guid.Empty; ViewData["Title"] = isCreate ? T.T("CreateTimeEntry") : T.T("EditTimeEntry"); }
<section class="admin-page"><h1 class="mb-3">@(isCreate ? T.T("CreateTimeEntry") : T.T("EditTimeEntry"))</h1>
    <form asp-action="@(isCreate ? "CreateTimeEntry" : "EditTimeEntry")" method="post">@Html.AntiForgeryToken()<input asp-for="Id" type="hidden" /><input asp-for="RowVersion" type="hidden" />
        <div class="row g-3"><div class="col-md-4"><label asp-for="BusinessId" class="form-label"></label><select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select></div><div class="col-md-4"><label asp-for="EmployeeId" class="form-label"></label><select asp-for="EmployeeId" asp-items="Model.EmployeeOptions" class="form-select"></select></div><div class="col-md-4"><label asp-for="WorkScheduleId" class="form-label"></label><select asp-for="WorkScheduleId" asp-items="Model.ScheduleOptions" class="form-select"></select></div><div class="col-md-3"><label asp-for="WorkDateUtc" class="form-label"></label><input asp-for="WorkDateUtc" type="date" class="form-control" /></div><div class="col-md-3"><label asp-for="DurationMinutes" class="form-label"></label><input asp-for="DurationMinutes" class="form-control" /></div><div class="col-md-3"><label asp-for="BreakMinutes" class="form-label"></label><input asp-for="BreakMinutes" class="form-control" /></div><div class="col-md-3"><label asp-for="WorkType" class="form-label"></label><input asp-for="WorkType" class="form-control" /></div><div class="col-md-3"><label asp-for="Source" class="form-label"></label><select asp-for="Source" asp-items="Model.SourceOptions" class="form-select"></select></div><div class="col-md-3"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select></div><div class="col-md-6"><label asp-for="Description" class="form-label"></label><input asp-for="Description" class="form-control" /></div><div class="col-md-6"><label asp-for="InternalNotes" class="form-label"></label><textarea asp-for="InternalNotes" class="form-control"></textarea></div><div class="col-md-6"><label asp-for="MetadataJson" class="form-label"></label><textarea asp-for="MetadataJson" class="form-control"></textarea></div></div>
        <div class="mt-3"><button class="btn btn-primary" type="submit">@T.T("Save")</button> <a asp-action="TimeEntries" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Back")</a></div>
    </form>
</section>
