@model Darwin.WebAdmin.ViewModels.HumanResources.HrListVm<Darwin.Application.HumanResources.DTOs.DepartmentListItemDto, Darwin.Application.HumanResources.DTOs.DepartmentQueueFilter>
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{ ViewData["Title"] = T.T("Departments"); }
<div id="hr-departments-shell">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">@T.T("Departments")</h1>
        <a asp-action="CreateDepartment" asp-route-businessId="@Model.BusinessId" class="btn btn-primary">@T.T("Create")</a>
    </div>
    <form asp-action="Departments" method="get" class="d-flex gap-2 mb-3">
        <select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("Search")" />
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
    </form>
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead><tr><th>@T.T("Code")</th><th>@T.T("DisplayName")</th><th>@T.T("Parent")</th><th>@T.T("Status")</th><th class="text-end">@T.T("Actions")</th></tr></thead>
            <tbody>
            @if (Model.Items.Count == 0) { <tr><td colspan="5" class="text-center text-muted">@T.T("NoItemsFound")</td></tr> }
            else { foreach (var item in Model.Items) { <tr><td class="fw-semibold">@item.Code</td><td>@item.DisplayName</td><td>@item.ParentDepartmentName</td><td><span class="badge text-bg-light">@T.T(item.Status.ToString())</span></td><td class="text-end"><a asp-action="EditDepartment" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">@T.T("Edit")</a></td></tr> } }
            </tbody>
        </table>
    </div>
    <pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="HumanResources" asp-action="Departments" asp-route-businessId="@Model.BusinessId" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter"></pager>
</div>
