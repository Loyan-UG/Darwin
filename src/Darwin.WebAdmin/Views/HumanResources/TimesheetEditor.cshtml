@model Darwin.WebAdmin.ViewModels.HumanResources.TimesheetEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{ var isCreate = (bool?)ViewData["IsCreate"] ?? Model.Id == Guid.Empty; ViewData["Title"] = isCreate ? T.T("CreateTimesheet") : T.T("EditTimesheet"); var rowVersion = Convert.ToBase64String(Model.RowVersion ?? Array.Empty<byte>()); }
<section class="admin-page"><h1 class="mb-3">@(isCreate ? T.T("CreateTimesheet") : T.T("EditTimesheet"))</h1>
    <form asp-action="@(isCreate ? "CreateTimesheet" : "EditTimesheet")" method="post">@Html.AntiForgeryToken()<input asp-for="Id" type="hidden" /><input asp-for="RowVersion" type="hidden" />
        <section class="admin-form-section"><div class="row g-3"><div class="col-md-4"><label asp-for="BusinessId" class="form-label"></label><select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select></div><div class="col-md-4"><label asp-for="EmployeeId" class="form-label"></label><select asp-for="EmployeeId" asp-items="Model.EmployeeOptions" class="form-select"></select></div><div class="col-md-4"><label asp-for="TimesheetNumber" class="form-label"></label><input asp-for="TimesheetNumber" class="form-control" /></div><div class="col-md-3"><label asp-for="PeriodStartUtc" class="form-label"></label><input asp-for="PeriodStartUtc" type="date" class="form-control" /></div><div class="col-md-3"><label asp-for="PeriodEndUtc" class="form-label"></label><input asp-for="PeriodEndUtc" type="date" class="form-control" /></div><div class="col-md-3"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Model.StatusOptions" class="form-select" disabled></select><input asp-for="Status" type="hidden" /></div><div class="col-md-3"><label class="form-label">@T.T("WorkMinutes")</label><input value="@Model.TotalWorkMinutes" class="form-control" readonly /></div><div class="col-md-6"><label asp-for="TimeEntryIds" class="form-label"></label><select asp-for="TimeEntryIds" asp-items="Model.TimeEntryOptions" multiple class="form-select" size="8"></select></div><div class="col-md-6"><label asp-for="ReviewNotes" class="form-label"></label><textarea asp-for="ReviewNotes" class="form-control"></textarea><label asp-for="MetadataJson" class="form-label mt-2"></label><textarea asp-for="MetadataJson" class="form-control"></textarea></div></div></section>
        <button class="btn btn-primary" type="submit">@T.T("Save")</button> <a asp-action="Timesheets" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Back")</a>
    </form>
    @if (!isCreate) {
        <section class="admin-form-section mt-4"><h2 class="admin-form-section-title">@T.T("TimesheetLines")</h2><table class="table table-sm"><tbody>@foreach (var line in Model.Lines) { <tr><td>@line.WorkDateUtc.ToString("yyyy-MM-dd")</td><td>@line.WorkType</td><td>@line.DurationMinutes</td><td>@line.BreakMinutes</td></tr> }</tbody></table></section>
        <section class="admin-form-section mt-4"><h2 class="admin-form-section-title">@T.T("Lifecycle")</h2><div class="d-flex flex-wrap gap-2">
            @foreach (var target in new[] { Darwin.Domain.Enums.TimesheetStatus.Submitted, Darwin.Domain.Enums.TimesheetStatus.InReview, Darwin.Domain.Enums.TimesheetStatus.Approved, Darwin.Domain.Enums.TimesheetStatus.Rejected, Darwin.Domain.Enums.TimesheetStatus.Cancelled }) {
                <form asp-action="UpdateTimesheetLifecycle" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="businessId" value="@Model.BusinessId" /><input type="hidden" name="rowVersion" value="@rowVersion" /><input type="hidden" name="target" value="@target" /><input type="hidden" name="notes" value="@Model.ReviewNotes" /><button class="btn btn-sm btn-outline-primary" type="submit">@T.T(target.ToString())</button></form>
            }
        </div></section>
    }
</section>
