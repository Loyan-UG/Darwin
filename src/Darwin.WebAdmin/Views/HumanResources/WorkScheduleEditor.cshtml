@model Darwin.WebAdmin.ViewModels.HumanResources.WorkScheduleEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{ var isCreate = (bool?)ViewData["IsCreate"] ?? Model.Id == Guid.Empty; ViewData["Title"] = isCreate ? T.T("CreateWorkSchedule") : T.T("EditWorkSchedule"); }
<section class="admin-page">
    <h1 class="mb-3">@(isCreate ? T.T("CreateWorkSchedule") : T.T("EditWorkSchedule"))</h1>
    <form asp-action="@(isCreate ? "CreateWorkSchedule" : "EditWorkSchedule")" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" /><input asp-for="RowVersion" type="hidden" />
        <section class="admin-form-section"><h2 class="admin-form-section-title">@T.T("WorkSchedule")</h2><div class="row g-3">
            <div class="col-md-4"><label asp-for="BusinessId" class="form-label"></label><select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select></div>
            <div class="col-md-4"><label asp-for="EmployeeId" class="form-label"></label><select asp-for="EmployeeId" asp-items="Model.EmployeeOptions" class="form-select"></select></div>
            <div class="col-md-4"><label asp-for="ScheduleCode" class="form-label"></label><input asp-for="ScheduleCode" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select></div>
            <div class="col-md-4"><label asp-for="EffectiveFromUtc" class="form-label"></label><input asp-for="EffectiveFromUtc" type="date" class="form-control" /></div>
            <div class="col-md-4"><label asp-for="EffectiveToUtc" class="form-label"></label><input asp-for="EffectiveToUtc" type="date" class="form-control" /></div>
        </div></section>
        <section class="admin-form-section"><h2 class="admin-form-section-title">@T.T("WeeklyMinutes")</h2><div class="row g-3">
            <div class="col-md-2"><label asp-for="MondayMinutes" class="form-label"></label><input asp-for="MondayMinutes" class="form-control" /></div>
            <div class="col-md-2"><label asp-for="TuesdayMinutes" class="form-label"></label><input asp-for="TuesdayMinutes" class="form-control" /></div>
            <div class="col-md-2"><label asp-for="WednesdayMinutes" class="form-label"></label><input asp-for="WednesdayMinutes" class="form-control" /></div>
            <div class="col-md-2"><label asp-for="ThursdayMinutes" class="form-label"></label><input asp-for="ThursdayMinutes" class="form-control" /></div>
            <div class="col-md-2"><label asp-for="FridayMinutes" class="form-label"></label><input asp-for="FridayMinutes" class="form-control" /></div>
            <div class="col-md-1"><label asp-for="SaturdayMinutes" class="form-label"></label><input asp-for="SaturdayMinutes" class="form-control" /></div>
            <div class="col-md-1"><label asp-for="SundayMinutes" class="form-label"></label><input asp-for="SundayMinutes" class="form-control" /></div>
        </div></section>
        <section class="admin-form-section"><div class="row g-3"><div class="col-md-6"><label asp-for="InternalNotes" class="form-label"></label><textarea asp-for="InternalNotes" class="form-control"></textarea></div><div class="col-md-6"><label asp-for="MetadataJson" class="form-label"></label><textarea asp-for="MetadataJson" class="form-control"></textarea></div></div></section>
        <button class="btn btn-primary" type="submit">@T.T("Save")</button> <a asp-action="WorkSchedules" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Back")</a>
    </form>
    @if (!isCreate) {
        <form asp-action="ArchiveWorkSchedule" method="post" class="mt-3">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="businessId" value="@Model.BusinessId" /><input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion ?? Array.Empty<byte>())" /><button type="submit" class="btn btn-outline-danger">@T.T("Archive")</button></form>
        <section class="admin-form-section mt-4"><h2 class="admin-form-section-title">@T.T("ScheduleExceptions")</h2>
            <form asp-action="CreateWorkScheduleException" method="post" class="row g-2 align-items-end">@Html.AntiForgeryToken()<input type="hidden" name="BusinessId" value="@Model.BusinessId" /><input type="hidden" name="WorkScheduleId" value="@Model.Id" /><div class="col-md-3"><label class="form-label">@T.T("WorkDate")</label><input name="WorkDateUtc" type="date" class="form-control" /></div><div class="col-md-2"><label class="form-label">@T.T("Minutes")</label><input name="ScheduledMinutes" class="form-control" /></div><div class="col-md-5"><label class="form-label">@T.T("Reason")</label><input name="Reason" class="form-control" /></div><div class="col-md-2"><button class="btn btn-outline-primary w-100" type="submit">@T.T("Add")</button></div></form>
            <table class="table table-sm mt-3"><tbody>@foreach (var item in Model.Exceptions) { <tr><td>@item.WorkDateUtc.ToString("yyyy-MM-dd")</td><td>@item.ScheduledMinutes</td><td>@item.Reason</td></tr> }</tbody></table>
        </section>
    }
</section>
