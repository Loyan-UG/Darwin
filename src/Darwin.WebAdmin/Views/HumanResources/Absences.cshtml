@model Darwin.WebAdmin.ViewModels.HumanResources.HrListVm<Darwin.Application.HumanResources.DTOs.AbsenceRecordListItemDto, Darwin.Application.HumanResources.DTOs.AbsenceRecordQueueFilter>
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{ ViewData["Title"] = T.T("Absences"); }
<section class="admin-page">
    <div class="d-flex justify-content-between align-items-center mb-3"><h1 class="mb-0">@T.T("Absences")</h1><a asp-action="CreateAbsence" asp-route-businessId="@Model.BusinessId" class="btn btn-primary">@T.T("Create")</a></div>
    <form asp-action="Absences" method="get" class="d-flex gap-2 mb-3"><select name="businessId" asp-items="Model.BusinessOptions" class="form-select"></select><select name="filter" asp-items="Model.FilterItems" class="form-select"></select><button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button></form>
    <div class="table-responsive"><table class="table table-sm table-striped align-middle"><thead><tr><th>@T.T("Employee")</th><th>@T.T("Type")</th><th>@T.T("Period")</th><th>@T.T("Minutes")</th><th>@T.T("LeaveRequest")</th><th>@T.T("Status")</th><th class="text-end">@T.T("Actions")</th></tr></thead><tbody>
    @if (!Model.Items.Any()) { <tr><td colspan="7" class="text-muted">@T.T("NoRecords")</td></tr> }
    else { foreach (var item in Model.Items) { <tr><td>@item.EmployeeName</td><td>@T.T(item.AbsenceType.ToString())</td><td>@item.StartDateUtc.ToString("yyyy-MM-dd") - @item.EndDateUtc.ToString("yyyy-MM-dd")</td><td>@item.AbsenceMinutes</td><td>@item.LeaveRequestNumber</td><td><span class="badge text-bg-light">@T.T(item.Status.ToString())</span></td><td class="text-end"><a asp-action="EditAbsence" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">@T.T("Edit")</a></td></tr> } }
    </tbody></table></div>
</section>
