@model Darwin.WebAdmin.ViewModels.HumanResources.AbsenceRecordEditVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{ var isCreate = (bool?)ViewData["IsCreate"] ?? Model.Id == Guid.Empty; ViewData["Title"] = isCreate ? T.T("CreateAbsence") : T.T("EditAbsence"); }
<section class="admin-page"><h1 class="mb-3">@(isCreate ? T.T("CreateAbsence") : T.T("EditAbsence"))</h1>
    <form asp-action="@(isCreate ? "CreateAbsence" : "EditAbsence")" method="post">@Html.AntiForgeryToken()<input asp-for="Id" type="hidden" /><input asp-for="RowVersion" type="hidden" />
        <div class="row g-3"><div class="col-md-4"><label asp-for="BusinessId" class="form-label"></label><select asp-for="BusinessId" asp-items="Model.BusinessOptions" class="form-select"></select></div><div class="col-md-4"><label asp-for="EmployeeId" class="form-label"></label><select asp-for="EmployeeId" asp-items="Model.EmployeeOptions" class="form-select"></select></div><div class="col-md-4"><label asp-for="LeaveRequestId" class="form-label"></label><select asp-for="LeaveRequestId" asp-items="Model.LeaveRequestOptions" class="form-select"></select></div><div class="col-md-3"><label asp-for="AbsenceType" class="form-label"></label><select asp-for="AbsenceType" asp-items="Model.AbsenceTypeOptions" class="form-select"></select></div><div class="col-md-3"><label asp-for="Status" class="form-label"></label><select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select></div><div class="col-md-3"><label asp-for="StartDateUtc" class="form-label"></label><input asp-for="StartDateUtc" type="date" class="form-control" /></div><div class="col-md-3"><label asp-for="EndDateUtc" class="form-label"></label><input asp-for="EndDateUtc" type="date" class="form-control" /></div><div class="col-md-3"><label asp-for="AbsenceMinutes" class="form-label"></label><input asp-for="AbsenceMinutes" class="form-control" /></div><div class="col-md-3"><label asp-for="PrivacyClassification" class="form-label"></label><select asp-for="PrivacyClassification" asp-items="Model.PrivacyOptions" class="form-select"></select></div><div class="col-md-6"><label asp-for="InternalNotes" class="form-label"></label><textarea asp-for="InternalNotes" class="form-control"></textarea></div><div class="col-md-6"><label asp-for="MetadataJson" class="form-label"></label><textarea asp-for="MetadataJson" class="form-control"></textarea></div></div>
        <div class="mt-3"><button class="btn btn-primary" type="submit">@T.T("Save")</button> <a asp-action="Absences" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Back")</a></div>
    </form>
</section>
