@model Darwin.WebAdmin.ViewModels.Admin.AdminDashboardVm
@inject Darwin.WebAdmin.Infrastructure.PermissionRazorHelper Perms
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("AdminDashboardTitle");
    var canManageIdentity = await Perms.HasAsync("FullAdminAccess");
    var canManageBusinesses = await Perms.HasAsync("ManageBusinessSupport");

    string SeverityBadgeClass(string severity) => severity switch
    {
        "critical" => "text-bg-danger",
        "warning" => "text-bg-warning",
        _ => "text-bg-info"
    };

    string SeverityLabelKey(string severity) => severity switch
    {
        "critical" => "Critical",
        "warning" => "Warning",
        _ => "Info"
    };
}

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="mb-1">@T.T("AdminDashboardTitle")</h1>
        <div class="text-muted small">@T.T("AdminDashboardSubtitle")</div>
    </div>

    <form asp-action="Index" method="get" class="d-flex flex-wrap align-items-center gap-2">
        <label for="businessId" class="form-label mb-0 text-muted">@T.T("BusinessContext")</label>
        <select id="businessId" name="businessId" asp-items="Model.BusinessOptions" class="form-select">
            @if (Model.BusinessOptions.Count == 0)
            {
                <option value="">@T.T("NoActiveBusiness")</option>
            }
        </select>
        <button type="submit" class="btn btn-outline-secondary">@T.T("Apply")</button>
    </form>
</div>

<section class="row g-3" aria-label="@T.T("DashboardKpisTitle")">
    @foreach (var kpi in Model.Kpis)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between gap-2">
                        <div>
                            <div class="text-muted small">@T.T(kpi.LabelKey)</div>
                            <div class="fs-2 fw-semibold">@kpi.Count</div>
                        </div>
                        <span class="badge @kpi.BadgeCssClass">@T.T(kpi.BadgeKey)</span>
                    </div>
                    <a href="@Url.Action(kpi.Action, kpi.Controller, kpi.RouteValues)" class="btn btn-sm btn-outline-primary mt-3">@T.T(kpi.ActionLabelKey)</a>
                </div>
            </div>
        </div>
    }
</section>

<section class="card shadow-sm mt-4">
    <div class="card-header bg-white">
        <div class="d-flex align-items-center justify-content-between gap-2">
            <div class="fw-semibold d-inline-flex align-items-center">
                @T.T("DashboardNeedsAttentionTitle")
                <field-help title="@T.T("DashboardNeedsAttentionTitle")" content="@T.T("DashboardNeedsAttentionHelp")" placement="bottom" />
            </div>
            <a asp-controller="Businesses" asp-action="SupportQueue" class="btn btn-sm btn-outline-secondary">@T.T("BusinessSupportOpenQueueAction")</a>
        </div>
    </div>
    <div class="card-body">
        @if (Model.AttentionItems.Count == 0)
        {
            <div class="alert alert-success mb-0">@T.T("DashboardNoAttentionItems")</div>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var item in Model.AttentionItems)
                {
                    <div class="list-group-item px-0">
                        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                            <div class="d-flex align-items-start gap-3">
                                <span class="badge @SeverityBadgeClass(item.Severity) mt-1">@T.T(SeverityLabelKey(item.Severity))</span>
                                <div>
                                    <div class="fw-semibold">@T.T(item.TitleKey)</div>
                                    <div class="small text-muted">@T.T(item.ModuleKey)</div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span class="fs-5 fw-semibold">@item.Count</span>
                                <a href="@Url.Action(item.Action, item.Controller, item.RouteValues)" class="btn btn-sm btn-outline-primary">@T.T(item.ActionLabelKey)</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@if (Model.BusinessContext is not null)
{
    <section class="card shadow-sm mt-4">
        <div class="card-header bg-white">
            <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-2">
                <div>
                    <div class="fw-semibold">@T.T("DashboardBusinessContextTitle")</div>
                    <div class="small text-muted">@Model.BusinessContext.BusinessName</div>
                </div>
                <a asp-controller="Businesses" asp-action="MerchantReadiness" class="btn btn-sm btn-outline-secondary">@T.T("MerchantReadinessTitle")</a>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                @foreach (var row in Model.BusinessContext.Rows)
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="border rounded p-3 h-100">
                            <div class="fw-semibold">@T.T(row.TitleKey)</div>
                            <div class="d-flex flex-wrap gap-3 mt-3">
                                @foreach (var metric in row.Metrics.Take(3))
                                {
                                    <div>
                                        <div class="text-muted small">@T.T(metric.LabelKey)</div>
                                        <div class="fw-semibold">@metric.Value</div>
                                    </div>
                                }
                            </div>
                            <a href="@Url.Action(row.PrimaryAction, row.PrimaryController, row.PrimaryRouteValues)" class="btn btn-sm btn-outline-primary mt-3">@T.T(row.PrimaryActionLabelKey)</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<section class="card shadow-sm mt-4">
    <div class="card-header bg-white">
        <div class="fw-semibold d-inline-flex align-items-center">
            @T.T("DashboardOperationsOverviewTitle")
            <field-help title="@T.T("DashboardOperationsOverviewTitle")" content="@T.T("DashboardOperationsOverviewHelp")" placement="bottom" />
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            @foreach (var module in Model.ModuleSummaries)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-semibold">@T.T(module.TitleKey)</div>
                        <div class="row g-2 mt-2">
                            @foreach (var metric in module.Metrics.Take(3))
                            {
                                <div class="col-4">
                                    <div class="text-muted small">@T.T(metric.LabelKey)</div>
                                    <div class="fw-semibold">@metric.Value</div>
                                </div>
                            }
                        </div>
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <a href="@Url.Action(module.PrimaryAction, module.PrimaryController, module.PrimaryRouteValues)" class="btn btn-sm btn-outline-primary">@T.T(module.PrimaryActionLabelKey)</a>
                            @if (!string.IsNullOrWhiteSpace(module.SecondaryActionLabelKey) &&
                                 !string.IsNullOrWhiteSpace(module.SecondaryController) &&
                                 !string.IsNullOrWhiteSpace(module.SecondaryAction))
                            {
                                <a href="@Url.Action(module.SecondaryAction, module.SecondaryController, module.SecondaryRouteValues)" class="btn btn-sm btn-outline-secondary">@T.T(module.SecondaryActionLabelKey)</a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<nav class="d-flex flex-wrap gap-2 mt-4" aria-label="@T.T("DashboardQuickLinksTitle")">
    <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkOrdersAction")</a>
    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkProductsAction")</a>
    <a asp-controller="Pages" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkPagesAction")</a>
    <a asp-controller="Media" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkMediaAction")</a>
    <a asp-controller="Crm" asp-action="Customers" class="btn btn-outline-primary">@T.T("DashboardQuickLinkCustomersAction")</a>
    @if (canManageBusinesses)
    {
        <a asp-controller="Businesses" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkBusinessesAction")</a>
        <a asp-controller="BusinessCommunications" asp-action="Index" class="btn btn-outline-primary">@T.T("Communications")</a>
    }
    @if (canManageIdentity)
    {
        <a asp-controller="Users" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkUsersAction")</a>
        <a asp-controller="SiteSettings" asp-action="Edit" class="btn btn-outline-primary">@T.T("DashboardQuickLinkSettingsAction")</a>
    }
</nav>
