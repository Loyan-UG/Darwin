@model Darwin.WebAdmin.ViewModels.Admin.AdminDashboardVm
@inject Darwin.WebAdmin.Infrastructure.PermissionRazorHelper Perms
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("AdminDashboardTitle");
    var canManageIdentity = await Perms.HasAsync("FullAdminAccess");
    var canManageBusinesses = await Perms.HasAsync("ManageBusinessSupport");
    var mobileAttentionCount = Model.MobileStaleDeviceCount + Model.MobileMissingPushTokenCount;
    var businessOperationsAttentionCount = (Model.PaymentCount ?? 0) + (Model.PurchaseOrderCount ?? 0);
    var businessComplianceAttentionCount = (Model.PaymentCount ?? 0) + Model.OrderCount;
    var businessCommunicationRuntimeExecutionAttentionCount = Model.BusinessSupport.SelectedBusinessPendingActivationCount
        + Model.BusinessSupport.SelectedBusinessFailedInvitationCount
        + Model.BusinessSupport.SelectedBusinessFailedActivationCount
        + Model.BusinessSupport.SelectedBusinessFailedPasswordResetCount
        + Model.BusinessSupport.SelectedBusinessFailedAdminTestCount;
}

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
    <div>
        <div class="d-flex align-items-center">
            <h1 class="mb-0">@T.T("AdminDashboardTitle")</h1>
            <field-help title="@T.T("AdminDashboardTitle")" content="@T.T("AdminDashboardIntro")" placement="bottom" />
        </div>
    </div>

    <form asp-action="Index" method="get" class="d-flex align-items-center gap-2">
        <label for="businessId" class="form-label mb-0 text-muted d-inline-flex align-items-center">
            @T.T("BusinessContext")
            <field-help title="@T.T("BusinessContext")" content="@T.T("BusinessContextHelp")" placement="bottom" />
        </label>
        <select id="businessId" name="businessId" asp-items="Model.BusinessOptions" class="form-select">
            @if (Model.BusinessOptions.Count == 0)
            {
                <option value="">@T.T("NoActiveBusiness")</option>
            }
        </select>
        <button type="submit" class="btn btn-outline-secondary">@T.T("Apply")</button>
    </form>
</div>

@if (canManageBusinesses)
{
    <div class="row g-3 mt-1">
        <div class="col-12">
            <partial name="~/Views/Home/_CommunicationOpsCard.cshtml" model="Model" />
        </div>
    </div>
}

<div class="row g-3">
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <div class="text-muted small d-inline-flex align-items-center">
                    @T.T("DashboardProductsLabel")
                    <field-help title="@T.T("DashboardProductsLabel")" content="@T.T("DashboardProductsHelp")" placement="bottom" />
                </div>
                <div class="fs-2 fw-semibold">@Model.ProductCount</div>
                <a asp-controller="Products" asp-action="Index" class="btn btn-sm btn-outline-primary mt-3">@T.T("DashboardOpenCatalogAction")</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <div class="text-muted small d-inline-flex align-items-center">
                    @T.T("DashboardPagesLabel")
                    <field-help title="@T.T("DashboardPagesLabel")" content="@T.T("DashboardPagesHelp")" placement="bottom" />
                </div>
                <div class="fs-2 fw-semibold">@Model.PageCount</div>
                <a asp-controller="Pages" asp-action="Index" class="btn btn-sm btn-outline-primary mt-3">@T.T("DashboardOpenCmsAction")</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="card h-100 shadow-sm">
            <div class="card-body">
                <div class="text-muted small d-inline-flex align-items-center">
                    @T.T("DashboardOrdersLabel")
                    <field-help title="@T.T("DashboardOrdersLabel")" content="@T.T("DashboardOrdersHelp")" placement="bottom" />
                </div>
                <div class="fs-2 fw-semibold">@Model.OrderCount</div>
                <a asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-outline-primary mt-3">@T.T("DashboardOpenOrdersAction")</a>
            </div>
        </div>
    </div>
    @if (canManageIdentity)
    {
        <div class="col-md-6 col-xl-3">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small d-inline-flex align-items-center">
                        @T.T("DashboardUsersLabel")
                        <field-help title="@T.T("DashboardUsersLabel")" content="@T.T("DashboardUsersHelp")" placement="bottom" />
                    </div>
                    <div class="fs-2 fw-semibold">@Model.UserCount</div>
                    <a asp-controller="Users" asp-action="Index" class="btn btn-sm btn-outline-primary mt-3">@T.T("DashboardOpenIdentityAction")</a>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-3 mt-1">
    @if (canManageBusinesses)
    {
        <div class="col-lg-4">
            <partial name="~/Views/Home/_BusinessSupportQueueCard.cshtml" model="Model" />
        </div>
    }

    <div class="@(canManageBusinesses ? "col-lg-4" : "col-lg-6")">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-white">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="fw-semibold d-inline-flex align-items-center">
                            @T.T("DashboardCrmTitle")
                            <field-help title="@T.T("DashboardCrmTitle")" content="@T.T("DashboardCrmIntro")" placement="bottom" />
                        </div>
                    </div>
                    <a asp-controller="Crm" asp-action="Index" class="btn btn-sm btn-outline-secondary">@T.T("DashboardOpenCrmAction")</a>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6 col-xl-4">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">@T.T("DashboardCustomersLabel")</div>
                            <div class="fs-4 fw-semibold">@Model.Crm.CustomerCount</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-4">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">@T.T("DashboardLeadsLabel")</div>
                            <div class="fs-4 fw-semibold">@Model.Crm.LeadCount</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-4">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">@T.T("DashboardQualifiedLeadsLabel")</div>
                            <div class="fs-4 fw-semibold">@Model.Crm.QualifiedLeadCount</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-4">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">@T.T("DashboardOpenOpportunitiesLabel")</div>
                            <div class="fs-4 fw-semibold">@Model.Crm.OpenOpportunityCount</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-4">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">@T.T("DashboardSegmentsLabel")</div>
                            <div class="fs-4 fw-semibold">@Model.Crm.SegmentCount</div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-xl-4">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small">@T.T("DashboardInteractions7dLabel")</div>
                            <div class="fs-4 fw-semibold">@Model.Crm.RecentInteractionCount</div>
                        </div>
                    </div>
                </div>

                <div class="border rounded p-3 mt-3">
                    <div class="text-muted small d-inline-flex align-items-center">
                        @T.T("DashboardOpenPipelineLabel")
                        <field-help title="@T.T("DashboardOpenPipelineLabel")" content="@T.T("DashboardOpenPipelineHelp")" placement="bottom" />
                    </div>
                    <div class="fs-4 fw-semibold">@Model.Crm.Currency @((Model.Crm.OpenPipelineMinor / 100.0M).ToString("0.00"))</div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-md-6">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small d-inline-flex align-items-center">
                                @T.T("Invoices")
                                <field-help title="@T.T("Invoices")" content="@T.T("DashboardInvoicesHelp")" placement="bottom" />
                            </div>
                            <div class="d-flex gap-2 flex-wrap mt-3">
                                <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="Overdue" class="btn btn-sm btn-outline-warning">@T.T("Overdue")</a>
                                <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="DueSoon" class="btn btn-sm btn-outline-warning">@T.T("DueSoon")</a>
                                <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="Draft" class="btn btn-sm btn-outline-secondary">@T.T("Draft")</a>
                                <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="MissingVatId" class="btn btn-sm btn-outline-secondary">@T.T("FixVatId")</a>
                                <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="Refunded" class="btn btn-sm btn-outline-secondary">@T.T("Refunded")</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded p-3 h-100">
                            <div class="text-muted small d-inline-flex align-items-center">
                                @T.T("Payments")
                                <field-help title="@T.T("Payments")" content="@T.T("DashboardPaymentsHelp")" placement="bottom" />
                            </div>
                            <div class="d-flex gap-2 flex-wrap mt-3">
                                <a asp-controller="Billing" asp-action="Payments" asp-route-queue="@Darwin.Application.Billing.DTOs.PaymentQueueFilter.Pending" class="btn btn-sm btn-outline-warning">@T.T("Pending")</a>
                                <a asp-controller="Billing" asp-action="Payments" asp-route-queue="@Darwin.Application.Billing.DTOs.PaymentQueueFilter.Unlinked" class="btn btn-sm btn-outline-warning">@T.T("Unlinked")</a>
                                <a asp-controller="Billing" asp-action="Payments" asp-route-queue="@Darwin.Application.Billing.DTOs.PaymentQueueFilter.Refunded" class="btn btn-sm btn-outline-secondary">@T.T("Refunded")</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="@(canManageBusinesses ? "col-lg-4" : "col-lg-6")">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-white">
                <div class="d-flex align-items-center justify-content-between gap-2">
                    <div>
                        <div class="fw-semibold d-inline-flex align-items-center">
                            @T.T("DashboardBusinessOperationsTitle")
                            <field-help title="@T.T("DashboardBusinessOperationsTitle")" content="@T.T("DashboardBusinessOperationsHelp")" placement="bottom" />
                        </div>
                        <div class="small text-muted">
                            @if (Model.SelectedBusinessId.HasValue)
                            {
                                <span>@string.Format(T.T("DashboardCurrentBusinessLabel"), Model.SelectedBusinessLabel)</span>
                            }
                            else
                            {
                                <span>@T.T("DashboardNoBusinessOperationsIntro")</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body">
                @if (Model.SelectedBusinessId.HasValue)
                {
                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                        <div>
                            <div class="text-muted text-uppercase small fw-semibold">@T.T("GoLiveReadiness")</div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-controller="Businesses" asp-action="MerchantReadiness" class="btn btn-sm btn-outline-primary">@T.T("MerchantReadinessTitle")</a>
                            <a asp-controller="Businesses" asp-action="SupportQueue" class="btn btn-sm btn-outline-secondary">@T.T("BusinessSupportQueueTitle")</a>
                            <a asp-controller="Billing" asp-action="TaxCompliance" class="btn btn-sm btn-outline-secondary">@T.T("TaxComplianceTitle")</a>
                            <a asp-controller="BusinessCommunications" asp-action="Index" class="btn btn-sm btn-outline-secondary">@T.T("Communications")</a>
                            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary">@T.T("CommunicationPolicy")</a>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">@T.T("DashboardPaymentsLabel")</div>
                                <div class="fs-4 fw-semibold">@Model.PaymentCount</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">@T.T("DashboardWarehousesLabel")</div>
                                <div class="fs-4 fw-semibold">@Model.WarehouseCount</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">@T.T("DashboardSuppliersLabel")</div>
                                <div class="fs-4 fw-semibold">@Model.SupplierCount</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">@T.T("DashboardPurchaseOrdersLabel")</div>
                                <div class="fs-4 fw-semibold">@Model.PurchaseOrderCount</div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small d-inline-flex align-items-center">
                                    @T.T("NeedsAttention")
                                    <field-help title="@T.T("NeedsAttention")" content="@T.T("DashboardBusinessNeedsAttentionHelp")" placement="bottom" />
                                </div>
                                <div class="fs-4 fw-semibold">@businessOperationsAttentionCount</div>
                                <div class="small text-muted mt-2">@T.T("TaxComplianceTitle"): <strong>@businessComplianceAttentionCount</strong> / @T.T("RuntimeExecution"): <strong>@businessCommunicationRuntimeExecutionAttentionCount</strong></div>
                                <div class="d-flex gap-2 flex-wrap mt-3">
                                    <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-primary">@T.T("DashboardOpenPaymentsAction")</a>
                                    <a asp-controller="Businesses" asp-action="MerchantReadiness" class="btn btn-sm btn-outline-secondary">@T.T("MerchantReadinessTitle")</a>
                                    <a asp-controller="Billing" asp-action="TaxCompliance" class="btn btn-sm btn-outline-secondary">@T.T("TaxComplianceTitle")</a>
                                    <a asp-controller="BusinessCommunications" asp-action="Index" class="btn btn-sm btn-outline-secondary">@T.T("Communications")</a>
                                    <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary">@T.T("CommunicationPolicy")</a>
                                </div>
                                <details class="mt-3">
                                    <summary class="small text-muted">@T.T("Queue")</summary>
                                    <div class="d-flex gap-2 flex-wrap mt-2">
                                    <a asp-controller="Businesses" asp-action="Invitations" asp-route-businessId="@Model.SelectedBusinessId" asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending" class="btn btn-sm btn-outline-secondary">@T.T("Pending")</a>
                                    <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.SelectedBusinessId" asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.PendingActivation" class="btn btn-sm btn-outline-secondary">@T.T("UsersFilterUnconfirmed")</a>
                                    <a asp-controller="Businesses" asp-action="Members" asp-route-businessId="@Model.SelectedBusinessId" asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Locked" class="btn btn-sm btn-outline-secondary">@T.T("UsersFilterLocked")</a>
                                    <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-businessId="@Model.SelectedBusinessId" asp-route-retryBlockedOnly="true" class="btn btn-sm btn-outline-warning">@T.T("RetryBlocked")</a>
                                    <a asp-controller="BusinessCommunications" asp-action="ChannelAudits" asp-route-businessId="@Model.SelectedBusinessId" asp-route-actionBlockedOnly="true" class="btn btn-sm btn-outline-warning">@T.T("ActionBlocked")</a>
                                    <a asp-controller="BusinessCommunications" asp-action="ChannelAudits" asp-route-businessId="@Model.SelectedBusinessId" asp-route-escalationCandidatesOnly="true" class="btn btn-sm btn-outline-dark">@T.T("EscalationCandidates")</a>
                                    <a asp-controller="BusinessCommunications" asp-action="ChannelAudits" asp-route-businessId="@Model.SelectedBusinessId" asp-route-phoneVerificationOnly="true" class="btn btn-sm btn-outline-dark">@T.T("PhoneVerification")</a>
                                    <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-businessId="@Model.SelectedBusinessId" asp-route-status="Failed" asp-route-flowKey="BusinessInvitation" class="btn btn-sm btn-outline-secondary">@T.T("OpenFailedInvitationEmails")</a>
                                    <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-businessId="@Model.SelectedBusinessId" asp-route-status="Failed" asp-route-flowKey="AccountActivation" class="btn btn-sm btn-outline-secondary">@T.T("OpenFailedActivationEmails")</a>
                                    <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-businessId="@Model.SelectedBusinessId" asp-route-status="Failed" asp-route-flowKey="AdminCommunicationTest" class="btn btn-sm btn-outline-secondary">@T.T("FailedAdminTests")</a>
                                    <a asp-controller="BusinessCommunications" asp-action="EmailAudits" asp-route-businessId="@Model.SelectedBusinessId" asp-route-status="Failed" asp-route-flowKey="PasswordReset" class="btn btn-sm btn-outline-secondary">@T.T("OpenFailedPasswordResets")</a>
                                    <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.SelectedBusinessId" asp-route-queue="@Darwin.Application.Billing.DTOs.PaymentQueueFilter.Pending" class="btn btn-sm btn-outline-warning">@T.T("Pending")</a>
                                    <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.SelectedBusinessId" asp-route-queue="@Darwin.Application.Billing.DTOs.PaymentQueueFilter.Unlinked" class="btn btn-sm btn-outline-warning">@T.T("Unlinked")</a>
                                    <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.SelectedBusinessId" asp-route-queue="@Darwin.Application.Billing.DTOs.PaymentQueueFilter.Refunded" class="btn btn-sm btn-outline-warning">@T.T("Refunded")</a>
                                    <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="MissingVatId" class="btn btn-sm btn-outline-warning">@T.T("FixVatId")</a>
                                    </div>
                                </details>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small d-inline-flex align-items-center">
                                    @T.T("DashboardPaymentsLabel")
                                    <field-help title="@T.T("DashboardPaymentsLabel")" content="@T.T("DashboardBusinessPaymentsHelp")" placement="bottom" />
                                </div>
                                <div class="fs-4 fw-semibold">@Model.PaymentCount</div>
                                <div class="d-flex gap-2 flex-wrap mt-3">
                                    <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-primary">@T.T("DashboardOpenPaymentsAction")</a>
                                    <a asp-controller="Businesses" asp-action="SupportQueue" class="btn btn-sm btn-outline-secondary">@T.T("SupportQueue")</a>
                                    <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="Overdue" class="btn btn-sm btn-outline-warning">@T.T("Overdue")</a>
                                    <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.SelectedBusinessId" asp-route-queue="@Darwin.Application.Billing.DTOs.PaymentQueueFilter.Pending" class="btn btn-sm btn-outline-warning">@T.T("Pending")</a>
                                    <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.SelectedBusinessId" asp-route-queue="@Darwin.Application.Billing.DTOs.PaymentQueueFilter.Unlinked" class="btn btn-sm btn-outline-warning">@T.T("Unlinked")</a>
                                    <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.SelectedBusinessId" asp-route-queue="@Darwin.Application.Billing.DTOs.PaymentQueueFilter.Refunded" class="btn btn-sm btn-outline-warning">@T.T("Refunded")</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small d-inline-flex align-items-center">
                                    @T.T("DashboardPurchaseOrdersLabel")
                                    <field-help title="@T.T("DashboardPurchaseOrdersLabel")" content="@T.T("DashboardPurchaseOrdersHelp")" placement="bottom" />
                                </div>
                                <div class="fs-4 fw-semibold">@Model.PurchaseOrderCount</div>
                                <div class="d-flex gap-2 flex-wrap mt-3">
                                    <a asp-controller="Inventory" asp-action="PurchaseOrders" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-primary">@T.T("DashboardOpenPurchaseOrdersAction")</a>
                                    <a asp-controller="Inventory" asp-action="Warehouses" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-secondary">@T.T("DashboardOpenInventoryAction")</a>
                                    <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="Draft" class="btn btn-sm btn-outline-secondary">@T.T("Draft")</a>
                                    <a asp-controller="Crm" asp-action="Invoices" asp-route-filter="DueSoon" class="btn btn-sm btn-outline-warning">@T.T("DueSoon")</a>
                                </div>
                            </div>
                        </div>
                    </div>

                }
                else
                {
                    <div class="alert alert-secondary mb-0">
                        @T.T("DashboardBusinessOperationsEmptyState")
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-6">
        <div class="card h-100 shadow-sm">
            <div class="card-header bg-white">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <div class="fw-semibold d-inline-flex align-items-center">
                            @T.T("LoyaltyOperations")
                            <field-help title="@T.T("LoyaltyOperations")" content="@T.T("LoyaltyOperationsIntro")" placement="bottom" />
                        </div>
                    </div>
                    <a asp-controller="Loyalty" asp-action="Accounts" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-secondary">@T.T("OpenLoyalty")</a>
                </div>
            </div>
            <div class="card-body">
                @if (Model.SelectedBusinessId.HasValue)
                {
                    <div class="row g-3">
                        <div class="col-sm-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">@T.T("Accounts")</div>
                                <div class="fs-4 fw-semibold">@Model.LoyaltyAccountCount</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">@T.T("PendingRedemptions")</div>
                                <div class="fs-4 fw-semibold">@Model.PendingRedemptionCount</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">@T.T("RecentScanSessions")</div>
                                <div class="fs-4 fw-semibold">@Model.ScanSessionCount</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-controller="Loyalty" asp-action="Accounts" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-primary">@T.T("Accounts")</a>
                        <a asp-controller="Loyalty" asp-action="Redemptions" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-primary">@T.T("Redemptions")</a>
                        <a asp-controller="Loyalty" asp-action="ScanSessions" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-primary">@T.T("ScanSessions")</a>
                        <a asp-controller="Loyalty" asp-action="Campaigns" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-sm btn-outline-primary">@T.T("Campaigns")</a>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary mb-0">
                        @T.T("SelectBusinessForLoyaltyMobile")
                    </div>
                }
            </div>
        </div>
    </div>

    @if (canManageBusinesses)
    {
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-white">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <div class="fw-semibold d-inline-flex align-items-center">
                                @T.T("MobileOperations")
                                <field-help title="@T.T("MobileOperations")" content="@T.T("MobileOperationsDashboardIntro")" placement="bottom" />
                            </div>
                        </div>
                        <a asp-controller="MobileOperations" asp-action="Index" class="btn btn-sm btn-outline-secondary">@T.T("OpenMobileOps")</a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">@T.T("ActiveDevices")</div>
                                <div class="fs-4 fw-semibold">@Model.MobileActiveDeviceCount</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">@T.T("MobileStaleDevices")</div>
                                <div class="fs-4 fw-semibold">@Model.MobileStaleDeviceCount</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="border rounded p-3 h-100">
                                <div class="text-muted small">@T.T("MobileMissingPushToken")</div>
                                <div class="fs-4 fw-semibold">@Model.MobileMissingPushTokenCount</div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-secondary mt-3 mb-0 d-flex align-items-center gap-1">
                        <span>@T.T("NeedsAttention"): <strong>@mobileAttentionCount</strong></span>
                        <field-help title="@T.T("NeedsAttention")" content="@T.T("DashboardMobileNeedsAttentionHelp")" placement="bottom" />
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-controller="MobileOperations" asp-action="Index" asp-route-state="stale" class="btn btn-sm btn-outline-primary">@T.T("MobileStaleDevices")</a>
                        <a asp-controller="MobileOperations" asp-action="Index" asp-route-state="missing-push" class="btn btn-sm btn-outline-primary">@T.T("MobileMissingPushToken")</a>
                        <a asp-controller="MobileOperations" asp-action="Index" class="btn btn-sm btn-outline-primary">@T.T("DeviceDiagnostics")</a>
                        @if (canManageIdentity)
                        {
                            <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked" class="btn btn-sm btn-outline-primary">@T.T("DashboardOpenMobileLinkedUsersAction")</a>
                        }
                        <a asp-controller="Businesses" asp-action="SupportQueue" class="btn btn-sm btn-outline-primary">@T.T("SupportQueue")</a>
                        <a asp-controller="BusinessCommunications" asp-action="Index" class="btn btn-sm btn-outline-primary">@T.T("Communications")</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header bg-white">
        <div class="fw-semibold d-inline-flex align-items-center">
            @T.T("DashboardQuickLinksTitle")
            <field-help title="@T.T("DashboardQuickLinksTitle")" content="@T.T("DashboardQuickLinksIntro")" placement="bottom" />
        </div>
    </div>
    <div class="card-body">
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkProductsAction")</a>
            <a asp-controller="Pages" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkPagesAction")</a>
            <a asp-controller="Media" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkMediaAction")</a>
            <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkOrdersAction")</a>
            <a asp-controller="Crm" asp-action="Customers" class="btn btn-outline-primary">@T.T("DashboardQuickLinkCustomersAction")</a>
            <a asp-controller="Crm" asp-action="Leads" class="btn btn-outline-primary">@T.T("DashboardQuickLinkLeadsAction")</a>
            <a asp-controller="Loyalty" asp-action="Accounts" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-outline-primary">@T.T("DashboardQuickLinkLoyaltyAction")</a>
            @if (canManageBusinesses)
            {
                <a asp-controller="Businesses" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkBusinessesAction")</a>
                <a asp-controller="MobileOperations" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkMobileOpsAction")</a>
            }
            @if (Model.SelectedBusinessId.HasValue)
            {
                <a asp-controller="Inventory" asp-action="Warehouses" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-outline-primary">@T.T("DashboardQuickLinkWarehousesAction")</a>
                <a asp-controller="Billing" asp-action="Payments" asp-route-businessId="@Model.SelectedBusinessId" class="btn btn-outline-primary">@T.T("DashboardQuickLinkPaymentsAction")</a>
            }
            @if (canManageIdentity)
            {
                <a asp-controller="Users" asp-action="Index" class="btn btn-outline-primary">@T.T("DashboardQuickLinkUsersAction")</a>
                <a asp-controller="Users" asp-action="Index" asp-route-filter="@Darwin.Application.Identity.DTOs.UserQueueFilter.MobileLinked" class="btn btn-outline-primary">@T.T("DashboardQuickLinkMobileLinkedUsersAction")</a>
                <a asp-controller="SiteSettings" asp-action="Edit" class="btn btn-outline-primary">@T.T("DashboardQuickLinkSettingsAction")</a>
            }
        </div>
    </div>
</div>
