@model Darwin.WebAdmin.ViewModels.Admin.AdminDashboardVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var setupAttentionCount = (Model.CommunicationOps.EmailTransportConfigured ? 0 : 1)
        + (Model.CommunicationOps.AdminAlertRoutingConfigured ? 0 : 1)
        + Model.CommunicationOps.BusinessesRequiringEmailSetupCount
        + Model.CommunicationOps.MissingSupportEmailCount
        + Model.CommunicationOps.MissingSenderIdentityCount;
    var failedFlowCount = Model.CommunicationOps.FailedInvitationCount
        + Model.CommunicationOps.FailedActivationCount
        + Model.CommunicationOps.FailedPasswordResetCount
        + Model.CommunicationOps.FailedAdminTestCount;
    var totalAttentionCount = setupAttentionCount + failedFlowCount;
    string CommunicationOpsFragmentUrl(Guid? businessId) => Url.Action("CommunicationOpsFragment", "Home", new { businessId }) ?? string.Empty;
}

<div id="communication-ops-card" class="card h-100 shadow-sm">
    <div class="card-header bg-white">
        <div class="d-flex align-items-center justify-content-between gap-2">
            <div class="fw-semibold d-inline-flex align-items-center">
                @T.T("CommunicationOpsTitle")
                <field-help title="@T.T("CommunicationOpsTitle")" content="@T.T("CommunicationOpsDashboardIntro")" placement="bottom" />
            </div>
            <button type="button"
                    class="btn btn-sm btn-outline-secondary"
                    hx-get="@CommunicationOpsFragmentUrl(Model.SelectedBusinessId)"
                    hx-target="#communication-ops-card"
                    hx-swap="outerHTML">
                @T.T("Refresh")
            </button>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-4">
                <div class="text-muted small">@T.T("NeedsSetup")</div>
                <div class="fs-4 fw-semibold">@setupAttentionCount</div>
            </div>
            <div class="col-4">
                <div class="text-muted small">@T.T("FailedEmails")</div>
                <div class="fs-4 fw-semibold">@failedFlowCount</div>
            </div>
            <div class="col-4">
                <div class="text-muted small">@T.T("NeedsAttention")</div>
                <div class="fs-4 fw-semibold">@totalAttentionCount</div>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
            <a asp-controller="BusinessCommunications" asp-action="Index" class="btn btn-sm btn-outline-primary">@T.T("OpenWorkspaceAction")</a>
            <a asp-controller="SiteSettings" asp-action="Edit" asp-fragment="site-settings-communications-policy" class="btn btn-sm btn-outline-secondary">@T.T("CommunicationPolicy")</a>
        </div>
    </div>
</div>
