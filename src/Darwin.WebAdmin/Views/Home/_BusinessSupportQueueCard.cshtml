@model Darwin.WebAdmin.ViewModels.Admin.AdminDashboardVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var invitationAttentionCount = Model.BusinessSupport.PendingInvitationCount + Model.BusinessSupport.OpenInvitationCount;
    var memberAttentionCount = Model.BusinessSupport.PendingActivationMemberCount + Model.BusinessSupport.LockedMemberCount;
    var businessAttentionCount = Model.BusinessSupport.AttentionBusinessCount
        + Model.BusinessSupport.PendingApprovalBusinessCount
        + Model.BusinessSupport.SuspendedBusinessCount
        + Model.BusinessSupport.MissingOwnerBusinessCount;
    var totalAttentionCount = businessAttentionCount + invitationAttentionCount + memberAttentionCount;
    string BusinessSupportQueueFragmentUrl(Guid? businessId) => Url.Action("BusinessSupportQueueFragment", "Home", new { businessId }) ?? string.Empty;
}

<div id="business-support-queue-card" class="card h-100 shadow-sm">
    <div class="card-header bg-white">
        <div class="d-flex align-items-center justify-content-between gap-2">
            <div class="fw-semibold d-inline-flex align-items-center">
                @T.T("BusinessSupportQueueTitle")
                <field-help title="@T.T("BusinessSupportQueueTitle")" content="@T.T("BusinessSupportQueueIntro")" placement="bottom" />
            </div>
            <button type="button"
                    class="btn btn-sm btn-outline-secondary"
                    hx-get="@BusinessSupportQueueFragmentUrl(Model.SelectedBusinessId)"
                    hx-target="#business-support-queue-card"
                    hx-swap="outerHTML">
                @T.T("Refresh")
            </button>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-4">
                <div class="text-muted small">@T.T("BusinessesTitle")</div>
                <div class="fs-4 fw-semibold">@businessAttentionCount</div>
            </div>
            <div class="col-4">
                <div class="text-muted small">@T.T("Invitations")</div>
                <div class="fs-4 fw-semibold">@invitationAttentionCount</div>
            </div>
            <div class="col-4">
                <div class="text-muted small">@T.T("Members")</div>
                <div class="fs-4 fw-semibold">@memberAttentionCount</div>
            </div>
        </div>
        <div class="small text-muted mt-3">@T.T("NeedsAttention"): <strong>@totalAttentionCount</strong></div>
        <div class="d-flex flex-wrap gap-2 mt-3">
            <a asp-controller="Businesses" asp-action="SupportQueue" class="btn btn-sm btn-outline-primary">@T.T("BusinessSupportOpenQueueAction")</a>
            <a asp-controller="Businesses" asp-action="MerchantReadiness" class="btn btn-sm btn-outline-secondary">@T.T("MerchantReadinessTitle")</a>
        </div>
    </div>
</div>
