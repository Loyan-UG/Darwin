@using System.Globalization
@using Darwin.Application.CRM.DTOs
@using Darwin.Domain.Enums
@model Darwin.WebAdmin.ViewModels.Billing.TaxComplianceListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("TaxComplianceTitle");
    string GlobalPaymentsUrl() => Url.Action("Payments", "Billing") ?? string.Empty;
    string GlobalRefundsUrl() => Url.Action("Refunds", "Billing") ?? string.Empty;
    string GlobalInvoicesUrl() => Url.Action("Invoices", "Crm") ?? string.Empty;
    string TaxSettingsUrl() => Url.Action("Edit", "SiteSettings", new { fragment = "site-settings-tax" }) ?? string.Empty;
    string TaxComplianceExportUrl() => Url.Action("ExportTaxComplianceInvoices", "Billing") ?? string.Empty;
    string CrmCustomersUrl(CustomerQueueFilter filter) => Url.Action("Customers", "Crm", new { filter }) ?? string.Empty;
    string CrmInvoicesUrl(string filter) => Url.Action("Invoices", "Crm", new { filter }) ?? string.Empty;
    string CrmInvoicesByQueryUrl(string q) => Url.Action("Invoices", "Crm", new { q }) ?? string.Empty;
    string CrmEditInvoiceUrl(Guid? id) => Url.Action("EditInvoice", "Crm", new { id }) ?? string.Empty;
    string CrmEditCustomerUrl(Guid? id) => Url.Action("EditCustomer", "Crm", new { id }) ?? string.Empty;
    string CrmOpportunitiesUrl(string q) => Url.Action("Opportunities", "Crm", new { q }) ?? string.Empty;
    string OrdersUrl(string filter) => Url.Action("Index", "Orders", new { filter }) ?? string.Empty;
    string OrderDetailsUrl(Guid? id) => Url.Action("Details", "Orders", new { id }) ?? string.Empty;
    string EditPaymentUrl(Guid? id) => Url.Action("EditPayment", "Billing", new { id }) ?? string.Empty;
    string LocalizeTaxInvoiceStatus(object? status) => status is null ? "-" : T.T(status.ToString() ?? string.Empty);
    string TaxComplianceOpsHealthBadgeClass(bool healthy) => healthy ? "text-bg-success" : "text-bg-warning";
    string TaxComplianceOpsHealthBadgeText(bool healthy) => healthy ? T.T("Ready") : T.T("NeedsAttention");
    string LocalizeVatValidationStatus(CustomerVatValidationStatus status) => T.T($"CustomerVatValidationStatus{status}");
    var taxComplianceAttentionCount = Model.Summary.BusinessCustomersMissingVatIdCount
        + Model.Summary.BusinessCustomersVatValidationReviewCount
        + Model.Summary.BusinessInvoicesMissingVatIdCount
        + Model.Summary.ReverseChargeCandidateInvoiceCount
        + Model.Summary.OverdueInvoiceCount
        + (!Model.Tax.ArchiveReadinessComplete ? 1 : 0)
        + (!Model.Tax.EInvoiceBaselineReady ? 1 : 0);
    var taxCollectionAttentionCount = Model.Summary.OverdueInvoiceCount + Model.Summary.DueSoonInvoiceCount;
    var taxInvoicePreparationCount = Model.Summary.DraftInvoiceCount + Model.Summary.BusinessInvoicesMissingVatIdCount + Model.Summary.ReverseChargeCandidateInvoiceCount;
}

<div id="billing-tax-compliance-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<h1 class="mb-3">@T.T("TaxComplianceTitle")</h1>

<div class="alert alert-secondary mb-3">
    @T.T("TaxComplianceIntro")
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <span class="badge @TaxComplianceOpsHealthBadgeClass(taxComplianceAttentionCount == 0)">@TaxComplianceOpsHealthBadgeText(taxComplianceAttentionCount == 0)</span>
                    <span class="badge @TaxComplianceOpsHealthBadgeClass(Model.Tax.ArchiveReadinessComplete && Model.Tax.EInvoiceBaselineReady)">@TaxComplianceOpsHealthBadgeText(Model.Tax.ArchiveReadinessComplete && Model.Tax.EInvoiceBaselineReady)</span>
                </div>
                <h2 class="h5 mb-1">@T.T("TaxComplianceTitle")</h2>
                <p class="text-muted mb-0">@T.T("TaxComplianceIntro")</p>
            </div>
            <div class="text-md-end">
                <div class="small text-muted">@T.T("NeedsAttention")</div>
                <div class="fs-4 fw-semibold">@taxComplianceAttentionCount</div>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("BusinessCustomersMissingVatId")</span>
                        <span class="badge @TaxComplianceOpsHealthBadgeClass(Model.Summary.BusinessCustomersMissingVatIdCount == 0)">@Model.Summary.BusinessCustomersMissingVatIdCount</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("FixVatId")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="CRM"
                           asp-action="Customers"
                           asp-route-filter="@CustomerQueueFilter.MissingVatId"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@CrmCustomersUrl(CustomerQueueFilter.MissingVatId)"
                           hx-target="#billing-tax-compliance-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-controller="CRM"
                           asp-action="Invoices"
                           asp-route-filter="MissingVatId"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@CrmInvoicesUrl("MissingVatId")"
                           hx-target="#billing-tax-compliance-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("ReviewInvoices")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("BusinessInvoicesMissingVatId")</span>
                        <span class="badge @TaxComplianceOpsHealthBadgeClass(Model.Summary.BusinessInvoicesMissingVatIdCount == 0)">@Model.Summary.BusinessInvoicesMissingVatIdCount</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("ReviewInvoices")</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="CRM"
                           asp-action="Invoices"
                           asp-route-filter="MissingVatId"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@CrmInvoicesUrl("MissingVatId")"
                           hx-target="#billing-tax-compliance-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-controller="Orders"
                           asp-action="Index"
                           asp-route-filter="PaymentIssues"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@OrdersUrl("PaymentIssues")"
                           hx-target="#billing-tax-compliance-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OrdersTitle")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("OverdueInvoices")</span>
                        <span class="badge @TaxComplianceOpsHealthBadgeClass(taxCollectionAttentionCount == 0)">@taxCollectionAttentionCount</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("Payments")</p>
                    <div class="small text-muted mb-2">@T.T("DueSoon"): <strong>@Model.Summary.DueSoonInvoiceCount</strong></div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="CRM"
                           asp-action="Invoices"
                           asp-route-filter="Overdue"
                           class="btn btn-sm btn-outline-danger"
                           hx-get="@CrmInvoicesUrl("Overdue")"
                           hx-target="#billing-tax-compliance-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Open")</a>
                        <a asp-controller="CRM"
                           asp-action="Invoices"
                           asp-route-filter="DueSoon"
                           class="btn btn-sm btn-outline-warning"
                           hx-get="@CrmInvoicesUrl("DueSoon")"
                           hx-target="#billing-tax-compliance-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("DueSoon")</a>
                        <a asp-action="Payments"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@GlobalPaymentsUrl()"
                           hx-target="#billing-tax-compliance-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Payments")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="text-muted small">@T.T("ArchiveReadiness")</span>
                        <span class="badge @TaxComplianceOpsHealthBadgeClass(Model.Tax.ArchiveReadinessComplete && Model.Tax.EInvoiceBaselineReady && taxInvoicePreparationCount == 0)">@((!Model.Tax.ArchiveReadinessComplete || !Model.Tax.EInvoiceBaselineReady) ? 1 : taxInvoicePreparationCount)</span>
                    </div>
                    <p class="small text-muted mb-3">@T.T("OpenTaxSettings")</p>
                    <div class="small text-muted mb-2">@T.T("DraftInvoices"): <strong>@Model.Summary.DraftInvoiceCount</strong></div>
                    <div class="small text-muted mb-2">@T.T("StructuredExportReadiness"): <strong>@(Model.Tax.StructuredExportBaselineReady ? T.T("Ready") : T.T("NotReady"))</strong></div>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="SiteSettings"
                           asp-action="Edit"
                           asp-fragment="site-settings-tax"
                           class="btn btn-sm btn-outline-secondary"
                          hx-get="@TaxSettingsUrl()"
                           hx-target="#billing-tax-compliance-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("OpenTaxSettings")</a>
                        <a asp-controller="CRM"
                           asp-action="Invoices"
                           asp-route-filter="Draft"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@CrmInvoicesUrl("Draft")"
                           hx-target="#billing-tax-compliance-workspace-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Draft")</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("TaxInvoicingReadiness")</span>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="Payments"
               class="btn btn-sm btn-outline-secondary"
               hx-get="@GlobalPaymentsUrl()"
               hx-target="#billing-tax-compliance-workspace-shell"
               hx-swap="outerHTML"
               hx-push-url="true">@T.T("Payments")</a>
                <a asp-controller="SiteSettings"
                   asp-action="Edit"
                   asp-fragment="site-settings-tax"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@TaxSettingsUrl()"
                   hx-target="#billing-tax-compliance-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("OpenTaxSettings")</a>
            <a class="btn btn-sm btn-outline-primary"
               href="@TaxComplianceExportUrl()">@T.T("ExportTaxComplianceCsv")</a>
        </div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("VatEnabled")</div><div class="fw-semibold mt-1">@(Model.Tax.VatEnabled ? T.T("Yes") : T.T("No"))</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("DefaultVat")</div><div class="fw-semibold mt-1">@Model.Tax.DefaultVatRatePercent.ToString("0.##")%</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("PriceMode")</div><div class="fw-semibold mt-1">@(Model.Tax.PricesIncludeVat ? T.T("VatInclusive") : T.T("VatExclusive"))</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("ReverseCharge")</div><div class="fw-semibold mt-1">@(Model.Tax.AllowReverseCharge ? T.T("Allowed") : T.T("Disabled"))</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Issuer")</div><div class="fw-semibold mt-1">@(Model.Tax.IssuerConfigured ? Model.Tax.InvoiceIssuerLegalName : T.T("Missing"))</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("TaxId")</div><div class="fw-semibold mt-1">@(Model.Tax.InvoiceIssuerTaxIdConfigured ? T.T("Ready") : T.T("Missing"))</div></div></div>
            <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("SiteSettingInvoiceIssuerCountry")</div><div class="fw-semibold mt-1">@(string.IsNullOrWhiteSpace(Model.Tax.InvoiceIssuerCountry) ? T.T("Missing") : Model.Tax.InvoiceIssuerCountry)</div></div></div>
            <div class="col-md-4"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("ArchiveReadiness")</div><div class="fw-semibold mt-1">@(Model.Tax.ArchiveReadinessComplete ? T.T("Ready") : T.T("NeedsIssuerData"))</div><div class="small text-muted mt-2">@Model.Tax.ArchiveReadinessLabel</div></div></div>
            <div class="col-md-4"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("EInvoiceBaseline")</div><div class="fw-semibold mt-1">@(Model.Tax.EInvoiceBaselineReady ? T.T("Ready") : T.T("NotReady"))</div><div class="small text-muted mt-2">@Model.Tax.EInvoiceBaselineLabel</div></div></div>
            <div class="col-md-4"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("StructuredExportReadiness")</div><div class="fw-semibold mt-1">@(Model.Tax.StructuredExportBaselineReady ? T.T("Ready") : T.T("NotReady"))</div><div class="small text-muted mt-2">@Model.Tax.StructuredExportBaselineLabel</div><div class="small text-muted mt-1">@Model.Tax.ComplianceScopeNote</div></div></div>
        </div>
        <div class="d-flex gap-2 flex-wrap mt-3">
            @if (!Model.Tax.ArchiveReadinessComplete)
            {
                <a asp-controller="SiteSettings"
                   asp-action="Edit"
                   asp-fragment="site-settings-tax"
                   class="btn btn-sm btn-outline-warning"
                   hx-get="@TaxSettingsUrl()"
                   hx-target="#billing-tax-compliance-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("CompleteIssuerData")</a>
            }
            @if (!Model.Tax.EInvoiceBaselineReady)
            {
                <a asp-controller="SiteSettings"
                   asp-action="Edit"
                   asp-fragment="site-settings-tax"
                   class="btn btn-sm btn-outline-danger"
                   hx-get="@TaxSettingsUrl()"
                   hx-target="#billing-tax-compliance-workspace-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("ReviewEInvoiceBaseline")</a>
            }
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("BusinessCustomersMissingVatId")</div><div class="fs-4 fw-semibold">@Model.Summary.BusinessCustomersMissingVatIdCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("BusinessVatValidationReview")</div><div class="fs-4 fw-semibold">@Model.Summary.BusinessCustomersVatValidationReviewCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("BusinessInvoicesMissingVatId")</div><div class="fs-4 fw-semibold">@Model.Summary.BusinessInvoicesMissingVatIdCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("ReverseChargeReview")</div><div class="fs-4 fw-semibold">@Model.Summary.ReverseChargeCandidateInvoiceCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("DraftInvoices")</div><div class="fs-4 fw-semibold">@Model.Summary.DraftInvoiceCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("DueSoonInvoices")</div><div class="fs-4 fw-semibold">@Model.Summary.DueSoonInvoiceCount</div></div></div>
    <div class="col-md-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("OverdueInvoices")</div><div class="fs-4 fw-semibold">@Model.Summary.OverdueInvoiceCount</div></div></div>
</div>

<details class="card mb-3">
    <summary class="card-header">@T.T("TaxCompliancePlaybooksTitle")</summary>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>@T.T("Playbook")</th>
                        <th>@T.T("TaxComplianceScopeColumn")</th>
                        <th>@T.T("OperatorAction")</th>
                        <th>@T.T("SettingsDependency")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var playbook in Model.Playbooks)
                {
                    <tr>
                        <td class="fw-semibold">@playbook.Title</td>
                        <td>@playbook.ScopeNote</td>
                        <td>@playbook.OperatorAction</td>
                        <td>@playbook.SettingsDependency</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</details>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("TaxComplianceInvoiceReviewTitle")</span>
        <a asp-controller="CRM"
           asp-action="Invoices"
           class="btn btn-sm btn-outline-secondary"
           hx-get="@GlobalInvoicesUrl()"
           hx-target="#billing-tax-compliance-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("ReviewInvoices")</a>
    </div>
    <div class="card-body">
        @if (Model.InvoiceItems.Count == 0)
        {
            <div class="text-muted">@T.T("TaxComplianceNoInvoiceFollowUp")</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@T.T("TaxComplianceCustomerColumn")</th>
                            <th>@T.T("TaxComplianceOrderColumn")</th>
                            <th>@T.T("CommonStatus")</th>
                            <th>@T.T("TaxComplianceTotalColumn")</th>
                            <th>@T.T("TaxComplianceDueDateColumn")</th>
                            <th>@T.T("CommonActions")</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.InvoiceItems)
                    {
                        var taxInvoiceNeedsVatRemediation = item.RequiresVatId;
                        var taxInvoiceNeedsReverseChargeReview = item.IsReverseChargeCandidate;
                        var taxInvoiceNeedsCollectionFollowUp = item.IsOverdue || item.IsDueSoon;
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.CustomerDisplayName</div>
                                @if (!string.IsNullOrWhiteSpace(item.CompanyName))
                                {
                                    <div class="small text-muted">@item.CompanyName</div>
                                }
                                @if (item.RequiresVatId)
                                {
                                    <div class="small text-danger">@T.T("VatIdMissing")</div>
                                }
                                @if (item.IsReverseChargeCandidate)
                                {
                                    <div class="small text-warning">@T.T("ReverseChargeReview")</div>
                                }
                                @if (item.ReverseChargeApplied.HasValue)
                                {
                                    <div class="small text-muted">
                                        @(item.ReverseChargeApplied.Value ? T.T("ReverseChargeAppliedStatus") : T.T("ReverseChargeNotApplicableStatus"))
                                        @if (item.ReverseChargeReviewedAtUtc.HasValue)
                                        {
                                            <span>@string.Format(T.T("CreatedUtcValue"), item.ReverseChargeReviewedAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</span>
                                        }
                                    </div>
                                }
                            </td>
                            <td>@(item.OrderNumber ?? "-")</td>
                            <td>
                                <div>@LocalizeTaxInvoiceStatus(item.Status)</div>
                                @if (item.IsOverdue)
                                {
                                    <span class="badge text-bg-danger">@T.T("OverdueInvoices")</span>
                                }
                                else if (item.IsDueSoon)
                                {
                                    <span class="badge text-bg-warning">@T.T("DueSoonInvoices")</span>
                                }
                            </td>
                            <td>@item.Currency @((item.TotalGrossMinor / 100.0m).ToString("0.00"))</td>
                            <td>@string.Format(T.T("CreatedUtcValue"), item.DueDateUtc.ToLocalTime().ToString(CultureInfo.CurrentCulture))</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <a asp-controller="CRM"
                                       asp-action="EditInvoice"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-secondary"
                                      hx-get="@CrmEditInvoiceUrl(item.Id)"
                                       hx-target="#billing-tax-compliance-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("TaxComplianceOpenInvoiceAction")</a>
                                    @if (item.CustomerId.HasValue)
                                    {
                                        <a asp-controller="CRM"
                                           asp-action="EditCustomer"
                                           asp-route-id="@item.CustomerId"
                                           class="btn btn-sm btn-outline-secondary"
                                          hx-get="@CrmEditCustomerUrl(item.CustomerId)"
                                           hx-target="#billing-tax-compliance-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("TaxComplianceOpenCustomerAction")</a>
                                    }
                                    @if (item.OrderId.HasValue)
                                    {
                                        <a asp-controller="Orders"
                                           asp-action="Details"
                                           asp-route-id="@item.OrderId"
                                           class="btn btn-sm btn-outline-secondary"
                                          hx-get="@OrderDetailsUrl(item.OrderId)"
                                           hx-target="#billing-tax-compliance-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("TaxComplianceOpenOrderAction")</a>
                                    }
                                    @if (item.PaymentId.HasValue)
                                    {
                                        <a asp-action="EditPayment"
                                           asp-route-id="@item.PaymentId"
                                           class="btn btn-sm btn-outline-secondary"
                                          hx-get="@EditPaymentUrl(item.PaymentId)"
                                           hx-target="#billing-tax-compliance-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("Payments")</a>
                                    }
                                    @if (taxInvoiceNeedsCollectionFollowUp)
                                    {
                                        <a asp-action="Payments"
                                           class="btn btn-sm btn-outline-warning"
                                           hx-get="@GlobalPaymentsUrl()"
                                           hx-target="#billing-tax-compliance-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("Payments")</a>
                                        <a asp-action="Refunds"
                                           class="btn btn-sm btn-outline-danger"
                                           hx-get="@GlobalRefundsUrl()"
                                           hx-target="#billing-tax-compliance-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("RefundQueueTitle")</a>
                                    }
                                    @if (taxInvoiceNeedsVatRemediation)
                                    {
                                        <a asp-controller="CRM"
                                           asp-action="Customers"
                                           asp-route-filter="@CustomerQueueFilter.MissingVatId"
                                           class="btn btn-sm btn-outline-warning"
                                          hx-get="@CrmCustomersUrl(CustomerQueueFilter.MissingVatId)"
                                           hx-target="#billing-tax-compliance-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("FixVatId")</a>
                                    }
                                    @if (taxInvoiceNeedsReverseChargeReview)
                                    {
                                        <form asp-action="UpdateInvoiceReverseChargeDecision"
                                              method="post"
                                              class="d-inline"
                                              hx-post="@Url.Action("UpdateInvoiceReverseChargeDecision", "Billing")"
                                              hx-target="#billing-tax-compliance-workspace-shell"
                                              hx-swap="outerHTML">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@item.Id" />
                                            <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                            <input type="hidden" name="Applies" value="true" />
                                            <button type="submit" class="btn btn-sm btn-warning">@T.T("ReverseChargeApplies")</button>
                                        </form>
                                        <form asp-action="UpdateInvoiceReverseChargeDecision"
                                              method="post"
                                              class="d-inline"
                                              hx-post="@Url.Action("UpdateInvoiceReverseChargeDecision", "Billing")"
                                              hx-target="#billing-tax-compliance-workspace-shell"
                                              hx-swap="outerHTML">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@item.Id" />
                                            <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                            <input type="hidden" name="Applies" value="false" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning">@T.T("ReverseChargeNotApplicable")</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>@T.T("TaxComplianceCustomerReviewTitle")</span>
        <a asp-controller="CRM"
           asp-action="Customers"
           asp-route-filter="@CustomerQueueFilter.MissingVatId"
           class="btn btn-sm btn-outline-secondary"
          hx-get="@CrmCustomersUrl(CustomerQueueFilter.MissingVatId)"
           hx-target="#billing-tax-compliance-workspace-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("FixVatId")</a>
    </div>
    <div class="card-body">
        @if (Model.CustomerItems.Count == 0)
        {
            <div class="text-muted">@T.T("TaxComplianceNoCustomerFollowUp")</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@T.T("TaxComplianceCustomerColumn")</th>
                            <th>@T.T("TaxComplianceEmailColumn")</th>
                            <th>@T.T("TaxComplianceOpportunitiesColumn")</th>
                            <th>@T.T("TaxComplianceUpdatedColumn")</th>
                            <th>@T.T("CommonActions")</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.CustomerItems)
                    {
                        var taxCustomerHasOpportunityDebt = item.OpportunityCount > 0;
                        <tr>
                            <td>
                                <div class="fw-semibold">@item.DisplayName</div>
                                @if (!string.IsNullOrWhiteSpace(item.CompanyName))
                                {
                                    <div class="small text-muted">@item.CompanyName</div>
                                }
                                @if (item.RequiresVatId)
                                {
                                    <div class="small text-danger">@T.T("VatIdMissing")</div>
                                }
                                else if (item.RequiresVatValidation)
                                {
                                    <div class="small text-warning">@T.T("BusinessVatValidationReview")</div>
                                    <div class="small text-muted">@LocalizeVatValidationStatus(item.VatValidationStatus)</div>
                                    @if (!string.IsNullOrWhiteSpace(item.VatValidationMessage))
                                    {
                                        <div class="small text-muted">@item.VatValidationMessage</div>
                                    }
                                }
                            </td>
                            <td>@item.Email</td>
                            <td>@item.OpportunityCount</td>
                            <td>@string.Format(T.T("CreatedUtcValue"), (item.ModifiedAtUtc ?? item.CreatedAtUtc).ToLocalTime().ToString(CultureInfo.CurrentCulture))</td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap mb-2">
                                    <a asp-controller="CRM"
                                       asp-action="EditCustomer"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-secondary"
                                      hx-get="@CrmEditCustomerUrl(item.Id)"
                                       hx-target="#billing-tax-compliance-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("TaxComplianceOpenCustomerAction")</a>
                                    <a asp-controller="CRM"
                                       asp-action="Invoices"
                                       asp-route-q="@item.Email"
                                       class="btn btn-sm btn-outline-secondary"
                                      hx-get="@CrmInvoicesByQueryUrl(item.Email)"
                                       hx-target="#billing-tax-compliance-workspace-shell"
                                       hx-swap="outerHTML"
                                       hx-push-url="true">@T.T("ReviewInvoices")</a>
                                    @if (taxCustomerHasOpportunityDebt)
                                    {
                                        <a asp-controller="CRM"
                                           asp-action="Opportunities"
                                           asp-route-q="@item.Email"
                                           class="btn btn-sm btn-outline-secondary"
                                          hx-get="@CrmOpportunitiesUrl(item.Email)"
                                           hx-target="#billing-tax-compliance-workspace-shell"
                                           hx-swap="outerHTML"
                                           hx-push-url="true">@T.T("Opportunities")</a>
                                    }
                                </div>
                                @if (item.RequiresVatId)
                                {
                                    <form asp-action="UpdateCustomerTaxProfile"
                                          method="post"
                                          class="d-flex flex-wrap align-items-end gap-2"
                                          hx-post="@Url.Action("UpdateCustomerTaxProfile", "Billing")"
                                          hx-target="#billing-tax-compliance-workspace-shell"
                                          hx-swap="outerHTML">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Id" value="@item.Id" />
                                        <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                        <input type="hidden" name="TaxProfileType" value="@CustomerTaxProfileType.Business" />
                                        <div>
                                            <label class="form-label small mb-1" for="tax-company-@item.Id">@T.T("CompanyName")</label>
                                            <input id="tax-company-@item.Id"
                                                   name="CompanyName"
                                                   value="@item.CompanyName"
                                                   class="form-control form-control-sm"
                                                   maxlength="200"
                                                   required />
                                        </div>
                                        <div>
                                            <label class="form-label small mb-1" for="tax-vat-@item.Id">@T.T("CustomerVatId")</label>
                                            <input id="tax-vat-@item.Id"
                                                   name="VatId"
                                                   value="@item.VatId"
                                                   class="form-control form-control-sm"
                                                   maxlength="64"
                                                   required />
                                        </div>
                                        <button type="submit" class="btn btn-sm btn-warning">@T.T("SaveVatId")</button>
                                    </form>
                                }
                                else if (item.RequiresVatValidation)
                                {
                                    <div class="d-flex flex-wrap gap-2">
                                        <form asp-action="ValidateCustomerVatId"
                                              method="post"
                                              class="d-inline"
                                              hx-post="@Url.Action("ValidateCustomerVatId", "Billing")"
                                              hx-target="#billing-tax-compliance-workspace-shell"
                                              hx-swap="outerHTML">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@item.Id" />
                                            <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                            <button type="submit" class="btn btn-sm btn-primary">@T.T("VatValidationLookup")</button>
                                        </form>
                                        <form asp-action="UpdateCustomerVatValidationDecision"
                                              method="post"
                                              class="d-inline"
                                              hx-post="@Url.Action("UpdateCustomerVatValidationDecision", "Billing")"
                                              hx-target="#billing-tax-compliance-workspace-shell"
                                              hx-swap="outerHTML">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@item.Id" />
                                            <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                            <input type="hidden" name="Status" value="@CustomerVatValidationStatus.Valid" />
                                            <input type="hidden" name="Source" value="operator" />
                                            <button type="submit" class="btn btn-sm btn-success">@T.T("VatValidationValid")</button>
                                        </form>
                                        <form asp-action="UpdateCustomerVatValidationDecision"
                                              method="post"
                                              class="d-inline"
                                              hx-post="@Url.Action("UpdateCustomerVatValidationDecision", "Billing")"
                                              hx-target="#billing-tax-compliance-workspace-shell"
                                              hx-swap="outerHTML">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@item.Id" />
                                            <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                            <input type="hidden" name="Status" value="@CustomerVatValidationStatus.Invalid" />
                                            <input type="hidden" name="Source" value="operator" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">@T.T("VatValidationInvalid")</button>
                                        </form>
                                        <form asp-action="UpdateCustomerVatValidationDecision"
                                              method="post"
                                              class="d-inline"
                                              hx-post="@Url.Action("UpdateCustomerVatValidationDecision", "Billing")"
                                              hx-target="#billing-tax-compliance-workspace-shell"
                                              hx-swap="outerHTML">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="Id" value="@item.Id" />
                                            <input type="hidden" name="RowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                            <input type="hidden" name="Status" value="@CustomerVatValidationStatus.NotApplicable" />
                                            <input type="hidden" name="Source" value="operator" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">@T.T("VatValidationNotApplicable")</button>
                                        </form>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
</div>

