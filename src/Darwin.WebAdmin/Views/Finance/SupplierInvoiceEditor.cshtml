@model Darwin.Application.Billing.DTOs.SupplierInvoiceEditDto
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = Model.Id == Guid.Empty;
    ViewData["Title"] = T.T(isCreate ? "CreateSupplierInvoice" : "EditSupplierInvoice");
    var rowVersion = Model.RowVersion.Length == 0 ? string.Empty : Convert.ToBase64String(Model.RowVersion);
}

<div id="finance-supplier-invoice-editor-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<h1 class="mb-4">@T.T(isCreate ? "CreateSupplierInvoice" : "EditSupplierInvoice")</h1>
<form method="post" asp-action="@(isCreate ? "CreateSupplierInvoice" : "EditSupplierInvoice")">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" name="RowVersion" value="@rowVersion" />
    <div class="row g-3 mb-3">
        <div class="col-md-3"><label class="form-label">@T.T("BusinessId")</label><input asp-for="BusinessId" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("SupplierId")</label><input asp-for="SupplierId" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("PurchaseOrderId")</label><input asp-for="PurchaseOrderId" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("GoodsReceiptId")</label><input asp-for="GoodsReceiptId" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("SupplierInvoiceNumber")</label><input asp-for="SupplierInvoiceNumber" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("InvoiceDate")</label><input asp-for="InvoiceDateUtc" type="date" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("DueDate")</label><input asp-for="DueDateUtc" type="date" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("Currency")</label><input asp-for="Currency" class="form-control" maxlength="3" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("PaymentTermDays")</label><input asp-for="PaymentTermDays" class="form-control" /></div>
        <div class="col-md-9"><label class="form-label">@T.T("InternalNotes")</label><input asp-for="InternalNotes" class="form-control" /></div>
    </div>

    <div class="table-responsive mb-3">
        <table class="table table-sm align-middle">
            <thead><tr><th>@T.T("Description")</th><th>@T.T("SupplierSku")</th><th>@T.T("Quantity")</th><th>@T.T("UnitNet")</th><th>@T.T("UnitTax")</th><th>@T.T("UnitGross")</th><th>@T.T("PurchaseOrderLineId")</th><th>@T.T("GoodsReceiptLineId")</th></tr></thead>
            <tbody>
            @for (var i = 0; i < Model.Lines.Count; i++)
            {
                <tr>
                    <td><input asp-for="Lines[i].Description" class="form-control form-control-sm" /></td>
                    <td><input asp-for="Lines[i].SupplierSku" class="form-control form-control-sm" /></td>
                    <td><input asp-for="Lines[i].InvoicedQuantity" class="form-control form-control-sm" /></td>
                    <td><input asp-for="Lines[i].UnitNetMinor" class="form-control form-control-sm" /></td>
                    <td><input asp-for="Lines[i].UnitTaxMinor" class="form-control form-control-sm" /></td>
                    <td><input asp-for="Lines[i].UnitGrossMinor" class="form-control form-control-sm" /></td>
                    <td><input asp-for="Lines[i].PurchaseOrderLineId" class="form-control form-control-sm" /></td>
                    <td><input asp-for="Lines[i].GoodsReceiptLineId" class="form-control form-control-sm" /></td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">@T.T("Save")</button>
        <a asp-action="SupplierInvoices" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Cancel")</a>
    </div>
</form>
</div>
