@model Darwin.Application.Billing.DTOs.SupplierAdvanceEditDto
@using Darwin.Domain.Enums
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = Model.Id == Guid.Empty;
    ViewData["Title"] = T.T(isCreate ? "CreateSupplierAdvance" : "EditSupplierAdvance");
    var rowVersion = Model.RowVersion.Length == 0 ? string.Empty : Convert.ToBase64String(Model.RowVersion);
}

<div id="finance-supplier-advance-editor-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<h1 class="mb-4">@T.T(isCreate ? "CreateSupplierAdvance" : "EditSupplierAdvance")</h1>
<form method="post" asp-action="@(isCreate ? "CreateSupplierAdvance" : "EditSupplierAdvance")">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" name="RowVersion" value="@rowVersion" />
    <input type="hidden" asp-for="MetadataJson" />
    <div class="row g-3 mb-3">
        <div class="col-md-3"><label class="form-label">@T.T("BusinessId")</label><input asp-for="BusinessId" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("SupplierId")</label><input asp-for="SupplierId" class="form-control" /></div>
        <div class="col-md-3">
            <label class="form-label">@T.T("PaymentMethod")</label>
            <select asp-for="PaymentMethod" class="form-select">
                @foreach (var method in Enum.GetValues<SupplierPaymentMethod>())
                {
                    <option value="@method">@T.T(method.ToString())</option>
                }
            </select>
        </div>
        <div class="col-md-3"><label class="form-label">@T.T("AdvanceDate")</label><input asp-for="AdvanceDateUtc" type="date" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("Currency")</label><input asp-for="Currency" class="form-control" maxlength="3" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("Amount")</label><input asp-for="TotalAmountMinor" class="form-control text-end" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("Reference")</label><input asp-for="Reference" class="form-control" maxlength="256" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("InternalNotes")</label><input asp-for="InternalNotes" class="form-control" maxlength="4000" /></div>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">@T.T("Save")</button>
        <a asp-action="SupplierAdvances" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Cancel")</a>
    </div>
</form>
</div>
