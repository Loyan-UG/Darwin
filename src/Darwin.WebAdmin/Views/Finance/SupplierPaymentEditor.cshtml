@model Darwin.Application.Billing.DTOs.SupplierPaymentEditDto
@using Darwin.Domain.Enums
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = Model.Id == Guid.Empty;
    ViewData["Title"] = T.T(isCreate ? "CreateSupplierPayment" : "EditSupplierPayment");
    var rowVersion = Model.RowVersion.Length == 0 ? string.Empty : Convert.ToBase64String(Model.RowVersion);
}

<div id="finance-supplier-payment-editor-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<h1 class="mb-4">@T.T(isCreate ? "CreateSupplierPayment" : "EditSupplierPayment")</h1>
<form method="post" asp-action="@(isCreate ? "CreateSupplierPayment" : "EditSupplierPayment")">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" name="RowVersion" value="@rowVersion" />
    <div class="row g-3 mb-3">
        <div class="col-md-3"><label class="form-label">@T.T("BusinessId")</label><input asp-for="BusinessId" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("SupplierId")</label><input asp-for="SupplierId" class="form-control" /></div>
        <div class="col-md-3">
            <label class="form-label">@T.T("PaymentMethod")</label>
            <select asp-for="PaymentMethod" class="form-select">
                @foreach (var method in Enum.GetValues<SupplierPaymentMethod>())
                {
                    <option value="@method">@T.T(method.ToString())</option>
                }
            </select>
        </div>
        <div class="col-md-3"><label class="form-label">@T.T("PaymentDate")</label><input asp-for="PaymentDateUtc" type="date" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("Currency")</label><input asp-for="Currency" class="form-control" maxlength="3" /></div>
        <div class="col-md-3"><label class="form-label">@T.T("Reference")</label><input asp-for="Reference" class="form-control" /></div>
        <div class="col-md-6"><label class="form-label">@T.T("InternalNotes")</label><input asp-for="InternalNotes" class="form-control" /></div>
    </div>

    <div class="table-responsive mb-3">
        <table class="table table-sm align-middle">
            <thead><tr><th>@T.T("SupplierInvoiceId")</th><th>@T.T("SupplierInvoice")</th><th class="text-end">@T.T("OpenAmount")</th><th class="text-end">@T.T("Amount")</th><th>@T.T("Memo")</th></tr></thead>
            <tbody>
            @for (var i = 0; i < Model.Allocations.Count; i++)
            {
                <tr>
                    <td><input asp-for="Allocations[i].SupplierInvoiceId" class="form-control form-control-sm" /></td>
                    <td><div class="fw-semibold">@Model.Allocations[i].SupplierInvoiceNumber</div><div class="text-muted small">@Model.Allocations[i].InternalInvoiceNumber</div></td>
                    <td class="text-end">@(Model.Allocations[i].OpenAmountMinor / 100.0M).ToString("0.00")</td>
                    <td><input asp-for="Allocations[i].AmountMinor" class="form-control form-control-sm text-end" /></td>
                    <td><input asp-for="Allocations[i].Memo" class="form-control form-control-sm" /></td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">@T.T("Save")</button>
        <a asp-action="SupplierPayments" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Cancel")</a>
    </div>
</form>
</div>
