@model Darwin.Application.Billing.DTOs.FinanceExportsPageDto
@using Darwin.Domain.Enums
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("FinanceExports");
    string FinanceOverviewUrl(Guid? businessId = null) => Url.Action("Index", "Finance", new { businessId }) ?? string.Empty;
    string ReceivablesUrl(Guid? businessId = null) => Url.Action("Receivables", "Finance", new { businessId }) ?? string.Empty;
    string PostingsUrl(Guid? businessId = null) => Url.Action("Postings", "Finance", new { businessId }) ?? string.Empty;
    string AccountMappingsUrl(Guid? businessId = null) => Url.Action("AccountMappings", "Finance", new { businessId }) ?? string.Empty;
    string ExportsUrl(Guid? businessId = null, Guid? externalSystemId = null, DateTime? periodStartUtc = null, DateTime? periodEndUtc = null, FinanceExportPostingStatusMode postingStatusMode = FinanceExportPostingStatusMode.PostedAndReversed)
        => Url.Action("Exports", "Finance", new { businessId, externalSystemId, periodStartUtc, periodEndUtc, postingStatusMode }) ?? string.Empty;
    string DownloadUrl(Guid id) => Url.Action("DownloadExportPackage", "Finance", new { id }) ?? string.Empty;
}

<div id="finance-exports-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-0"><i class="fa-solid fa-file-export"></i> @T.T("FinanceExports")</h1>
        <div class="text-muted small mt-1">@Model.BusinessName</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" asp-route-businessId="@Model.BusinessId" hx-get="@FinanceOverviewUrl(Model.BusinessId)" hx-target="#finance-exports-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("Overview")</a>
        <a asp-action="Receivables" asp-route-businessId="@Model.BusinessId" hx-get="@ReceivablesUrl(Model.BusinessId)" hx-target="#finance-exports-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("FinanceReceivables")</a>
        <a asp-action="Postings" asp-route-businessId="@Model.BusinessId" hx-get="@PostingsUrl(Model.BusinessId)" hx-target="#finance-exports-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("FinancePostings")</a>
        <a asp-action="AccountMappings" asp-route-businessId="@Model.BusinessId" hx-get="@AccountMappingsUrl(Model.BusinessId)" hx-target="#finance-exports-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("FinanceAccountMappings")</a>
        <a asp-action="Exports" asp-route-businessId="@Model.BusinessId" hx-get="@ExportsUrl(Model.BusinessId, Model.ExternalSystemId, Model.PeriodStartUtc, Model.PeriodEndUtc, Model.PostingStatusMode)" hx-target="#finance-exports-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("FinanceExports")</a>
    </div>
</div>

@if (!Model.StorageReady)
{
    <div class="alert alert-warning">@T.T(Model.StorageReadinessMessage)</div>
}
@if (Model.StorageReady && !Model.ConnectorAdapterReady)
{
    <div class="alert alert-secondary">@T.T(Model.ConnectorReadinessMessage)</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Draft")</div><div class="fs-4 fw-semibold">@Model.DraftBatchCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Failed")</div><div class="fs-4 fw-semibold">@Model.FailedBatchCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Generated")</div><div class="fs-4 fw-semibold">@Model.GeneratedBatchCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Delivered")</div><div class="fs-4 fw-semibold">@Model.DeliveredBatchCount</div></div></div>
</div>

<form method="get" asp-action="Exports" class="row g-2 align-items-end mb-3">
    <div class="col-md-2">
        <label class="form-label small text-muted">@T.T("Business")</label>
        <select name="businessId" class="form-select">
            @foreach (var business in Model.BusinessOptions)
            {
                <option value="@business.Id" selected="@(Model.BusinessId == business.Id)">@business.Name</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label small text-muted">@T.T("FinanceExportTarget")</label>
        <select name="externalSystemId" class="form-select">
            @foreach (var target in Model.ExternalSystemOptions)
            {
                <option value="@target.Id" selected="@(Model.ExternalSystemId == target.Id)">@target.Label</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">@T.T("PeriodStart")</label>
        <input type="date" name="periodStartUtc" value="@Model.PeriodStartUtc.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">@T.T("PeriodEnd")</label>
        <input type="date" name="periodEndUtc" value="@Model.PeriodEndUtc.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">@T.T("Status")</label>
        <select name="postingStatusMode" class="form-select">
            @foreach (var mode in Enum.GetValues<FinanceExportPostingStatusMode>())
            {
                <option value="@mode" selected="@(Model.PostingStatusMode == mode)">@mode</option>
            }
        </select>
    </div>
    <div class="col-md-1">
        <button type="submit" class="btn btn-primary w-100">@T.T("Apply")</button>
    </div>
</form>

<form method="post" asp-action="CreateExportBatch" class="mb-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="BusinessId" value="@Model.BusinessId" />
    <input type="hidden" name="ExternalSystemId" value="@Model.ExternalSystemId" />
    <input type="hidden" name="PeriodStartUtc" value="@Model.PeriodStartUtc.ToString("O")" />
    <input type="hidden" name="PeriodEndUtc" value="@Model.PeriodEndUtc.ToString("O")" />
    <input type="hidden" name="PostingStatusMode" value="@Model.PostingStatusMode" />
    <button type="submit" class="btn btn-success" disabled="@(!Model.BusinessId.HasValue || !Model.ExternalSystemId.HasValue || !Model.StorageReady)">@T.T("FinanceExportCreateBatch")</button>
</form>

<div class="border rounded p-3">
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
            <tr>
                <th>@T.T("FinanceExportTarget")</th>
                <th>@T.T("Period")</th>
                <th>@T.T("Status")</th>
                <th>@T.T("Attempts")</th>
                <th>@T.T("Package")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="6" class="text-center text-muted">@T.T("NoFinanceExportBatches")</td></tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@item.ExternalSystemName</div>
                            <div class="text-muted small">@item.PostingStatusMode</div>
                        </td>
                        <td>
                            <div>@item.PeriodStartUtc.ToString("yyyy-MM-dd") - @item.PeriodEndUtc.ToString("yyyy-MM-dd")</div>
                            <div class="text-muted small">@item.ExportKey</div>
                        </td>
                        <td>
                            <span class="badge text-bg-secondary">@item.Status</span>
                            @if (!string.IsNullOrWhiteSpace(item.ErrorSummary))
                            {
                                <div class="text-danger small mt-1">@item.ErrorSummary</div>
                            }
                        </td>
                        <td>
                            <div>@item.AttemptCount</div>
                            <div class="text-muted small">@item.LastAttemptStatus @item.LastAttemptAtUtc?.ToString("yyyy-MM-dd HH:mm")</div>
                        </td>
                        <td>
                            @if (item.HasPackageDocument)
                            {
                                <div class="fw-semibold">@item.PackageFileName</div>
                                <div class="text-muted small">@item.PackageHashSha256</div>
                                @if (item.DeliveredAtUtc.HasValue)
                                {
                                    <div class="text-muted small">@T.T("DeliveredAt"): @item.DeliveredAtUtc.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                }
                                @if (item.HasDeliveryReference)
                                {
                                    <div class="text-muted small">@T.T("FinanceExportDeliveredReference"): @item.DeliveryReferenceDisplay</div>
                                }
                            }
                            else
                            {
                                <span class="text-muted">@T.T("NotReady")</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-end">
                                @if (item.CanGenerate && Model.StorageReady)
                                {
                                    <form method="post" asp-action="GenerateExportPackage">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="businessId" value="@Model.BusinessId" />
                                        <input type="hidden" name="externalSystemId" value="@Model.ExternalSystemId" />
                                        <input type="hidden" name="periodStartUtc" value="@Model.PeriodStartUtc.ToString("O")" />
                                        <input type="hidden" name="periodEndUtc" value="@Model.PeriodEndUtc.ToString("O")" />
                                        <input type="hidden" name="postingStatusMode" value="@Model.PostingStatusMode" />
                                        <button type="submit" class="btn btn-sm btn-primary">@T.T("Generate")</button>
                                    </form>
                                }
                                @if (item.CanDownload)
                                {
                                    <a class="btn btn-sm btn-outline-secondary" href="@DownloadUrl(item.Id)">@T.T("Download")</a>
                                }
                                @if (item.CanPush)
                                {
                                    <form method="post" asp-action="PushExportPackage">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="businessId" value="@Model.BusinessId" />
                                        <input type="hidden" name="externalSystemId" value="@Model.ExternalSystemId" />
                                        <input type="hidden" name="periodStartUtc" value="@Model.PeriodStartUtc.ToString("O")" />
                                        <input type="hidden" name="periodEndUtc" value="@Model.PeriodEndUtc.ToString("O")" />
                                        <input type="hidden" name="postingStatusMode" value="@Model.PostingStatusMode" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("FinanceExportPushPackage")</button>
                                    </form>
                                }
                                else if (item.Status == FinanceExportBatchStatus.Generated && item.HasPackageDocument && !Model.ConnectorAdapterReady)
                                {
                                    <span class="badge text-bg-light border">@T.T("FinanceExportPushBlocked")</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
</div>
