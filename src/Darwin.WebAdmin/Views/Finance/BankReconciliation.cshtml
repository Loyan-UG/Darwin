@model Darwin.Application.Billing.DTOs.BankReconciliationPageDto
@using Darwin.Domain.Enums
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BankReconciliation");
    string BankReconciliationUrl() => Url.Action("BankReconciliation", "Finance") ?? string.Empty;
}

<section id="finance-bank-reconciliation-workspace-shell" class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0"><i class="fa-solid fa-link"></i> @T.T("BankReconciliation")</h1>
        <a asp-action="CreateBankReconciliation" asp-route-businessId="@Model.BusinessId" asp-route-bankAccountId="@Model.BankAccountId" class="btn btn-primary">@T.T("CreateBankReconciliation")</a>
    </div>

    <form method="get" asp-action="BankReconciliation" class="row g-2 align-items-end mb-3" hx-get="@BankReconciliationUrl()" hx-target="#finance-bank-reconciliation-workspace-shell" hx-swap="outerHTML" hx-push-url="true">
        <div class="col-md-3">
            <label class="form-label small text-muted">@T.T("Business")</label>
            <select name="businessId" class="form-select">
                <option value="">@T.T("AllBusinesses")</option>
                @foreach (var business in Model.BusinessOptions)
                {
                    <option value="@business.Id" selected="@(Model.BusinessId == business.Id)">@business.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">@T.T("BankAccount")</label>
            <select name="bankAccountId" class="form-select">
                <option value="">@T.T("All")</option>
                @foreach (var account in Model.BankAccountOptions)
                {
                    <option value="@account.Id" selected="@(Model.BankAccountId == account.Id)">@account.Label</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">@T.T("Search")</label>
            <input name="q" value="@Model.Query" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted">@T.T("Status")</label>
            <select name="status" class="form-select">
                <option value="">@T.T("All")</option>
                @foreach (var status in Enum.GetValues<BankReconciliationMatchStatus>())
                {
                    <option value="@status" selected="@(Model.Status == status)">@T.T(status.ToString())</option>
                }
            </select>
        </div>
        <div class="col-md-1">
            <button class="btn btn-outline-primary w-100" type="submit">@T.T("Filter")</button>
        </div>
    </form>

    <div class="row g-3 mb-3">
        <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted small">@T.T("Draft")</div><strong>@Model.DraftCount</strong></div></div>
        <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted small">@T.T("Matched")</div><strong>@Model.MatchedCount</strong></div></div>
        <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted small">@T.T("Cancelled")</div><strong>@Model.CancelledCount</strong></div></div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
            <tr>
                <th>@T.T("MatchNumber")</th>
                <th>@T.T("BankAccount")</th>
                <th>@T.T("Date")</th>
                <th>@T.T("Totals")</th>
                <th>@T.T("Difference")</th>
                <th>@T.T("Status")</th>
                <th class="text-end">@T.T("Actions")</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-muted">@T.T("NoBankReconciliationMatches")</td></tr>
            }
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td class="fw-semibold">@(string.IsNullOrWhiteSpace(item.MatchNumber) ? item.Id.ToString("N")[..8] : item.MatchNumber)</td>
                    <td>@item.BankAccountLabel</td>
                    <td>@item.MatchDateUtc.ToString("yyyy-MM-dd")</td>
                    <td>@item.BankTotalMinor / @item.FinanceTotalMinor @item.Currency</td>
                    <td>@item.DifferenceMinor</td>
                    <td><span class="badge text-bg-light border">@T.T(item.Status.ToString())</span></td>
                    <td class="text-end">
                        <a asp-action="BankReconciliationMatch" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">@T.T("Details")</a>
                        @if (item.Status == BankReconciliationMatchStatus.Draft)
                        {
                            <a asp-action="EditBankReconciliation" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">@T.T("Edit")</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
