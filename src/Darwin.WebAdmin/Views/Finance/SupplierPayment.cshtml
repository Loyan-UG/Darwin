@model Darwin.Application.Billing.DTOs.SupplierPaymentEditDto
@using Darwin.Domain.Enums
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("SupplierPayment");
    var rowVersion = Convert.ToBase64String(Model.RowVersion);
    string Money(long minor) => $"{Model.Currency} {(minor / 100.0M):0.00}";
    var postingQuery = $"supplier-payment-posted:{Model.Id}";
    var reversalQuery = $"supplier-payment-reversed:{Model.Id}";
}

<div id="finance-supplier-payment-detail-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-0">@T.T("SupplierPayment") @(string.IsNullOrWhiteSpace(Model.PaymentNumber) ? "-" : Model.PaymentNumber)</h1>
        <div class="text-muted small">@T.T(Model.Status.ToString()) / @T.T(Model.PaymentMethod.ToString())</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="SupplierPayments" asp-route-businessId="@Model.BusinessId" class="btn btn-outline-secondary">@T.T("Back")</a>
        @if (Model.Status == SupplierPaymentStatus.Draft)
        {
            <a asp-action="EditSupplierPayment" asp-route-id="@Model.Id" class="btn btn-outline-primary">@T.T("Edit")</a>
        }
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("PaymentDate")</div><div class="fw-semibold">@Model.PaymentDateUtc.ToString("yyyy-MM-dd")</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("PaymentMethod")</div><div class="fw-semibold">@T.T(Model.PaymentMethod.ToString())</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("Reference")</div><div class="fw-semibold">@(Model.Reference ?? "-")</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("Total")</div><div class="fw-semibold">@Money(Model.TotalAmountMinor)</div></div></div>
</div>

<div class="border rounded p-3 mb-3">
    <div class="row g-3 align-items-center">
        <div class="col-md-6">
            <div class="text-muted small">@T.T("PaymentPosting")</div>
            <div class="fw-semibold">@(Model.PostedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? T.T("NotPosted"))</div>
            @if (Model.PostingJournalEntryId.HasValue)
            {
                <a asp-action="Postings" asp-route-businessId="@Model.BusinessId" asp-route-q="@postingQuery" class="btn btn-sm btn-outline-secondary mt-2">@T.T("ViewPosting")</a>
            }
        </div>
        <div class="col-md-6">
            <div class="text-muted small">@T.T("PaymentReversal")</div>
            <div class="fw-semibold">@(Model.ReversedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? T.T("NotReversed"))</div>
            @if (!string.IsNullOrWhiteSpace(Model.ReversalReason))
            {
                <div class="small text-muted">@Model.ReversalReason</div>
            }
            @if (Model.ReversalJournalEntryId.HasValue)
            {
                <a asp-action="Postings" asp-route-businessId="@Model.BusinessId" asp-route-q="@reversalQuery" class="btn btn-sm btn-outline-secondary mt-2">@T.T("ViewReversal")</a>
            }
        </div>
    </div>
</div>

<div class="table-responsive mb-3">
    <table class="table table-sm align-middle">
        <thead><tr><th>@T.T("SupplierInvoice")</th><th>@T.T("DueDate")</th><th class="text-end">@T.T("InvoiceTotal")</th><th class="text-end">@T.T("AlreadyPaid")</th><th class="text-end">@T.T("Amount")</th><th>@T.T("Memo")</th></tr></thead>
        <tbody>
        @foreach (var allocation in Model.Allocations)
        {
            <tr>
                <td><div class="fw-semibold">@allocation.SupplierInvoiceNumber</div><div class="text-muted small">@(string.IsNullOrWhiteSpace(allocation.InternalInvoiceNumber) ? "-" : allocation.InternalInvoiceNumber)</div></td>
                <td>@(allocation.DueDateUtc?.ToString("yyyy-MM-dd") ?? "-")</td>
                <td class="text-end">@Money(allocation.InvoiceGrossMinor)</td>
                <td class="text-end">@Money(allocation.AlreadyPaidMinor)</td>
                <td class="text-end">@Money(allocation.AmountMinor)</td>
                <td>@(allocation.Memo ?? "-")</td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="d-flex gap-2 flex-wrap">
    <form method="post" asp-action="PostSupplierPayment">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="RowVersion" value="@rowVersion" />
        <button type="submit" name="Action" value="Post" class="btn btn-warning" disabled="@(Model.Status != SupplierPaymentStatus.Draft)">@T.T("PostSupplierPayment")</button>
    </form>
    <form method="post" asp-action="CancelSupplierPayment">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="RowVersion" value="@rowVersion" />
        <button type="submit" name="Action" value="Cancel" class="btn btn-outline-danger" disabled="@(Model.Status != SupplierPaymentStatus.Draft)">@T.T("Cancel")</button>
    </form>
    @if (Model.Status == SupplierPaymentStatus.Posted)
    {
        <form method="post" asp-action="ReverseSupplierPayment" class="d-flex gap-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />
            <input type="hidden" name="RowVersion" value="@rowVersion" />
            <input type="hidden" name="Action" value="Reverse" />
            <input name="Reason" class="form-control" style="max-width: 24rem" placeholder="@T.T("ReversalReason")" required />
            <button type="submit" class="btn btn-outline-danger">@T.T("ReversePayment")</button>
        </form>
    }
</div>
</div>
