@model Darwin.Application.Billing.DTOs.FinanceOverviewDto
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("FinanceOverviewTitle");
    string FinanceOverviewUrl(Guid? businessId = null) => Url.Action("Index", "Finance", new { businessId }) ?? string.Empty;
    string ReceivablesUrl(Guid? businessId = null) => Url.Action("Receivables", "Finance", new { businessId }) ?? string.Empty;
    string PostingsUrl(Guid? businessId = null) => Url.Action("Postings", "Finance", new { businessId }) ?? string.Empty;
    string AccountMappingsUrl(Guid? businessId = null) => Url.Action("AccountMappings", "Finance", new { businessId }) ?? string.Empty;
    string ExportsUrl(Guid? businessId = null) => Url.Action("Exports", "Finance", new { businessId }) ?? string.Empty;
    string BillingAccountsUrl(Guid? businessId = null) => Url.Action("FinancialAccounts", "Billing", new { businessId }) ?? string.Empty;
    string BillingJournalsUrl(Guid? businessId = null) => Url.Action("JournalEntries", "Billing", new { businessId }) ?? string.Empty;
    string Money(long minor) => $"{Model.Currency} {(minor / 100.0M):0.00}";
}

<div id="finance-overview-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-0"><i class="fa-solid fa-scale-balanced"></i> @T.T("FinanceOverviewTitle")</h1>
        <div class="text-muted small mt-1">@T.T("FinanceOverviewSubtitle")</div>
    </div>
    <form method="get" asp-action="Index" class="d-flex gap-2">
        <select name="businessId" class="form-select form-select-sm">
            @foreach (var business in Model.BusinessOptions)
            {
                <option value="@business.Id" selected="@(Model.BusinessId == business.Id)">@business.Name</option>
            }
        </select>
        <button type="submit" class="btn btn-sm btn-outline-primary">@T.T("Apply")</button>
    </form>
</div>

<div class="d-flex gap-2 flex-wrap mb-4">
    <a asp-action="Index" asp-route-businessId="@Model.BusinessId" hx-get="@FinanceOverviewUrl(Model.BusinessId)" hx-target="#finance-overview-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("Overview")</a>
    <a asp-action="Receivables" asp-route-businessId="@Model.BusinessId" hx-get="@ReceivablesUrl(Model.BusinessId)" hx-target="#finance-overview-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("FinanceReceivables")</a>
    <a asp-action="Postings" asp-route-businessId="@Model.BusinessId" hx-get="@PostingsUrl(Model.BusinessId)" hx-target="#finance-overview-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("FinancePostings")</a>
    <a asp-action="AccountMappings" asp-route-businessId="@Model.BusinessId" hx-get="@AccountMappingsUrl(Model.BusinessId)" hx-target="#finance-overview-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("FinanceAccountMappings")</a>
    <a asp-action="Exports" asp-route-businessId="@Model.BusinessId" hx-get="@ExportsUrl(Model.BusinessId)" hx-target="#finance-overview-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("FinanceExports")</a>
    <a asp-controller="Billing" asp-action="FinancialAccounts" asp-route-businessId="@Model.BusinessId" hx-get="@BillingAccountsUrl(Model.BusinessId)" hx-target="#finance-overview-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("FinancialAccounts")</a>
    <a asp-controller="Billing" asp-action="JournalEntries" asp-route-businessId="@Model.BusinessId" hx-get="@BillingJournalsUrl(Model.BusinessId)" hx-target="#finance-overview-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("JournalEntries")</a>
</div>

@if (!Model.BusinessId.HasValue)
{
    <div class="alert alert-info">@T.T("FinanceReportingNoBusiness")</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4 col-xl-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("OpenReceivables")</div><div class="fs-4 fw-semibold">@Money(Model.OpenReceivablesMinor)</div></div></div>
    <div class="col-md-4 col-xl-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("ReceivablesDebit")</div><div class="fs-4 fw-semibold">@Money(Model.ReceivablesDebitMinor)</div></div></div>
    <div class="col-md-4 col-xl-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("ReceivablesCredit")</div><div class="fs-4 fw-semibold">@Money(Model.ReceivablesCreditMinor)</div></div></div>
    <div class="col-md-4 col-xl-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Posted")</div><div class="fs-4 fw-semibold">@Model.PostedJournalEntryCount</div></div></div>
    <div class="col-md-4 col-xl-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Draft")</div><div class="fs-4 fw-semibold">@Model.DraftJournalEntryCount</div></div></div>
    <div class="col-md-4 col-xl-2"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("FinanceNeedsAttention")</div><div class="fs-4 fw-semibold">@(Model.MissingSourcePostingCount + Model.UnpostedIssuedCreditNoteCount)</div></div></div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ReceivablesReadinessMessage))
{
    <div class="alert alert-warning">@T.T("FinanceReceivablesReadiness") <span class="small">@Model.ReceivablesReadinessMessage</span></div>
}

<div class="row g-3">
    <div class="col-lg-5">
        <div class="border rounded p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h6 mb-0">@T.T("FinancePostingBreakdown")</h2>
                <a asp-action="Postings" asp-route-businessId="@Model.BusinessId" hx-get="@PostingsUrl(Model.BusinessId)" hx-target="#finance-overview-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("FinancePostings")</a>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead><tr><th>@T.T("Type")</th><th class="text-end">@T.T("Count")</th><th class="text-end">@T.T("Debit")</th><th class="text-end">@T.T("Credit")</th></tr></thead>
                    <tbody>
                    @if (Model.PostingKindBreakdown.Count == 0)
                    {
                        <tr><td colspan="4" class="text-center text-muted">@T.T("NoFinancePostings")</td></tr>
                    }
                    else
                    {
                        foreach (var item in Model.PostingKindBreakdown)
                        {
                            <tr>
                                <td>@item.PostingKind</td>
                                <td class="text-end">@item.Count</td>
                                <td class="text-end">@Money(item.DebitMinor)</td>
                                <td class="text-end">@Money(item.CreditMinor)</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="border rounded p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h6 mb-0">@T.T("LargestOpenReceivables")</h2>
                <a asp-action="Receivables" asp-route-businessId="@Model.BusinessId" hx-get="@ReceivablesUrl(Model.BusinessId)" hx-target="#finance-overview-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-secondary">@T.T("FinanceReceivables")</a>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead><tr><th>@T.T("Document")</th><th>@T.T("Source")</th><th class="text-end">@T.T("OpenBalance")</th><th>@T.T("LastEntry")</th></tr></thead>
                    <tbody>
                    @if (Model.TopReceivables.Count == 0)
                    {
                        <tr><td colspan="4" class="text-center text-muted">@T.T("NoOpenReceivables")</td></tr>
                    }
                    else
                    {
                        foreach (var item in Model.TopReceivables)
                        {
                            <tr>
                                <td>@(!string.IsNullOrWhiteSpace(item.SourceDocumentNumber) ? item.SourceDocumentNumber : item.SourceEntityId?.ToString("N"))</td>
                                <td>@item.SourceEntityType</td>
                                <td class="text-end">@Money(item.OpenBalanceMinor)</td>
                                <td>@item.LastEntryDateUtc.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</div>
