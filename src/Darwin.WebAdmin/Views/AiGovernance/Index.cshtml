@model Darwin.Application.Foundation.AiGovernanceReviewPageDto
@using Darwin.Domain.Enums
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("AiGovernance");
}

<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-0">@T.T("AiGovernance")</h1>
        <div class="text-muted small">@T.T("AiGovernanceReviewQueue")</div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted small">@T.T("OpenRecommendations")</div><div class="fs-4 fw-semibold">@Model.Summary.OpenRecommendations</div></div></div>
    <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted small">@T.T("PendingActionDrafts")</div><div class="fs-4 fw-semibold">@Model.Summary.PendingActionDrafts</div></div></div>
    <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted small">@T.T("ApprovedActionDrafts")</div><div class="fs-4 fw-semibold">@Model.Summary.ApprovedNotExecutedDrafts</div></div></div>
</div>

<form method="get" asp-action="Index" class="row g-2 align-items-end mb-4">
    <div class="col-md-3">
        <label class="form-label">@T.T("Search")</label>
        <input name="q" value="@Model.Query" class="form-control" maxlength="200" />
    </div>
    <div class="col-md-3">
        <label class="form-label">@T.T("RecommendationStatus")</label>
        <select name="recommendationStatus" class="form-select">
            <option value="">@T.T("All")</option>
            @foreach (var status in Enum.GetValues<AiRecommendationStatus>())
            {
                <option value="@status" selected="@(Model.RecommendationStatus == status)">@T.T(status.ToString())</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">@T.T("ActionDraftStatus")</label>
        <select name="actionDraftStatus" class="form-select">
            <option value="">@T.T("All")</option>
            @foreach (var status in Enum.GetValues<AiActionDraftStatus>())
            {
                <option value="@status" selected="@(Model.ActionDraftStatus == status)">@T.T(status.ToString())</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label">@T.T("PageSize")</label>
        <input name="pageSize" value="@Model.PageSize" type="number" min="5" max="100" class="form-control" />
    </div>
    <div class="col-md-1">
        <button class="btn btn-primary w-100" type="submit">@T.T("Filter")</button>
    </div>
</form>

<div class="row g-4">
    <div class="col-xl-6">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h2 class="h5 mb-0">@T.T("Recommendations")</h2>
            <span class="badge bg-secondary">@Model.RecommendationTotal</span>
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                <tr>
                    <th>@T.T("Title")</th>
                    <th>@T.T("FeatureArea")</th>
                    <th>@T.T("Status")</th>
                    <th class="text-end">@T.T("Confidence")</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Recommendations)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@item.Title</div>
                            <div class="small text-muted">@item.Summary</div>
                        </td>
                        <td>@item.FeatureAreaCode</td>
                        <td><span class="badge bg-light text-dark">@T.T(item.Status.ToString())</span></td>
                        <td class="text-end">@item.ConfidenceScore%</td>
                        <td class="text-end"><a asp-action="Recommendation" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">@T.T("Open")</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-xl-6">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h2 class="h5 mb-0">@T.T("ActionDrafts")</h2>
            <span class="badge bg-secondary">@Model.ActionDraftTotal</span>
        </div>
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                <tr>
                    <th>@T.T("Summary")</th>
                    <th>@T.T("CommandType")</th>
                    <th>@T.T("Risk")</th>
                    <th>@T.T("Status")</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.ActionDrafts)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@item.Summary</div>
                            <div class="small text-muted">@item.TargetEntityType @(item.TargetEntityId?.ToString() ?? "-")</div>
                        </td>
                        <td>@item.CommandType</td>
                        <td><span class="badge bg-light text-dark">@T.T(item.RiskLevel.ToString())</span></td>
                        <td><span class="badge bg-light text-dark">@T.T(item.Status.ToString())</span></td>
                        <td class="text-end"><a asp-action="ActionDraft" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">@T.T("Open")</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
