@model Darwin.Application.Foundation.InternalFollowUpTasksPageDto
@using Darwin.Domain.Enums
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("FollowUpTasks");
}

<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-0">@T.T("FollowUpTasks")</h1>
        <div class="text-muted small">@T.T("AiGovernance")</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">@T.T("AiGovernance")</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("Total")</div><div class="fs-4 fw-semibold">@Model.Total</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("Open")</div><div class="fs-4 fw-semibold">@Model.OpenCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("InProgress")</div><div class="fs-4 fw-semibold">@Model.InProgressCount</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("Overdue")</div><div class="fs-4 fw-semibold">@Model.OverdueCount</div></div></div>
</div>

<form method="get" asp-action="FollowUpTasks" class="row g-2 align-items-end mb-4">
    <div class="col-md-4">
        <label class="form-label">@T.T("Search")</label>
        <input name="q" value="@Model.Query" class="form-control" maxlength="200" />
    </div>
    <div class="col-md-3">
        <label class="form-label">@T.T("Status")</label>
        <select name="status" class="form-select">
            <option value="">@T.T("All")</option>
            @foreach (var status in Enum.GetValues<InternalFollowUpTaskStatus>())
            {
                <option value="@status" selected="@(Model.Status == status)">@T.T(status.ToString())</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label">@T.T("PageSize")</label>
        <input name="pageSize" value="@Model.PageSize" type="number" min="5" max="100" class="form-control" />
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" type="submit">@T.T("Filter")</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead>
        <tr>
            <th>@T.T("Title")</th>
            <th>@T.T("FeatureArea")</th>
            <th>@T.T("TargetEntity")</th>
            <th>@T.T("Priority")</th>
            <th>@T.T("DueAtUtc")</th>
            <th>@T.T("Status")</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>
                    <div class="fw-semibold">@item.Title</div>
                    @if (item.SourceAiActionDraftId.HasValue)
                    {
                        <div class="small text-muted">@T.T("AiActionDraft") @item.SourceAiActionDraftId.Value.ToString("N")</div>
                    }
                </td>
                <td>@item.FeatureAreaCode</td>
                <td><span class="small">@item.TargetEntityType</span></td>
                <td><span class="badge bg-light text-dark">@T.T(item.Priority.ToString())</span></td>
                <td>@(item.DueAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                <td><span class="badge bg-light text-dark">@T.T(item.Status.ToString())</span></td>
                <td class="text-end"><a asp-action="FollowUpTask" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">@T.T("Open")</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
