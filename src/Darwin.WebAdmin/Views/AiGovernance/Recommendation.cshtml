@model Darwin.Application.Foundation.AiRecommendationDetailDto
@using Darwin.Domain.Enums
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("AiRecommendation");
}

<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-0">@Model.Title</h1>
        <div class="text-muted small">@Model.FeatureAreaCode / @Model.RecommendationType / @T.T(Model.Status.ToString())</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">@T.T("Back")</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("Confidence")</div><div class="fw-semibold">@Model.ConfidenceScore%</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("ExpiresAt")</div><div class="fw-semibold">@(Model.ExpiresAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("SourceEntity")</div><div class="fw-semibold">@(Model.SourceEntityType ?? "-")</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted small">@T.T("CreatedAt")</div><div class="fw-semibold">@Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</div></div></div>
</div>

<div class="border rounded p-3 mb-3">
    <h2 class="h5">@T.T("Summary")</h2>
    <p class="mb-3">@Model.Summary</p>
    <h2 class="h5">@T.T("Rationale")</h2>
    <p class="mb-0">@Model.Rationale</p>
</div>

@if (Model.Status == AiRecommendationStatus.Open)
{
    <div class="border rounded p-3">
        <h2 class="h5">@T.T("Review")</h2>
        <div class="row g-3">
            <div class="col-md-4">
                <form method="post" asp-action="AcceptRecommendation">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="rowVersion" value="@Model.RowVersionText" />
                    <label class="form-label">@T.T("Reason")</label>
                    <input name="reason" class="form-control mb-2" maxlength="1024" required />
                    <button class="btn btn-success w-100" type="submit">@T.T("Accept")</button>
                </form>
            </div>
            <div class="col-md-4">
                <form method="post" asp-action="DismissRecommendation">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="rowVersion" value="@Model.RowVersionText" />
                    <label class="form-label">@T.T("Reason")</label>
                    <input name="reason" class="form-control mb-2" maxlength="1024" required />
                    <button class="btn btn-outline-danger w-100" type="submit">@T.T("Dismiss")</button>
                </form>
            </div>
            <div class="col-md-4">
                <form method="post" asp-action="ExpireRecommendation">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="rowVersion" value="@Model.RowVersionText" />
                    <label class="form-label">@T.T("Reason")</label>
                    <input name="reason" class="form-control mb-2" maxlength="1024" required />
                    <button class="btn btn-outline-secondary w-100" type="submit">@T.T("Expire")</button>
                </form>
            </div>
        </div>
    </div>
}
else
{
    <div class="border rounded p-3">
        <div class="text-muted small">@T.T("ReviewedAt")</div>
        <div class="fw-semibold">@(Model.ReviewedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
        @if (!string.IsNullOrWhiteSpace(Model.ReviewReason))
        {
            <div class="small text-muted mt-2">@Model.ReviewReason</div>
        }
    </div>
}
