@model Darwin.WebAdmin.ViewModels.Sales.CreditNotesListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("CreditNotes");
    var culture = System.Globalization.CultureInfo.CurrentCulture;
    string SalesOverviewUrl() => Url.Action("Index", "Sales") ?? string.Empty;
    string CreditNotesBaseUrl() => Url.Action("CreditNotes", "Sales") ?? string.Empty;
    string CreditNoteUrl(Guid id) => Url.Action("CreditNote", "Sales", new { id }) ?? string.Empty;
    string Money(string currency, long minor) => $"{currency} {(minor / 100.0M):0.00}";
    string DateText(DateTime? utc) => utc.HasValue ? utc.Value.ToString("g", culture) : "-";
}

<div id="sales-credit-notes-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="mb-0"><i class="fa-solid fa-file-circle-minus"></i> @T.T("CreditNotes")</h1>
        <div class="text-muted small mt-1">@T.T("CreditNotesSubtitle")</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" hx-get="@SalesOverviewUrl()" hx-target="#sales-credit-notes-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("Overview")</a>
        <a asp-action="Orders" hx-get="@Url.Action("Orders", "Sales")" hx-target="#sales-credit-notes-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("SalesOrders")</a>
        <a asp-action="ReturnOrders" hx-get="@Url.Action("ReturnOrders", "Sales")" hx-target="#sales-credit-notes-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("ReturnOrders")</a>
        <a asp-action="Invoices" hx-get="@Url.Action("Invoices", "Sales")" hx-target="#sales-credit-notes-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("SalesInvoices")</a>
    </div>
</div>

<form asp-action="CreditNotes" method="get" class="row g-2 align-items-end mb-3" hx-get="@CreditNotesBaseUrl()" hx-target="#sales-credit-notes-workspace-shell" hx-swap="outerHTML" hx-push-url="true">
    <div class="col-md-3">
        <label class="form-label small text-muted">@T.T("Search")</label>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchCreditNotesPlaceholder")" />
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">@T.T("Status")</label>
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">@T.T("IssuedFrom")</label>
        <input type="date" name="issuedFromUtc" value="@Model.IssuedFromUtc?.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">@T.T("IssuedTo")</label>
        <input type="date" name="issuedToUtc" value="@Model.IssuedToUtc?.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-md-3 d-flex gap-2">
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="CreditNotes" hx-get="@CreditNotesBaseUrl()" hx-target="#sales-credit-notes-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("ClearQueueFilters")</a>
    </div>
    <input type="hidden" name="businessId" value="@Model.BusinessId" />
    <input type="hidden" name="customerId" value="@Model.CustomerId" />
</form>

<div class="border rounded p-3 mb-3">
    <form asp-action="CreateCreditNote" method="post" class="row g-2 align-items-end" hx-post="@Url.Action("CreateCreditNote", "Sales")" hx-target="#sales-credit-notes-workspace-shell" hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <div class="col-md-3">
            <label class="form-label small text-muted">@T.T("InvoiceId")</label>
            <input name="InvoiceId" value="@Model.Create.InvoiceId" class="form-control" required />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted">@T.T("ReturnOrderId")</label>
            <input name="ReturnOrderId" value="@Model.Create.ReturnOrderId" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted">@T.T("RefundId")</label>
            <input name="RefundId" value="@Model.Create.RefundId" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted">@T.T("Reason")</label>
            <select name="Reason" class="form-select">
                @foreach (var reason in Enum.GetValues<Darwin.Domain.Enums.CreditNoteReason>())
                {
                    <option value="@reason">@T.T($"CreditNoteReason{reason}")</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary w-100">@T.T("CreateCreditNote")</button>
        </div>
        <div class="col-md-4">
            <label class="form-label small text-muted">@T.T("InvoiceLineId")</label>
            <input name="Lines[0].InvoiceLineId" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label small text-muted">@T.T("Quantity")</label>
            <input name="Lines[0].CreditedQuantity" type="number" min="1" value="1" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label small text-muted">@T.T("InternalNotes")</label>
            <input name="InternalNotes" value="@Model.Create.InternalNotes" class="form-control" />
        </div>
    </form>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
        <tr>
            <th>@T.T("CreditNoteNumber")</th>
            <th>@T.T("InvoiceNumber")</th>
            <th>@T.T("Status")</th>
            <th>@T.T("Reason")</th>
            <th class="text-end">@T.T("Net")</th>
            <th class="text-end">@T.T("Tax")</th>
            <th class="text-end">@T.T("GrossTotal")</th>
            <th>@T.T("IssuedAt")</th>
            <th class="text-end">@T.T("Actions")</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="9" class="text-center text-muted">@T.T("NoCreditNotesFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@(item.CreditNoteNumber ?? "-")</td>
                    <td>@(item.OriginalInvoiceNumber ?? item.InvoiceId.ToString("D"))</td>
                    <td>@T.T($"CreditNoteStatus{item.Status}")</td>
                    <td>@T.T($"CreditNoteReason{item.Reason}")</td>
                    <td class="text-end">@Money(item.Currency, item.TotalNetMinor)</td>
                    <td class="text-end">@Money(item.Currency, item.TotalTaxMinor)</td>
                    <td class="text-end">@Money(item.Currency, item.TotalGrossMinor)</td>
                    <td>@DateText(item.IssuedAtUtc)</td>
                    <td class="text-end">
                        <a asp-action="CreditNote" asp-route-id="@item.Id" hx-get="@CreditNoteUrl(item.Id)" hx-target="#sales-credit-notes-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">@T.T("View")</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Sales" asp-action="CreditNotes" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" asp-route-issuedFromUtc="@Model.IssuedFromUtc" asp-route-issuedToUtc="@Model.IssuedToUtc" asp-route-businessId="@Model.BusinessId" asp-route-customerId="@Model.CustomerId" hx-target="#sales-credit-notes-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
