@model Darwin.WebAdmin.ViewModels.Sales.CreditNoteDetailVm
@using Darwin.Domain.Enums
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("CreditNote");
    var doc = Model.Document;
    var culture = System.Globalization.CultureInfo.CurrentCulture;
    string CreditNotesUrl() => Url.Action("CreditNotes", "Sales") ?? string.Empty;
    string Money(long minor) => $"{doc.Currency} {(minor / 100.0M):0.00}";
    string DateText(DateTime? utc) => utc.HasValue ? utc.Value.ToString("g", culture) : "-";
    string RowVersion() => doc.RowVersion is null || doc.RowVersion.Length == 0 ? string.Empty : Convert.ToBase64String(doc.RowVersion);
}

<div id="sales-credit-note-detail-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="mb-0"><i class="fa-solid fa-file-circle-minus"></i> @(doc.CreditNoteNumber ?? T.T("CreditNote"))</h1>
        <div class="text-muted small mt-1">@T.T($"CreditNoteStatus{doc.Status}")</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="CreditNotes" hx-get="@CreditNotesUrl()" hx-target="#sales-credit-note-detail-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("BackToList")</a>
        <a asp-controller="Sales" asp-action="Invoice" asp-route-id="@doc.InvoiceId" class="btn btn-outline-primary">@T.T("SalesInvoice")</a>
        @if (doc.ReturnOrderId.HasValue)
        {
            <a asp-controller="Sales" asp-action="ReturnOrder" asp-route-id="@doc.ReturnOrderId.Value" class="btn btn-outline-primary">@T.T("ReturnOrder")</a>
        }
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Net")</div><div class="fs-5 fw-semibold">@Money(doc.TotalNetMinor)</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Tax")</div><div class="fs-5 fw-semibold">@Money(doc.TotalTaxMinor)</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("GrossTotal")</div><div class="fs-5 fw-semibold">@Money(doc.TotalGrossMinor)</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("IssuedAt")</div><div class="fs-6 fw-semibold">@DateText(doc.IssuedAtUtc)</div></div></div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <h2 class="h5">@T.T("Lines")</h2>
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                <tr>
                    <th>@T.T("Description")</th>
                    <th class="text-end">@T.T("OriginalQuantity")</th>
                    <th class="text-end">@T.T("CreditedQuantity")</th>
                    <th class="text-end">@T.T("TaxRate")</th>
                    <th class="text-end">@T.T("Total")</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var line in doc.Lines)
                {
                    <tr>
                        <td>@line.Description</td>
                        <td class="text-end">@line.OriginalQuantity</td>
                        <td class="text-end">@line.CreditedQuantity</td>
                        <td class="text-end">@line.TaxRate</td>
                        <td class="text-end">@Money(line.TotalGrossMinor)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-4">
        <h2 class="h5">@T.T("Actions")</h2>
        <div class="d-grid gap-2">
            @if (doc.Status == CreditNoteStatus.Draft)
            {
                <form asp-action="IssueCreditNote" method="post" hx-post="@Url.Action("IssueCreditNote", "Sales")" hx-target="#sales-credit-note-detail-shell" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@doc.Id" />
                    <input type="hidden" name="RowVersion" value="@RowVersion()" />
                    <button type="submit" class="btn btn-success w-100">@T.T("IssueCreditNote")</button>
                </form>
                <form asp-action="CancelCreditNote" method="post" hx-post="@Url.Action("CancelCreditNote", "Sales")" hx-target="#sales-credit-note-detail-shell" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@doc.Id" />
                    <input type="hidden" name="RowVersion" value="@RowVersion()" />
                    <button type="submit" class="btn btn-outline-danger w-100">@T.T("CancelCreditNote")</button>
                </form>
            }
            @if (doc.Status == CreditNoteStatus.Issued)
            {
                <form asp-action="VoidCreditNote" method="post" hx-post="@Url.Action("VoidCreditNote", "Sales")" hx-target="#sales-credit-note-detail-shell" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@doc.Id" />
                    <input type="hidden" name="RowVersion" value="@RowVersion()" />
                    <button type="submit" class="btn btn-outline-danger w-100">@T.T("VoidCreditNote")</button>
                </form>
            }
        </div>

        <h2 class="h6 mt-4">@T.T("SourceModel")</h2>
        <div class="small text-muted">@T.T("Hash"): @(doc.SourceModelHashSha256 ?? "-")</div>
        <div class="small text-muted">@T.T("ArchiveRetainUntil"): @DateText(doc.ArchiveRetainUntilUtc)</div>
        <div class="small text-muted">@T.T("PostingJournalEntryId"): @(doc.PostingJournalEntryId?.ToString("D") ?? "-")</div>
        @if (doc.HasSourceModel)
        {
            <a asp-action="DownloadCreditNoteSourceModel" asp-route-id="@doc.Id" class="btn btn-outline-secondary w-100 mt-3">@T.T("DownloadCreditNoteSourceModel")</a>
        }
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <h2 class="h6">@T.T("SourceModelJson")</h2>
        <pre class="bg-light border rounded p-2 small mb-0">@doc.SourceModelJson</pre>
    </div>
    <div class="col-lg-6">
        <h2 class="h6">@T.T("MetadataJson")</h2>
        <pre class="bg-light border rounded p-2 small mb-0">@doc.MetadataJson</pre>
    </div>
</div>
</div>
