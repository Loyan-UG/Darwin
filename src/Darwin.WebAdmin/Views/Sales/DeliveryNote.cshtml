@model Darwin.WebAdmin.ViewModels.Sales.DeliveryNoteDetailVm
@using Darwin.Domain.Enums
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("DeliveryNote");
    var note = Model.Document;
    var culture = System.Globalization.CultureInfo.CurrentCulture;
    string NotesUrl() => Url.Action("DeliveryNotes", "Sales") ?? string.Empty;
    string Money(long minor) => $"{note.Currency} {(minor / 100.0M):0.00}";
    string DateText(DateTime? utc) => utc.HasValue ? utc.Value.ToString("g", culture) : "-";
    string RowVersion() => note.RowVersion is null || note.RowVersion.Length == 0 ? string.Empty : Convert.ToBase64String(note.RowVersion);
}

<div id="sales-delivery-note-detail-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="mb-0"><i class="fa-solid fa-truck-ramp-box"></i> @(note.DeliveryNoteNumber ?? T.T("DeliveryNote"))</h1>
        <div class="text-muted small mt-1">@T.T($"DeliveryNoteStatus{note.Status}")</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="DeliveryNotes" hx-get="@NotesUrl()" hx-target="#sales-delivery-note-detail-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("BackToList")</a>
        <a asp-controller="Sales" asp-action="Order" asp-route-id="@note.OrderId" class="btn btn-outline-primary">@T.T("SalesOrder")</a>
        <a asp-controller="Orders" asp-action="ShipmentsQueue" class="btn btn-outline-primary">@T.T("Shipments")</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Total")</div><div class="fs-5 fw-semibold">@Money(note.TotalGrossMinor)</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("Quantity")</div><div class="fs-5 fw-semibold">@note.TotalQuantity</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("IssuedAt")</div><div class="fs-6 fw-semibold">@DateText(note.IssuedAtUtc)</div></div></div>
    <div class="col-md-3"><div class="border rounded p-3 h-100"><div class="text-muted small">@T.T("TrackingNumber")</div><div class="fs-6 fw-semibold">@(note.TrackingNumber ?? "-")</div></div></div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <h2 class="h5">@T.T("Lines")</h2>
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                <tr>
                    <th>@T.T("Name")</th>
                    <th>@T.T("Sku")</th>
                    <th class="text-end">@T.T("Quantity")</th>
                    <th class="text-end">@T.T("UnitNet")</th>
                    <th class="text-end">@T.T("UnitGross")</th>
                    <th class="text-end">@T.T("Tax")</th>
                    <th class="text-end">@T.T("Total")</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var line in note.Lines)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@line.Name</div>
                            @if (!string.IsNullOrWhiteSpace(line.Description))
                            {
                                <div class="small text-muted">@line.Description</div>
                            }
                        </td>
                        <td>@(line.Sku ?? "-")</td>
                        <td class="text-end">@line.Quantity</td>
                        <td class="text-end">@Money(line.UnitPriceNetMinor)</td>
                        <td class="text-end">@Money(line.UnitPriceGrossMinor)</td>
                        <td class="text-end">@Money(line.TotalTaxMinor)</td>
                        <td class="text-end">@Money(line.TotalGrossMinor)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-4">
        <h2 class="h5">@T.T("Actions")</h2>
        <div class="d-grid gap-2">
            @if (note.Status == DeliveryNoteStatus.Draft)
            {
                <form asp-action="PrepareDeliveryNote" method="post" hx-post="@Url.Action("PrepareDeliveryNote", "Sales")" hx-target="#sales-delivery-note-detail-shell" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@note.Id" />
                    <input type="hidden" name="RowVersion" value="@RowVersion()" />
                    <button type="submit" class="btn btn-primary w-100">@T.T("PrepareDeliveryNote")</button>
                </form>
                <form asp-action="CancelDeliveryNote" method="post" hx-post="@Url.Action("CancelDeliveryNote", "Sales")" hx-target="#sales-delivery-note-detail-shell" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@note.Id" />
                    <input type="hidden" name="RowVersion" value="@RowVersion()" />
                    <button type="submit" class="btn btn-outline-danger w-100">@T.T("CancelDeliveryNote")</button>
                </form>
            }
            @if (note.Status == DeliveryNoteStatus.Prepared)
            {
                <form asp-action="IssueDeliveryNote" method="post" hx-post="@Url.Action("IssueDeliveryNote", "Sales")" hx-target="#sales-delivery-note-detail-shell" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@note.Id" />
                    <input type="hidden" name="RowVersion" value="@RowVersion()" />
                    <button type="submit" class="btn btn-success w-100">@T.T("IssueDeliveryNote")</button>
                </form>
                <form asp-action="CancelDeliveryNote" method="post" hx-post="@Url.Action("CancelDeliveryNote", "Sales")" hx-target="#sales-delivery-note-detail-shell" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@note.Id" />
                    <input type="hidden" name="RowVersion" value="@RowVersion()" />
                    <button type="submit" class="btn btn-outline-danger w-100">@T.T("CancelDeliveryNote")</button>
                </form>
            }
            @if (note.Status == DeliveryNoteStatus.Issued)
            {
                <form asp-action="MarkDeliveryNoteShipped" method="post" hx-post="@Url.Action("MarkDeliveryNoteShipped", "Sales")" hx-target="#sales-delivery-note-detail-shell" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@note.Id" />
                    <input type="hidden" name="RowVersion" value="@RowVersion()" />
                    <button type="submit" class="btn btn-primary w-100">@T.T("MarkShipped")</button>
                </form>
                <form asp-action="CancelDeliveryNote" method="post" hx-post="@Url.Action("CancelDeliveryNote", "Sales")" hx-target="#sales-delivery-note-detail-shell" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@note.Id" />
                    <input type="hidden" name="RowVersion" value="@RowVersion()" />
                    <button type="submit" class="btn btn-outline-danger w-100">@T.T("CancelDeliveryNote")</button>
                </form>
            }
            @if (note.Status == DeliveryNoteStatus.Shipped)
            {
                <form asp-action="MarkDeliveryNoteDelivered" method="post" hx-post="@Url.Action("MarkDeliveryNoteDelivered", "Sales")" hx-target="#sales-delivery-note-detail-shell" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@note.Id" />
                    <input type="hidden" name="RowVersion" value="@RowVersion()" />
                    <button type="submit" class="btn btn-success w-100">@T.T("MarkDelivered")</button>
                </form>
            }
        </div>

        <h2 class="h5 mt-4">@T.T("DocumentLinks")</h2>
        <dl class="row small mb-0">
            <dt class="col-5">@T.T("OrderNumber")</dt><dd class="col-7">@(note.OrderNumber ?? note.OrderId.ToString())</dd>
            <dt class="col-5">@T.T("ShipmentId")</dt><dd class="col-7">@note.ShipmentId</dd>
            <dt class="col-5">@T.T("Carrier")</dt><dd class="col-7">@(note.Carrier ?? "-")</dd>
            <dt class="col-5">@T.T("Service")</dt><dd class="col-7">@(note.Service ?? "-")</dd>
        </dl>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <h2 class="h6">@T.T("ShippingAddressJson")</h2>
        <pre class="bg-light border rounded p-2 small mb-0">@note.ShippingAddressJson</pre>
    </div>
    <div class="col-lg-6">
        <h2 class="h6">@T.T("MetadataJson")</h2>
        <pre class="bg-light border rounded p-2 small mb-0">@note.MetadataJson</pre>
    </div>
</div>
</div>
