@model Darwin.WebAdmin.ViewModels.Sales.SalesQuoteEditorVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = Model.IsCreate ? T.T("NewSalesQuote") : T.T("EditSalesQuote");
    var quote = Model.Quote;
    var action = Model.IsCreate ? "CreateQuote" : "EditQuote";
    var target = "#sales-quote-editor-shell";
    var lineRows = quote.Lines.Count == 0
        ? Enumerable.Range(0, 5).Select(_ => new Darwin.Application.Sales.DTOs.SalesQuoteLineEditDto()).ToList()
        : quote.Lines.Concat(Enumerable.Range(0, 3).Select(_ => new Darwin.Application.Sales.DTOs.SalesQuoteLineEditDto())).ToList();
    string QuotesUrl() => Url.Action("Quotes", "Sales") ?? string.Empty;
}

<div id="sales-quote-editor-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="mb-0"><i class="fa-solid fa-file-signature"></i> @ViewData["Title"]</h1>
        <div class="text-muted small mt-1">@T.T("SalesQuoteEditorSubtitle")</div>
    </div>
    <a asp-action="Quotes" hx-get="@QuotesUrl()" hx-target="#sales-quote-editor-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("BackToList")</a>
</div>

<form asp-action="@action" method="post" hx-post="@Url.Action(action, "Sales")" hx-target="@target" hx-swap="outerHTML">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@quote.Id" />
    <input type="hidden" name="RowVersion" value="@(quote.RowVersion is null || quote.RowVersion.Length == 0 ? string.Empty : Convert.ToBase64String(quote.RowVersion))" />

    <div class="row g-3 mb-3">
        <div class="col-md-5">
            <label class="form-label">@T.T("Title")</label>
            <input name="Title" value="@quote.Title" class="form-control" maxlength="250" required />
        </div>
        <div class="col-md-2">
            <label class="form-label">@T.T("Currency")</label>
            <input name="Currency" value="@quote.Currency" class="form-control" maxlength="3" required />
        </div>
        <div class="col-md-3">
            <label class="form-label">@T.T("ValidUntil")</label>
            <input type="date" name="ValidUntilUtc" value="@quote.ValidUntilUtc?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">@T.T("BusinessId")</label>
            <input name="BusinessId" value="@quote.BusinessId" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@T.T("CustomerId")</label>
            <input name="CustomerId" value="@quote.CustomerId" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@T.T("OpportunityId")</label>
            <input name="OpportunityId" value="@quote.OpportunityId" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">@T.T("OwnerUserId")</label>
            <input name="OwnerUserId" value="@quote.OwnerUserId" class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">@T.T("InternalNotes")</label>
        <textarea name="InternalNotes" class="form-control" rows="3" maxlength="2000">@quote.InternalNotes</textarea>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-lg-4">
            <label class="form-label">@T.T("CustomerSnapshotJson")</label>
            <textarea name="CustomerSnapshotJson" class="form-control font-monospace" rows="4">@(string.IsNullOrWhiteSpace(quote.CustomerSnapshotJson) ? "{}" : quote.CustomerSnapshotJson)</textarea>
        </div>
        <div class="col-lg-4">
            <label class="form-label">@T.T("BillingAddressJson")</label>
            <textarea name="BillingAddressJson" class="form-control font-monospace" rows="4">@(string.IsNullOrWhiteSpace(quote.BillingAddressJson) ? "{}" : quote.BillingAddressJson)</textarea>
        </div>
        <div class="col-lg-4">
            <label class="form-label">@T.T("ShippingAddressJson")</label>
            <textarea name="ShippingAddressJson" class="form-control font-monospace" rows="4">@(string.IsNullOrWhiteSpace(quote.ShippingAddressJson) ? "{}" : quote.ShippingAddressJson)</textarea>
        </div>
    </div>

    <div class="table-responsive mb-3">
        <table class="table table-sm align-middle">
            <thead>
            <tr>
                <th>@T.T("Name")</th>
                <th>@T.T("Sku")</th>
                <th class="text-end">@T.T("Quantity")</th>
                <th class="text-end">@T.T("UnitNet")</th>
                <th class="text-end">@T.T("UnitGross")</th>
                <th class="text-end">@T.T("TaxRate")</th>
                <th class="text-end">@T.T("SortOrder")</th>
            </tr>
            </thead>
            <tbody>
            @for (var i = 0; i < lineRows.Count; i++)
            {
                var line = lineRows[i];
                <tr>
                    <td>
                        <input type="hidden" name="Lines[@i].Id" value="@line.Id" />
                        <input type="hidden" name="Lines[@i].ProductVariantId" value="@line.ProductVariantId" />
                        <input name="Lines[@i].Name" value="@line.Name" class="form-control form-control-sm" maxlength="250" />
                        <input name="Lines[@i].Description" value="@line.Description" class="form-control form-control-sm mt-1" maxlength="1000" placeholder="@T.T("Description")" />
                    </td>
                    <td><input name="Lines[@i].Sku" value="@line.Sku" class="form-control form-control-sm" maxlength="100" /></td>
                    <td><input type="number" name="Lines[@i].Quantity" value="@(line.Quantity == 0 ? null : line.Quantity)" class="form-control form-control-sm text-end" min="1" /></td>
                    <td><input type="number" name="Lines[@i].UnitPriceNetMinor" value="@(line.UnitPriceNetMinor == 0 ? null : line.UnitPriceNetMinor)" class="form-control form-control-sm text-end" min="0" /></td>
                    <td><input type="number" name="Lines[@i].UnitPriceGrossMinor" value="@(line.UnitPriceGrossMinor == 0 ? null : line.UnitPriceGrossMinor)" class="form-control form-control-sm text-end" min="0" /></td>
                    <td><input type="number" step="0.0001" name="Lines[@i].TaxRate" value="@(line.TaxRate == 0 ? null : line.TaxRate)" class="form-control form-control-sm text-end" min="0" /></td>
                    <td><input type="number" name="Lines[@i].SortOrder" value="@line.SortOrder" class="form-control form-control-sm text-end" min="0" /></td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">@T.T("Save")</button>
        <a asp-action="Quotes" hx-get="@QuotesUrl()" hx-target="#sales-quote-editor-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("Cancel")</a>
    </div>
</form>
</div>
