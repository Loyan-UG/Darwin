@model Darwin.WebAdmin.ViewModels.Sales.ReturnOrdersListVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("ReturnOrders");
    var culture = System.Globalization.CultureInfo.CurrentCulture;
    string SalesOverviewUrl() => Url.Action("Index", "Sales") ?? string.Empty;
    string ReturnOrdersBaseUrl() => Url.Action("ReturnOrders", "Sales") ?? string.Empty;
    string ReturnOrderUrl(Guid id) => Url.Action("ReturnOrder", "Sales", new { id }) ?? string.Empty;
    string Money(string currency, long minor) => $"{currency} {(minor / 100.0M):0.00}";
    string DateText(DateTime? utc) => utc.HasValue ? utc.Value.ToString("g", culture) : "-";
}

<div id="sales-return-orders-workspace-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />
<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="mb-0"><i class="fa-solid fa-rotate-left"></i> @T.T("ReturnOrders")</h1>
        <div class="text-muted small mt-1">@T.T("ReturnOrdersSubtitle")</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" hx-get="@SalesOverviewUrl()" hx-target="#sales-return-orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("Overview")</a>
        <a asp-action="Orders" hx-get="@Url.Action("Orders", "Sales")" hx-target="#sales-return-orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("SalesOrders")</a>
        <a asp-action="DeliveryNotes" hx-get="@Url.Action("DeliveryNotes", "Sales")" hx-target="#sales-return-orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("DeliveryNotes")</a>
        <a asp-action="Invoices" hx-get="@Url.Action("Invoices", "Sales")" hx-target="#sales-return-orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-primary">@T.T("SalesInvoices")</a>
    </div>
</div>

<form asp-action="ReturnOrders" method="get" class="row g-2 align-items-end mb-3" hx-get="@ReturnOrdersBaseUrl()" hx-target="#sales-return-orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true">
    <div class="col-md-3">
        <label class="form-label small text-muted">@T.T("Search")</label>
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="@T.T("SearchReturnOrdersPlaceholder")" />
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">@T.T("Status")</label>
        <select name="filter" asp-items="Model.FilterItems" class="form-select"></select>
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">@T.T("CreatedFrom")</label>
        <input type="date" name="createdFromUtc" value="@Model.CreatedFromUtc?.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-md-2">
        <label class="form-label small text-muted">@T.T("CreatedTo")</label>
        <input type="date" name="createdToUtc" value="@Model.CreatedToUtc?.ToString("yyyy-MM-dd")" class="form-control" />
    </div>
    <div class="col-md-3 d-flex gap-2">
        <button class="btn btn-outline-secondary" type="submit">@T.T("Filter")</button>
        <a asp-action="ReturnOrders" hx-get="@ReturnOrdersBaseUrl()" hx-target="#sales-return-orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-outline-secondary">@T.T("ClearQueueFilters")</a>
    </div>
    <input type="hidden" name="businessId" value="@Model.BusinessId" />
    <input type="hidden" name="customerId" value="@Model.CustomerId" />
</form>

<div class="border rounded p-3 mb-3">
    <form asp-action="CreateReturnOrder" method="post" class="row g-2 align-items-end" hx-post="@Url.Action("CreateReturnOrder", "Sales")" hx-target="#sales-return-orders-workspace-shell" hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <div class="col-md-3">
            <label class="form-label small text-muted">@T.T("OrderId")</label>
            <input name="OrderId" value="@Model.Create.OrderId" class="form-control" required />
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">@T.T("ShipmentId")</label>
            <input name="ShipmentId" value="@Model.Create.ShipmentId" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted">@T.T("OrderLineId")</label>
            <input name="Lines[0].OrderLineId" class="form-control" required />
        </div>
        <div class="col-md-1">
            <label class="form-label small text-muted">@T.T("Quantity")</label>
            <input name="Lines[0].RequestedQuantity" type="number" min="1" value="1" class="form-control" required />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">@T.T("CreateReturnOrder")</button>
        </div>
    </form>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
        <tr>
            <th>@T.T("ReturnOrderNumber")</th>
            <th>@T.T("Status")</th>
            <th>@T.T("OrderId")</th>
            <th class="text-end">@T.T("Requested")</th>
            <th class="text-end">@T.T("Accepted")</th>
            <th class="text-end">@T.T("RefundEligible")</th>
            <th class="text-end">@T.T("LinkedRefund")</th>
            <th class="text-end">@T.T("RemainingRefund")</th>
            <th>@T.T("CreatedAt")</th>
            <th class="text-end">@T.T("Actions")</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="10" class="text-center text-muted">@T.T("NoReturnOrdersFound")</td></tr>
        }
        else
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@(item.ReturnOrderNumber ?? "-")</td>
                    <td>@T.T($"ReturnOrderStatus{item.Status}")</td>
                    <td>@item.OrderId</td>
                    <td class="text-end">@item.RequestedQuantity</td>
                    <td class="text-end">@item.AcceptedQuantity</td>
                    <td class="text-end">@Money(item.Currency, item.RefundEligibleGrossMinor)</td>
                    <td class="text-end">@Money(item.Currency, item.LinkedRefundGrossMinor)</td>
                    <td class="text-end">@Money(item.Currency, item.RemainingRefundGrossMinor)</td>
                    <td>@DateText(item.CreatedAtUtc)</td>
                    <td class="text-end">
                        <a asp-action="ReturnOrder" asp-route-id="@item.Id" hx-get="@ReturnOrderUrl(item.Id)" hx-target="#sales-return-orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true" class="btn btn-sm btn-outline-primary">@T.T("View")</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

<pager page="Model.Page" page-size="Model.PageSize" total="Model.Total" asp-controller="Sales" asp-action="ReturnOrders" asp-route-q="@Model.Query" asp-route-filter="@Model.Filter" asp-route-createdFromUtc="@Model.CreatedFromUtc" asp-route-createdToUtc="@Model.CreatedToUtc" asp-route-businessId="@Model.BusinessId" asp-route-customerId="@Model.CustomerId" hx-target="#sales-return-orders-workspace-shell" hx-swap="outerHTML" hx-push-url="true"></pager>
</div>
