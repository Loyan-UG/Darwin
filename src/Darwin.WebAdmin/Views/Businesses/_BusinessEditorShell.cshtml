@model Darwin.WebAdmin.ViewModels.Businesses.BusinessEditVm
@using System.Globalization
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    var isCreate = (bool?)ViewData["IsCreate"] == true || Model.Id == Guid.Empty;
    ViewData["Title"] = isCreate ? T.T("BusinessEditorCreateTitle") : T.T("BusinessEditorEditTitle");
    string BusinessMembersUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter? filter = null) =>
        Url.Action("Members", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessSubscriptionUrl(Guid? businessId) => Url.Action("Subscription", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessSetupUrl(Guid? id) => Url.Action("Setup", "Businesses", new { id }) ?? string.Empty;
    string BusinessLocationsUrl(Guid? businessId) => Url.Action("Locations", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessInvitationsUrl(Guid? businessId, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter? filter = null) =>
        Url.Action("Invitations", "Businesses", new { businessId, filter }) ?? string.Empty;
    string BusinessMerchantReadinessUrl(Guid? businessId) => Url.Action("MerchantReadiness", "Businesses", new { businessId }) ?? string.Empty;
    string BusinessSupportQueueUrl(Guid? businessId) => Url.Action("SupportQueue", "Businesses", new { businessId }) ?? string.Empty;
    string CreateMemberUrl(Guid? businessId) => Url.Action("CreateMember", "Businesses", new { businessId }) ?? string.Empty;
    string CreateLocationUrl(Guid? businessId) => Url.Action("CreateLocation", "Businesses", new { businessId }) ?? string.Empty;
    string CreateInvitationUrl(Guid? businessId) => Url.Action("CreateInvitation", "Businesses", new { businessId }) ?? string.Empty;
    string InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter filter) => filter switch
    {
        Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites => T.T("PendingInvites"),
        _ => T.T("Invitations")
    };
    string MemberWorkspaceLabel() => T.T("Members");
    string ChecklistBooleanLabel(bool isComplete) => isComplete ? T.T("Yes") : T.T("No");
}

<div id="business-editor-shell">
    <partial name="~/Views/Shared/_Alerts.cshtml" />

    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-1">@(isCreate ? T.T("BusinessEditorCreateTitle") : T.T("BusinessEditorEditTitle"))</h1>
            <p class="text-muted mb-0">@T.T("BusinessEditorIntro")</p>
        </div>
        @if (!isCreate)
        {
            <div class="d-flex gap-2">
                <a asp-action="Members"
                   asp-route-businessId="@Model.Id"
                   asp-route-filter="@(Model.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                   class="btn btn-outline-secondary"
                   hx-get="@BusinessMembersUrl(Model.Id, Model.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-user-group"></i> @T.T("CommonMembers")
                </a>
                <a asp-action="Subscription"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@BusinessSubscriptionUrl(Model.Id)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-credit-card"></i> @T.T("BusinessEditorSubscription")
                </a>
                <a asp-action="Setup"
                   asp-route-id="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@BusinessSetupUrl(Model.Id)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-sliders"></i> @T.T("CommonSetup")
                </a>
                <a asp-action="Locations"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@BusinessLocationsUrl(Model.Id)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-location-dot"></i> @T.T("BusinessEditorLocations")
                </a>
                <a asp-action="Invitations"
                   asp-route-businessId="@Model.Id"
                   asp-route-filter="@(Model.InvitationCount > 0 ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending : null)"
                   class="btn btn-outline-secondary"
                   hx-get="@BusinessInvitationsUrl(Model.Id, Model.InvitationCount > 0 ? Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending : null)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-envelope"></i> @T.T("BusinessEditorInvitations")
                </a>
            </div>
        }
    </div>

    @if (!isCreate)
    {
        var checklistComplete = Model.ActiveOwnerCount > 0 &&
                                Model.PrimaryLocationCount > 0 &&
                                Model.HasContactEmailConfigured &&
                                Model.HasLegalNameConfigured;

        <div class="row g-3 mb-3">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">@T.T("BusinessEditorOwners")</div>
                    <div class="fs-4 fw-semibold">@Model.ActiveOwnerCount</div>
                    <div class="mt-2">
                        <a asp-action="Members"
                           asp-route-businessId="@Model.Id"
                           asp-route-filter="@(Model.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                           class="btn btn-sm btn-outline-secondary"
                                hx-get="@BusinessMembersUrl(Model.Id, Model.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                           hx-target="#business-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@MemberWorkspaceLabel()</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">@T.T("CommonMembers")</div>
                    <div class="fs-4 fw-semibold">@Model.MemberCount</div>
                    <div class="mt-2">
                        <a asp-action="Members"
                           asp-route-businessId="@Model.Id"
                           asp-route-filter="@(Model.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                           class="btn btn-sm btn-outline-secondary"
                                hx-get="@BusinessMembersUrl(Model.Id, Model.ActiveOwnerCount > 0 ? null : Darwin.Application.Businesses.DTOs.BusinessMemberSupportFilter.Attention)"
                           hx-target="#business-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("CommonMembers")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">@T.T("BusinessEditorLocations")</div>
                    <div class="fs-4 fw-semibold">@Model.LocationCount</div>
                    <div class="mt-2">
                        <a asp-action="Locations"
                           asp-route-businessId="@Model.Id"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessLocationsUrl(Model.Id)"
                           hx-target="#business-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@T.T("Locations")</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small text-uppercase">@InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites)</div>
                    <div class="fs-4 fw-semibold">@Model.InvitationCount</div>
                    <div class="mt-2">
                        <a asp-action="Invitations"
                           asp-route-businessId="@Model.Id"
                           asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                           class="btn btn-sm btn-outline-secondary"
                           hx-get="@BusinessInvitationsUrl(Model.Id, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)"
                           hx-target="#business-editor-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@InvitationReadinessLabel(Darwin.Application.Businesses.DTOs.BusinessReadinessQueueFilter.PendingInvites)</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="border rounded p-3 mb-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <div class="text-muted small text-uppercase mb-1">@T.T("BusinessEditorOperationalStatus")</div>
                    @if (Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                    {
                        <span class="badge text-bg-warning">@T.T("BusinessEditorPendingApproval")</span>
                    }
                    else if (Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Approved)
                    {
                        <span class="badge text-bg-success">@T.T("BusinessEditorApproved")</span>
                    }
                    else
                    {
                        <span class="badge text-bg-danger">@T.T("BusinessEditorSuspended")</span>
                    }

                    @if (Model.ApprovedAtUtc.HasValue)
                    {
                    <div class="small text-muted mt-2">@string.Format(T.T("BusinessEditorApprovedAt"), Model.ApprovedAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</div>
                    }

                    @if (Model.SuspendedAtUtc.HasValue)
                    {
                    <div class="small text-muted mt-1">@string.Format(T.T("BusinessEditorSuspendedAt"), Model.SuspendedAtUtc.Value.ToLocalTime().ToString(CultureInfo.CurrentCulture))</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.SuspensionReason))
                    {
                        <div class="small text-muted mt-1">@string.Format(T.T("BusinessEditorReasonValue"), Model.SuspensionReason)</div>
                    }
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    @if (Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                    {
                        <form asp-action="Approve" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                            <button type="submit" class="btn btn-success">@T.T("BusinessEditorApprove")</button>
                        </form>
                    }
                    else if (Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)
                    {
                        <form asp-action="Reactivate" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                            <button type="submit" class="btn btn-success">@T.T("BusinessEditorReactivate")</button>
                        </form>
                    }

                    @if (Model.OperationalStatus != Darwin.Domain.Enums.BusinessOperationalStatus.Suspended)
                    {
                        <form asp-action="Suspend" method="post" class="d-flex gap-2 flex-wrap">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.RowVersion)" />
                                    <input type="text" name="note" class="form-control admin-min-w-240" placeholder="@T.T("BusinessEditorOptionalSuspensionReason")" />
                            <button type="submit" class="btn btn-outline-danger">@T.T("BusinessEditorSuspend")</button>
                        </form>
                    }

                    <a asp-action="MerchantReadiness"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-secondary"
                       hx-get="@BusinessMerchantReadinessUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                    <a asp-action="SupportQueue"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-secondary"
                       hx-get="@BusinessSupportQueueUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                </div>
            </div>
        </div>

        <div class="border rounded p-3 mb-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <div class="text-muted small text-uppercase mb-1">@T.T("BusinessEditorOnboardingChecklist")</div>
                    <div class="fw-semibold">@(checklistComplete ? T.T("BusinessEditorReadyForGoLiveReview") : T.T("BusinessEditorSetupStillIncomplete"))</div>
                </div>
                <div>
                    @if (checklistComplete)
                    {
                        <span class="badge text-bg-success">@T.T("BusinessEditorChecklistComplete")</span>
                    }
                    else
                    {
                        <span class="badge text-bg-warning">@T.T("BusinessEditorChecklistIncomplete")</span>
                    }
                </div>
            </div>

            <div class="row g-2 mt-2">
                <div class="col-md-6">
                    <div class="small">@ChecklistBooleanLabel(Model.ActiveOwnerCount > 0) - @T.T("BusinessEditorActiveOwnerAssigned")</div>
                </div>
                <div class="col-md-6">
                    <div class="small">@ChecklistBooleanLabel(Model.PrimaryLocationCount > 0) - @T.T("BusinessEditorPrimaryLocationConfigured")</div>
                </div>
                <div class="col-md-6">
                    <div class="small">@ChecklistBooleanLabel(Model.HasContactEmailConfigured) - @T.T("BusinessEditorContactEmailConfigured")</div>
                </div>
                <div class="col-md-6">
                    <div class="small">@ChecklistBooleanLabel(Model.HasLegalNameConfigured) - @T.T("BusinessEditorLegalBusinessNameConfigured")</div>
                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap mt-3">
                <a asp-action="Setup"
                   asp-route-id="@Model.Id"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessSetupUrl(Model.Id)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("Setup")</a>
                <a asp-action="MerchantReadiness"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-sm btn-outline-secondary"
                   hx-get="@BusinessMerchantReadinessUrl(Model.Id)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
            </div>
        </div>

        <div class="border rounded p-3 mb-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <div class="text-muted small text-uppercase mb-1">@T.T("BusinessEditorNextActions")</div>
                    <div class="fw-semibold">@T.T("BusinessEditorNextActionsIntro")</div>
                </div>
                @if (checklistComplete && Model.OperationalStatus == Darwin.Domain.Enums.BusinessOperationalStatus.PendingApproval)
                {
                    <span class="badge text-bg-info">@T.T("BusinessEditorReadyForApprovalReview")</span>
                }
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                @if (Model.ActiveOwnerCount == 0)
                {
                    <a asp-action="CreateMember"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-primary"
                       hx-get="@CreateMemberUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-user-plus"></i> @T.T("BusinessEditorAssignOwner")
                    </a>
                }
                @if (Model.PrimaryLocationCount == 0)
                {
                    <a asp-action="CreateLocation"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-outline-primary"
                       hx-get="@CreateLocationUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-location-dot"></i> @T.T("BusinessEditorAddPrimaryLocation")
                    </a>
                }
                @if (!Model.HasContactEmailConfigured || !Model.HasLegalNameConfigured)
                {
                    <a href="#business-core-fields" class="btn btn-outline-secondary">
                        <i class="fa-solid fa-pen-to-square"></i> @T.T("BusinessEditorCompleteBusinessProfile")
                    </a>
                }
                <a asp-action="CreateInvitation"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@CreateInvitationUrl(Model.Id)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-envelope"></i> @T.T("BusinessEditorInviteUser")
                </a>
                <a asp-action="Subscription"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@BusinessSubscriptionUrl(Model.Id)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-credit-card"></i> @T.T("BusinessEditorReviewSubscription")
                </a>
                <a asp-action="Setup"
                   asp-route-id="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@BusinessSetupUrl(Model.Id)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-sliders"></i> @T.T("BusinessEditorOpenSetupWorkspace")
                </a>
                @if (Model.InvitationCount > 0)
                {
                    <a asp-action="Invitations"
                       asp-route-businessId="@Model.Id"
                       asp-route-filter="@Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending"
                       class="btn btn-outline-secondary"
                       hx-get="@BusinessInvitationsUrl(Model.Id, Darwin.Application.Businesses.DTOs.BusinessInvitationQueueFilter.Pending)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">
                        <i class="fa-solid fa-list-check"></i> @T.T("BusinessEditorReviewInvitations")
                    </a>
                }
                <a asp-action="MerchantReadiness"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@BusinessMerchantReadinessUrl(Model.Id)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-list-check"></i> @T.T("MerchantReadinessTitle")
                </a>
                <a asp-action="SupportQueue"
                   asp-route-businessId="@Model.Id"
                   class="btn btn-outline-secondary"
                   hx-get="@BusinessSupportQueueUrl(Model.Id)"
                   hx-target="#business-editor-shell"
                   hx-swap="outerHTML"
                   hx-push-url="true">
                    <i class="fa-solid fa-life-ring"></i> @T.T("BusinessSupportQueueTitle")
                </a>
            </div>
        </div>

        @if (!checklistComplete)
        {
            <div class="alert alert-warning">
                <div>@T.T("BusinessEditorNotOnboardingCompleteYet")
                @if (Model.ActiveOwnerCount == 0)
                {
                    <span>@T.T("BusinessEditorAddAtLeastOneActiveOwner")</span>
                }
                @if (Model.ActiveOwnerCount == 0 && (Model.PrimaryLocationCount == 0 || !Model.HasContactEmailConfigured || !Model.HasLegalNameConfigured))
                {
                    <span class="mx-1">@T.T("And")</span>
                }
                @if (Model.PrimaryLocationCount == 0)
                {
                    <span>@T.T("BusinessEditorAddPrimaryLocationSentence")</span>
                }
                @if (Model.PrimaryLocationCount == 0 && (!Model.HasContactEmailConfigured || !Model.HasLegalNameConfigured))
                {
                    <span class="mx-1">@T.T("And")</span>
                }
                @if (!Model.HasContactEmailConfigured)
                {
                    <span>@T.T("BusinessEditorConfigureContactEmail")</span>
                }
                @if (!Model.HasContactEmailConfigured && !Model.HasLegalNameConfigured)
                {
                    <span class="mx-1">@T.T("And")</span>
                }
                @if (!Model.HasLegalNameConfigured)
                {
                    <span>@T.T("BusinessEditorCompleteLegalBusinessName")</span>
                }
                </div>
                <div class="d-flex gap-2 flex-wrap mt-3">
                    <a asp-action="Setup"
                       asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessSetupUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("Setup")</a>
                    <a asp-action="MerchantReadiness"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessMerchantReadinessUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("MerchantReadinessTitle")</a>
                    <a asp-action="SupportQueue"
                       asp-route-businessId="@Model.Id"
                       class="btn btn-sm btn-outline-secondary"
                       hx-get="@BusinessSupportQueueUrl(Model.Id)"
                       hx-target="#business-editor-shell"
                       hx-swap="outerHTML"
                       hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
                </div>
            </div>
        }
    }

    @if (!isCreate)
    {
        <div class="border rounded p-3 mb-3">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <h2 class="h5 mb-1">Business media</h2>
                    <p class="text-muted mb-0">Profile image and 1-10 gallery images used by Consumer discovery and profile pages.</p>
                </div>
                <span class="badge text-bg-secondary">@Model.MediaLibrary.Gallery.Count / 10</span>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-semibold mb-2">Profile image</div>
                        @if (!string.IsNullOrWhiteSpace(Model.MediaLibrary.ProfileImageUrl))
                        {
                            <img src="@Model.MediaLibrary.ProfileImageUrl" alt="@Model.Name profile" class="rounded-circle border mb-3" style="width:72px;height:72px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle border d-flex align-items-center justify-content-center mb-3" style="width:72px;height:72px;">@Model.Name.Take(2).Aggregate("", (s, c) => s + c).ToUpperInvariant()</div>
                        }
                        <form asp-action="UploadBusinessProfileImage" method="post" enctype="multipart/form-data" class="d-grid gap-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="businessId" value="@Model.Id" />
                            <input type="file" name="file" class="form-control" accept="image/*" />
                            <button type="submit" class="btn btn-sm btn-primary">Upload profile image</button>
                        </form>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="border rounded p-3 h-100">
                        <div class="fw-semibold mb-2">Gallery images</div>
                        <form asp-action="AddBusinessGalleryImage" method="post" enctype="multipart/form-data" class="row g-2 align-items-end mb-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="businessId" value="@Model.Id" />
                            <div class="col-md-5">
                                <label class="form-label small">Image</label>
                                <input type="file" name="file" class="form-control" accept="image/*" @(Model.MediaLibrary.Gallery.Count >= 10 ? "disabled" : "") />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Caption</label>
                                <input type="text" name="caption" class="form-control" maxlength="500" @(Model.MediaLibrary.Gallery.Count >= 10 ? "disabled" : "") />
                            </div>
                            <div class="col-md-3">
                                <div class="form-check mb-2">
                                    <input type="checkbox" name="isPrimary" value="true" class="form-check-input" id="business-media-primary" @(Model.MediaLibrary.Gallery.Count == 0 ? "checked" : "") @(Model.MediaLibrary.Gallery.Count >= 10 ? "disabled" : "") />
                                    <label for="business-media-primary" class="form-check-label small">Main image</label>
                                </div>
                                <button type="submit" class="btn btn-sm btn-primary w-100" @(Model.MediaLibrary.Gallery.Count >= 10 ? "disabled" : "")>Add image</button>
                            </div>
                        </form>

                        @if (Model.MediaLibrary.Gallery.Count == 0)
                        {
                            <div class="text-muted small">No gallery images uploaded yet.</div>
                        }
                        else
                        {
                            <div class="row g-2">
                                @foreach (var item in Model.MediaLibrary.Gallery.OrderByDescending(x => x.IsPrimary).ThenBy(x => x.SortOrder))
                                {
                                    <div class="col-md-6">
                                        <div class="border rounded p-2 h-100">
                                            <img src="@item.Url" alt="@item.Caption" class="rounded mb-2" style="width:100%;height:120px;object-fit:cover;" />
                                            <div class="d-flex justify-content-between align-items-center gap-2">
                                                <div class="small text-truncate">
                                                    <span class="fw-semibold">#@item.SortOrder</span>
                                                    @if (item.IsPrimary)
                                                    {
                                                        <span class="badge text-bg-warning ms-1">Main</span>
                                                    }
                                                </div>
                                                <div class="d-flex gap-1">
                                                    @if (!item.IsPrimary)
                                                    {
                                                        <form asp-action="SetBusinessGalleryPrimary" method="post">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="businessId" value="@Model.Id" />
                                                            <input type="hidden" name="mediaId" value="@item.Id" />
                                                            <input type="hidden" name="url" value="@item.Url" />
                                                            <input type="hidden" name="caption" value="@item.Caption" />
                                                            <input type="hidden" name="sortOrder" value="@item.SortOrder" />
                                                            <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                                            <button type="submit" class="btn btn-sm btn-outline-secondary">Set main</button>
                                                        </form>
                                                    }
                                                    <form asp-action="DeleteBusinessGalleryImage" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="businessId" value="@Model.Id" />
                                                        <input type="hidden" name="mediaId" value="@item.Id" />
                                                        <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(item.RowVersion)" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" @(Model.MediaLibrary.Gallery.Count <= 1 ? "disabled" : "")>Delete</button>
                                                    </form>
                                                </div>
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(item.Caption))
                                            {
                                                <div class="small text-muted mt-1">@item.Caption</div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <form asp-action="@(isCreate ? "Create" : "Edit")"
          method="post"
          hx-post="@Url.Action(isCreate ? "Create" : "Edit", "Businesses")"
          hx-target="#business-editor-shell"
          hx-swap="outerHTML"
          id="business-core-fields">
        @Html.AntiForgeryToken()
        @if (!isCreate)
        {
            <input type="hidden" asp-for="Id" />
            <input type="hidden" name="RowVersion" value="@(Model.RowVersion is null ? string.Empty : Convert.ToBase64String(Model.RowVersion))" />
        }

        <partial name="_BusinessForm" model="Model" />
    </form>
</div>
