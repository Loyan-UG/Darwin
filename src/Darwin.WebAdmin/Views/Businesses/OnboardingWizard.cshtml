@model Darwin.WebAdmin.ViewModels.Businesses.BusinessOnboardingWizardVm
@inject Darwin.WebAdmin.Localization.IAdminTextLocalizer T
@{
    ViewData["Title"] = T.T("BusinessOnboardingWizardTitle");
    string BusinessSetupUrl(Guid id) => Url.Action("Setup", "Businesses", new { id }) ?? string.Empty;
    string BusinessSupportQueueUrl(Guid businessId) => Url.Action("SupportQueue", "Businesses", new { businessId }) ?? string.Empty;
}

<div id="business-onboarding-wizard-shell">
<partial name="~/Views/Shared/_Alerts.cshtml" />

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="mb-1">@T.T("BusinessOnboardingWizardTitle")</h1>
        <p class="text-muted mb-0">@Model.Business.Name</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Setup"
           asp-route-id="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@BusinessSetupUrl(Model.Business.Id)"
           hx-target="#business-onboarding-wizard-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessSetupTitle")</a>
        <a asp-action="SupportQueue"
           asp-route-businessId="@Model.Business.Id"
           class="btn btn-outline-secondary"
           hx-get="@BusinessSupportQueueUrl(Model.Business.Id)"
           hx-target="#business-onboarding-wizard-shell"
           hx-swap="outerHTML"
           hx-push-url="true">@T.T("BusinessSupportQueueTitle")</a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
            <div>
                <div class="text-muted text-uppercase small fw-semibold">@T.T("GoLiveReadiness")</div>
                <h2 class="h5 mb-1">@T.T("BusinessOnboardingWizardSubtitle")</h2>
                <p class="text-muted mb-0">@T.T("BusinessOnboardingWizardIntro")</p>
            </div>
            <div class="text-end">
                <div class="fs-4 fw-semibold">@Model.CompletedRequiredStepCount / @Model.RequiredStepCount</div>
                <div class="small text-muted">@T.T("BusinessOnboardingWizardRequiredProgress")</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    @foreach (var step in Model.Steps)
    {
        var badgeClass = step.IsComplete
            ? "badge bg-success-subtle text-success-emphasis"
            : step.IsRequired ? "badge bg-warning-subtle text-warning-emphasis" : "badge bg-info-subtle text-info-emphasis";
        var badgeText = step.IsComplete
            ? T.T("Completed")
            : step.IsRequired ? T.T("NeedsAttention") : T.T("Optional");

        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                        <div>
                            <div class="text-muted small">@string.Format(T.T("BusinessOnboardingWizardStepNumber"), step.Number)</div>
                            <h2 class="h6 mb-0">@step.Title</h2>
                        </div>
                        <span class="@badgeClass">@badgeText</span>
                    </div>
                    <p class="text-muted small mb-0">@step.Summary</p>
                    @if (!string.IsNullOrWhiteSpace(step.ActionUrl))
                    {
                        <a href="@step.ActionUrl"
                           class="btn btn-sm btn-outline-primary mt-auto"
                           hx-get="@step.ActionUrl"
                           hx-target="#business-onboarding-wizard-shell"
                           hx-swap="outerHTML"
                           hx-push-url="true">@step.ActionLabel</a>
                    }
                </div>
            </div>
        </div>
    }
</div>

<div class="card border-0 shadow-sm mt-3">
    <div class="card-body d-flex justify-content-between align-items-center gap-3 flex-wrap">
        <div>
            <h2 class="h6 mb-1">@T.T("BusinessOnboardingWizardFinalActionTitle")</h2>
            <p class="text-muted mb-0">@T.T(Model.CanFinalize ? "BusinessOnboardingWizardFinalActionReady" : "FinalizeBusinessOnboardingBlocked")</p>
        </div>
        @if (Model.CanFinalize)
        {
            <form asp-action="ProvisionOnboarding" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Business.Id" />
                <input type="hidden" name="rowVersion" value="@Convert.ToBase64String(Model.Business.RowVersion)" />
                <input type="hidden" name="returnToSetup" value="true" />
                <button type="submit" class="btn btn-success">@T.T("FinalizeBusinessOnboarding")</button>
            </form>
        }
    </div>
</div>
</div>
