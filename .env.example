# Copy this file to .env for local Docker Desktop usage.
# Never commit .env because it contains local credentials.

DARWIN_POSTGRES_DB=darwin_dev
DARWIN_POSTGRES_USER=darwin
DARWIN_POSTGRES_PASSWORD=change-this-local-postgres-password

DARWIN_PGADMIN_EMAIL=admin@example.test
DARWIN_PGADMIN_PASSWORD=change-this-local-pgadmin-password

DARWIN_MSSQL_SA_PASSWORD=change-this-local-sqlserver-sa-password

DARWIN_MINIO_ROOT_USER=darwin-local-minio
DARWIN_MINIO_ROOT_PASSWORD=change-this-local-minio-password
DARWIN_MINIO_BUCKET=darwin-invoice-archive-smoke

# Optional local app overrides. Set these in your shell or user-secrets when running apps.
ConnectionStrings__PostgreSql=Host=localhost;Port=5432;Database=darwin_dev;Username=darwin;Password=change-this-local-postgres-password;Include Error Detail=true
ConnectionStrings__SqlServer=Server=localhost,11433;Database=Darwin_Dev;User Id=sa;Password=change-this-local-sqlserver-sa-password;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=darwin_dev;Username=darwin;Password=change-this-local-postgres-password;Include Error Detail=true
Persistence__Provider=PostgreSql

# Use false when running apps with a restricted runtime role after migrations/seed were applied by an owner role.
DatabaseStartup__ApplyMigrations=false
DatabaseStartup__Seed=false
